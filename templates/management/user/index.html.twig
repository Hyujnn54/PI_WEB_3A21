{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | User Management{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl">
            <h2 class="page-title">{{ module }}</h2>
            <p class="text-secondary mb-0">{{ description }}</p>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl">
            <div class="card">
                <div class="card-body">
                    <p class="mb-3">This area is ready for your teammate branch work.</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-primary" href="#">Admins</a>
                        <a class="btn btn-outline-primary" href="#">Candidates</a>
                        <a class="btn btn-outline-primary" href="#">Recruiters</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
