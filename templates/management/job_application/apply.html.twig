{% extends 'base.html.twig' %}

{% block title %}Apply for {{ offer.title }}{% endblock %}

{% block body %}
<style>
    .tb-apply-hero {
        background: linear-gradient(135deg, #f8fbff 0%, #eef4ff 100%);
        border: 1px solid #e6edf9;
        border-radius: 14px;
        padding: 18px 20px;
    }

    .tb-apply-layout {
        display: grid;
        grid-template-columns: 1.75fr 1fr;
        gap: 1rem;
    }

    .tb-apply-card {
        border: 1px solid #e8edf5;
        border-radius: 14px;
        background: #fff;
        box-shadow: 0 10px 24px rgba(25, 46, 89, 0.05);
    }

    .tb-apply-card .card-header {
        border-bottom: 1px solid #edf2f9;
        background: #fbfdff;
        border-top-left-radius: 14px;
        border-top-right-radius: 14px;
    }

    .tb-apply-section-title {
        font-size: 0.83rem;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        color: #5f7492;
        font-weight: 700;
        margin-bottom: 0.7rem;
    }

    .tb-apply-field .form-label {
        font-weight: 600;
        color: #24364e;
        margin-bottom: 0.45rem;
    }

    .tb-apply-field .form-control {
        border: 1px solid #d6dfeb;
        border-radius: 10px;
        padding: 0.64rem 0.75rem;
    }

    .tb-apply-field .form-control:focus {
        border-color: #96b7ef;
        box-shadow: 0 0 0 0.2rem rgba(68, 126, 217, 0.13);
    }

    .tb-apply-sidebar-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 0.7rem;
    }

    .tb-apply-sidebar-item {
        display: flex;
        align-items: start;
        gap: 0.55rem;
        color: #4d617d;
        font-size: 0.92rem;
    }

    .tb-apply-sidebar-item i {
        color: #3f6db4;
        margin-top: 0.1rem;
    }

    .tb-cv-box {
        border: 1px dashed #c8d6ec;
        border-radius: 11px;
        padding: 0.9rem;
        background: #f8fbff;
    }

    @media (max-width: 991.98px) {
        .tb-apply-layout {
            grid-template-columns: 1fr;
        }
    }
</style>
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <div class="tb-apply-hero">
                        <h2 class="page-title mb-1">Apply for {{ offer.title }}</h2>
                        <div class="text-secondary">
                            {{ offer.location }} &bull; {{ offer.contract_type }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            <div class="tb-apply-layout">
                <div class="tb-apply-card card">
                        <div class="card-header">
                        <h3 class="card-title mb-0">Job Application Form</h3>
                        </div>
                        <div class="card-body">
                            {{ form_start(form) }}

                            {{ form_errors(form) }}

                            <div class="tb-apply-section-title">Contact Information</div>
                            <div class="mb-3 tb-apply-field">
                                {{ form_label(form.phone) }}
                                {{ form_widget(form.phone, {'attr': {'class': 'form-control', 'placeholder': 'e.g. +216 12 345 678'}}) }}
                                {{ form_errors(form.phone) }}
                            </div>

                            <div class="tb-apply-section-title">Application Details</div>
                            <div class="mb-3 tb-apply-field">
                                {{ form_label(form.cover_letter) }}
                                {{ form_widget(form.cover_letter, {'attr': {'class': 'form-control', 'rows': '6', 'placeholder': 'Briefly describe why your profile matches this role...'}}) }}
                                {{ form_errors(form.cover_letter) }}
                            </div>

                            <div class="tb-apply-section-title">Curriculum Vitae</div>
                            <div class="tb-cv-box mb-3">
                                <div class="mb-3">
                                    <label class="form-check mb-1">
                                        {{ form_widget(form.use_profile_cv) }}
                                        <span class="form-check-label fw-semibold text-dark">{{ form_label(form.use_profile_cv) }}</span>
                                    </label>
                                    <small class="form-hint text-secondary">If selected, we will attach the CV currently saved in your profile.</small>
                                </div>

                                <div id="cv-upload-wrapper" class="tb-apply-field mb-0">
                                    {{ form_label(form.cv_file) }}
                                    {{ form_widget(form.cv_file, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(form.cv_file) }}
                                </div>
                            </div>

                            <div class="mt-4 d-flex gap-2">
                                <a href="{{ path('front_job_offers', {role: 'candidate'}) }}" class="btn btn-outline-secondary w-50">Cancel</a>
                                <button type="submit" class="btn btn-primary w-50">Submit Application</button>
                            </div>

                            {{ form_end(form) }}
                        </div>
                </div>

                <div class="tb-apply-card card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Application Summary</h3>
                    </div>
                    <div class="card-body">
                        <ul class="tb-apply-sidebar-list">
                            <li class="tb-apply-sidebar-item"><i class="ti ti-briefcase"></i><span><strong>Position:</strong> {{ offer.title }}</span></li>
                            <li class="tb-apply-sidebar-item"><i class="ti ti-map-pin"></i><span><strong>Location:</strong> {{ offer.location }}</span></li>
                            <li class="tb-apply-sidebar-item"><i class="ti ti-file-description"></i><span><strong>Contract:</strong> {{ offer.contract_type }}</span></li>
                            {% if offer.deadline is defined and offer.deadline %}
                                <li class="tb-apply-sidebar-item"><i class="ti ti-calendar-event"></i><span><strong>Deadline:</strong> {{ offer.deadline|date('d M Y') }}</span></li>
                            {% endif %}
                        </ul>
                        <hr>
                        <p class="text-secondary small mb-0">
                            Make sure your phone number and cover letter are accurate. Recruiters will use this information to contact you.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    (function () {
        const useProfileCvCheckbox = document.getElementById('{{ form.use_profile_cv.vars.id }}');
        const cvUploadWrapper = document.getElementById('cv-upload-wrapper');
        const cvFileInput = document.getElementById('{{ form.cv_file.vars.id }}');

        if (!useProfileCvCheckbox || !cvUploadWrapper) {
            return;
        }

        const updateCvUploadVisibility = function () {
            const useProfileCv = useProfileCvCheckbox.checked;
            cvUploadWrapper.classList.toggle('d-none', useProfileCv);

            if (cvFileInput) {
                cvFileInput.disabled = useProfileCv;
            }
        };

        updateCvUploadVisibility();
        useProfileCvCheckbox.addEventListener('change', updateCvUploadVisibility);
    })();
</script>
{% endblock %}