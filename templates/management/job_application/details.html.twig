{% extends 'base.html.twig' %}

{% block title %}Application Details{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h2 class="page-title"><i class="ti ti-file-description me-1"></i>Application Details</h2>
                <p class="text-secondary mb-0">Full details of your selected job application.</p>
            </div>
            <div class="d-flex gap-2">
                {% if application.current_status|upper == 'SUBMITTED' %}
                    <a href="{{ path('app_candidate_application_edit', {'applicationId': application.id}) }}" class="btn btn-primary">
                        <i class="ti ti-edit me-1"></i>Edit Application
                    </a>
                {% endif %}
                <a href="{{ path('front_job_applications', {role: 'candidate'}) }}" class="btn btn-outline-secondary">Back to My Applications</a>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            <div class="row g-3">
                <div class="col-12 col-lg-8">
                    <div class="card tb-admin-card">
                        <div class="card-header">
                            <h3 class="card-title mb-0">{{ offer ? offer.title : 'Unknown Offer' }}</h3>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="small text-secondary">Current Status</div>
                                    <div class="fw-semibold">{{ application.current_status }}</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="small text-secondary">Applied At</div>
                                    <div class="fw-semibold">{{ application.applied_at|date('d M Y H:i') }}</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="small text-secondary">Phone Number</div>
                                    <div class="fw-semibold">{{ application.phone }}</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="small text-secondary">CV File</div>
                                    {% set cvPath = (application.cv_path|default('')|trim) %}
                                    {% set cvPathNormalized = cvPath|replace({'\\': '/'}) %}
                                    {% set cvUrl = '' %}
                                    {% if cvPathNormalized != '' %}
                                        {% if cvPathNormalized starts with 'http://' or cvPathNormalized starts with 'https://' %}
                                            {% set cvUrl = cvPathNormalized %}
                                        {% elseif cvPathNormalized starts with '/' %}
                                            {% set cvUrl = cvPathNormalized %}
                                        {% elseif cvPathNormalized starts with 'public/' %}
                                            {% set cvUrl = asset(cvPathNormalized|slice(7)) %}
                                        {% elseif cvPathNormalized starts with 'uploads/' %}
                                            {% set cvUrl = asset(cvPathNormalized) %}
                                        {% else %}
                                            {% set cvUrl = asset('uploads/applications/' ~ cvPathNormalized) %}
                                        {% endif %}
                                    {% endif %}

                                    {% if cvUrl != '' %}
                                        <a class="btn btn-outline-primary btn-sm" href="{{ cvUrl }}" target="_blank" rel="noopener">
                                            <i class="ti ti-file-cv me-1"></i>Open CV
                                        </a>
                                    {% else %}
                                        <span class="badge bg-secondary-subtle text-secondary-emphasis">CV unavailable</span>
                                    {% endif %}
                                </div>
                                <div class="col-12">
                                    <div class="small text-secondary mb-1">Cover Letter</div>
                                    <div class="p-3 border rounded bg-light-subtle">{{ application.cover_letter }}</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-4">
                    <div class="card tb-admin-card">
                        <div class="card-header">
                            <h3 class="card-title mb-0">Offer Snapshot</h3>
                        </div>
                        <div class="card-body">
                            {% if offer %}
                                <div class="small text-secondary">Location</div>
                                <div class="fw-semibold mb-2">{{ offer.location }}</div>
                                <div class="small text-secondary">Contract Type</div>
                                <div class="fw-semibold mb-2">{{ offer.contract_type }}</div>
                                <div class="small text-secondary">Description</div>
                                <div>{{ offer.description }}</div>
                            {% else %}
                                <div class="text-secondary">Offer details are not available.</div>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card tb-admin-card">
                        <div class="card-header">
                            <h3 class="card-title mb-0"><i class="ti ti-history me-1"></i>Status History</h3>
                        </div>
                        <div class="card-body">
                            {% if historyEntries is not empty %}
                                <div class="list-group list-group-flush">
                                    {% for entry in historyEntries %}
                                        <div class="list-group-item px-0">
                                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                                <div>
                                                    <div class="fw-semibold">{{ entry.status }}</div>
                                                    <div class="text-secondary">{{ entry.note }}</div>
                                                </div>
                                                <div class="small text-secondary">{{ entry.changed_at|date('d M Y H:i') }}</div>
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <div class="text-secondary">No status history available yet.</div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
