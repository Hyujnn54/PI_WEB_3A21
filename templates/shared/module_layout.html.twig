{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | {{ module_title }}{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                <div>
                    <h2 class="page-title">{{ module_title }}</h2>
                    <p class="text-secondary mb-0">{{ module_subtitle }}</p>
                </div>
                <span class="badge bg-blue-lt text-uppercase">{{ module_scope }}</span>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            <div class="card mb-3">
                <div class="card-body d-flex flex-wrap gap-2">
                    {% for action in module_actions %}
                        <a class="btn {{ action.style|default('btn-outline-primary') }}" href="{{ action.href }}">{{ action.label }}</a>
                    {% endfor %}
                </div>
            </div>

            <div class="row row-cards">
                {% for metric in module_metrics %}
                    <div class="col-sm-6 col-lg-3">
                        <div class="card card-sm">
                            <div class="card-body">
                                <div class="text-secondary">{{ metric.label }}</div>
                                <div class="h2 m-0">{{ metric.value }}</div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <div class="card mt-3">
                <div class="card-header">
                    <h3 class="card-title">{{ table_title }}</h3>
                </div>
                <div class="table-responsive">
                    <table class="table table-vcenter card-table">
                        <thead>
                        <tr>
                            {% for head in table_headers %}
                                <th>{{ head }}</th>
                            {% endfor %}
                        </tr>
                        </thead>
                        <tbody>
                        {% for row in table_rows %}
                            <tr>
                                {% for cell in row %}
                                    <td>{{ cell }}</td>
                                {% endfor %}
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
