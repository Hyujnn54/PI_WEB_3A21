<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Talent Bridge{% endblock %}</title>
        <link rel="icon" type="image/png" href="{{ asset('assets/team_uploads/logo.png') }}">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Sora:wght@500;600;700;800&display=swap" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        <link href="https://cdn.jsdelivr.net/npm/@tabler/core@latest/dist/css/tabler.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
        <link rel="stylesheet" href="{{ asset('css/app.css') }}?v=20260407-2">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    {% set routeName = app.request.attributes.get('_route') %}
    {% set isAdminPage = routeName starts with 'management_' or routeName == 'back_dashboard' or routeName starts with 'app_admin' %}
    <body class="tb-body {{ isAdminPage ? 'tb-admin-body' : 'tb-front-body' }}">
        {% set queryRole = app.request.query.get('role') %}
        {% set currentRole = queryRole in ['candidate', 'recruiter'] ? queryRole : 'candidate' %}
        {% set unsafeRoleRoutes = ['front_interview_create', 'front_interview_edit', 'front_interview_delete', 'front_interview_feedback', 'front_application_set_status', 'front_job_offer_edit', 'front_job_offer_delete', 'app_candidate_apply', 'app_candidate_application_details', 'app_candidate_application_edit', 'app_candidate_application_withdraw', 'app_recruiter_application_details', 'management_job_applications_details'] %}
        {% set roleSwitchRoute = routeName in unsafeRoleRoutes ? 'front_interviews' : routeName %}
        <div class="page tb-page-shell">
            {% if not isAdminPage %}
            <header class="navbar navbar-expand-md navbar-light d-print-none tb-topbar">
                <div class="container-xl">
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#tbMainNav" aria-controls="tbMainNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <h1 class="navbar-brand navbar-brand-autodark mb-0 d-flex align-items-center">
                        <img src="{{ asset('assets/team_uploads/logo.png') }}" alt="Talent Bridge logo" class="tb-logo me-2" onerror="this.onerror=null; this.style.display='none'; this.nextElementSibling.classList.remove('d-none');">
                        <i class="ti ti-briefcase-2 text-primary me-2 d-none" style="font-size: 1.5rem;"></i>
                        <span class="tb-brand-text">Talent Bridge</span>
                    </h1>
                    <div class="collapse navbar-collapse" id="tbMainNav">
                        <ul class="navbar-nav tb-main-nav me-auto">
                            {% if isAdminPage %}
                                <li class="nav-item"><a class="nav-link" href="{{ path('management_users') }}"><span class="nav-link-icon d-md-none d-lg-inline-block"><i class="ti ti-users"></i></span><span class="nav-link-title">Users</span></a></li>
                                <li class="nav-item"><a class="nav-link" href="{{ path('back_dashboard') }}"><span class="nav-link-icon d-md-none d-lg-inline-block"><i class="ti ti-layout-dashboard"></i></span><span class="nav-link-title">Admin Dashboard</span></a></li>
                            {% else %}
                                <li class="nav-item"><a class="nav-link" href="{{ path('front_home', {role: currentRole}) }}"><span class="nav-link-icon d-md-none d-lg-inline-block"><i class="ti ti-home"></i></span><span class="nav-link-title">Home</span></a></li>
                                <li class="nav-item"><a class="nav-link" href="{{ path('front_job_offers', {role: currentRole}) }}"><span class="nav-link-icon d-md-none d-lg-inline-block"><i class="ti ti-briefcase-2"></i></span><span class="nav-link-title">Job Offers</span></a></li>
                                <li class="nav-item"><a class="nav-link" href="{{ path('front_job_applications', {role: currentRole}) }}"><span class="nav-link-icon d-md-none d-lg-inline-block"><i class="ti ti-file-check"></i></span><span class="nav-link-title">Applications</span></a></li>
                                <li class="nav-item"><a class="nav-link" href="{{ path('front_events', {role: currentRole}) }}"><span class="nav-link-icon d-md-none d-lg-inline-block"><i class="ti ti-calendar-event"></i></span><span class="nav-link-title">Events</span></a></li>
                                <li class="nav-item"><a class="nav-link" href="{{ path('front_interviews', {role: currentRole}) }}"><span class="nav-link-icon d-md-none d-lg-inline-block"><i class="ti ti-message-2"></i></span><span class="nav-link-title">Interviews</span></a></li>
                            {% endif %}
                        </ul>
                    </div>
                    <div class="navbar-nav flex-row order-md-last">
                        <div class="btn-list me-2">
                            <a class="btn btn-sm {{ currentRole == 'candidate' ? 'btn-primary' : 'btn-outline-primary' }}" href="{{ path(roleSwitchRoute, app.request.query.all|merge({role: 'candidate'})) }}">Candidate</a>
                            <a class="btn btn-sm {{ currentRole == 'recruiter' ? 'btn-primary' : 'btn-outline-primary' }}" href="{{ path(roleSwitchRoute, app.request.query.all|merge({role: 'recruiter'})) }}">Recruiter</a>
                        </div>
                        <div class="nav-item d-none d-md-flex me-2">
                            {% if isAdminPage %}
                                <a class="btn btn-sm btn-dark" href="{{ path('front_home', {role: currentRole}) }}">Front Portal</a>
                            {% else %}
                                <a class="btn btn-sm btn-dark" href="{{ path('back_dashboard') }}">Admin Panel</a>
                            {% endif %}
                        </div>
                        <div class="nav-item d-none d-md-flex me-2">
                            <a class="btn btn-sm btn-outline-primary" href="{{ path('app_login') }}"><i class="ti ti-user-circle me-1"></i>User Login</a>
                        </div>
                        <div class="nav-item d-none d-md-flex me-2">
                            <a class="btn btn-sm btn-primary" href="{{ path('app_register') }}">Register</a>
                        </div>
                        <div class="nav-item d-none d-md-flex">
                            <form method="post" action="{{ path('app_logout') }}">
                                <button class="btn btn-sm btn-outline-secondary" type="submit"><i class="ti ti-logout me-1"></i>Logout</button>
                            </form>
                        </div>
                    </div>
                </div>
            </header>
            {% endif %}
            {% if not isAdminPage %}
                <div class="container-xl mt-2">
                    {% for label in ['success', 'warning', 'error'] %}
                        {% for message in app.flashes(label) %}
                            <div class="alert alert-{{ label == 'error' ? 'danger' : (label == 'warning' ? 'warning' : 'success') }}" role="alert">{{ message }}</div>
                        {% endfor %}
                    {% endfor %}
                </div>
            {% endif %}
            {% block body %}{% endblock %}
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
        <script src="https://cdn.jsdelivr.net/npm/@tabler/core@latest/dist/js/tabler.min.js"></script>
        <script>
            document.querySelectorAll('.tb-filter-form').forEach(function (filterForm) {
                const targetSelector = filterForm.getAttribute('data-target');
                if (!targetSelector) {
                    return;
                }

                const grid = document.querySelector(targetSelector);
                if (!grid) {
                    return;
                }

                const searchInput = filterForm.querySelector('[data-filter-search]');
                const criteriaSelect = filterForm.querySelector('[data-filter-criteria]');
                const sortSelect = filterForm.querySelector('[data-filter-sort]');
                const resultLabel = filterForm.querySelector('[data-filter-results]');
                const items = Array.from(grid.querySelectorAll('.tb-filter-item'));

                items.forEach(function (item, index) {
                    item.dataset.originalIndex = String(index);
                });

                const runFilters = function () {
                    const query = ((searchInput && searchInput.value) || '').trim().toLowerCase();
                    const criteria = (criteriaSelect && criteriaSelect.value) || 'all';
                    const sortMode = (sortSelect && sortSelect.value) || 'default';

                    let visibleCount = 0;
                    items.forEach(function (item) {
                        let haystack = (item.dataset.filterText || '').toLowerCase();
                        if (criteria === 'title') {
                            haystack = (item.dataset.filterTitle || '').toLowerCase();
                        } else if (criteria === 'location') {
                            haystack = (item.dataset.filterLocation || '').toLowerCase();
                        } else if (criteria === 'contract_type') {
                            haystack = (item.dataset.filterContractType || '').toLowerCase();
                        } else if (criteria === 'status') {
                            haystack = (item.dataset.filterStatus || '').toLowerCase();
                        }

                        const isMatch = query === '' || haystack.includes(query);
                        item.classList.toggle('d-none', !isMatch);
                        if (isMatch) {
                            visibleCount += 1;
                        }
                    });

                    const sorted = items.slice().sort(function (a, b) {
                        if (sortMode === 'title_asc') {
                            return (a.dataset.sortTitle || '').localeCompare((b.dataset.sortTitle || ''));
                        }
                        if (sortMode === 'title_desc') {
                            return (b.dataset.sortTitle || '').localeCompare((a.dataset.sortTitle || ''));
                        }
                        if (sortMode === 'meta_asc') {
                            return (a.dataset.sortMeta || '').localeCompare((b.dataset.sortMeta || ''));
                        }
                        if (sortMode === 'meta_desc') {
                            return (b.dataset.sortMeta || '').localeCompare((a.dataset.sortMeta || ''));
                        }
                        if (sortMode === 'date_asc') {
                            return Number(a.dataset.sortDate || 0) - Number(b.dataset.sortDate || 0);
                        }
                        if (sortMode === 'date_desc') {
                            return Number(b.dataset.sortDate || 0) - Number(a.dataset.sortDate || 0);
                        }
                        if (sortMode === 'status_asc') {
                            return (a.dataset.sortStatus || '').localeCompare((b.dataset.sortStatus || ''));
                        }
                        if (sortMode === 'status_desc') {
                            return (b.dataset.sortStatus || '').localeCompare((a.dataset.sortStatus || ''));
                        }

                        return Number(a.dataset.originalIndex || 0) - Number(b.dataset.originalIndex || 0);
                    });

                    sorted.forEach(function (item) {
                        grid.appendChild(item);
                    });

                    if (resultLabel) {
                        resultLabel.textContent = visibleCount + ' result(s)';
                    }
                };

                if (searchInput) {
                    searchInput.addEventListener('input', runFilters);
                }
                if (sortSelect) {
                    sortSelect.addEventListener('change', runFilters);
                }
                if (criteriaSelect) {
                    criteriaSelect.addEventListener('change', runFilters);
                }

                runFilters();
            });

            document.querySelectorAll('.tb-detail-close').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    const panel = btn.closest('.tb-detail-panel');
                    if (!panel) return;
                    panel.classList.add('d-none');
                    panel.classList.remove('is-open');
                    document.querySelectorAll('.tb-module-card.is-selected').forEach(function (selectedCard) {
                        selectedCard.classList.remove('is-selected');
                    });
                });
            });

            document.querySelectorAll('.tb-module-card').forEach(function (card) {
                card.addEventListener('click', function (event) {
                    if (event.target.closest('a,button,input,select,textarea,form')) {
                        return;
                    }

                    document.querySelectorAll('.tb-module-card.is-selected').forEach(function (selectedCard) {
                        selectedCard.classList.remove('is-selected');
                    });
                    card.classList.add('is-selected');

                    const detailTarget = card.getAttribute('data-detail-target');
                    if (detailTarget) {
                        document.querySelectorAll('.tb-detail-panel').forEach(function (p) {
                            p.classList.add('d-none');
                            p.classList.remove('is-open');
                        });

                        const panel = document.querySelector(detailTarget);
                        if (panel) {
                            const meta = panel.querySelector('.tb-detail-meta');
                            const title = panel.querySelector('.tb-detail-title');
                            const text = panel.querySelector('.tb-detail-text');
                            const extra = panel.querySelector('.tb-detail-extra');
                            const primary = panel.querySelector('.tb-detail-primary');
                            const secondary = panel.querySelector('.tb-detail-secondary');
                            const tertiary = panel.querySelector('.tb-detail-tertiary');

                            if (meta) meta.textContent = card.getAttribute('data-detail-meta') || '';
                            if (title) title.textContent = card.getAttribute('data-detail-title') || 'Details';
                            if (text) text.textContent = card.getAttribute('data-detail-text') || '';

                            if (extra) {
                                const rawExtra = card.getAttribute('data-detail-extra') || '';
                                extra.innerHTML = '';

                                const appendValue = function (container, rawValue) {
                                    const valueText = (rawValue || '').trim();
                                    const isUrl = /^https?:\/\//i.test(valueText);
                                    if (isUrl) {
                                        const link = document.createElement('a');
                                        link.href = valueText;
                                        link.target = '_blank';
                                        link.rel = 'noopener noreferrer';
                                        link.textContent = valueText;
                                        container.appendChild(link);
                                        return;
                                    }

                                    const value = document.createElement('span');
                                    value.textContent = valueText;
                                    container.appendChild(value);
                                };

                                rawExtra.split('||').map(function (s) { return s.trim(); }).filter(Boolean).forEach(function (line) {
                                    const item = document.createElement('div');
                                    item.className = 'tb-detail-row';
                                    const splitIndex = line.indexOf(':');
                                    if (splitIndex > -1) {
                                        const key = document.createElement('strong');
                                        key.textContent = line.slice(0, splitIndex + 1) + ' ';
                                        item.appendChild(key);
                                        appendValue(item, line.slice(splitIndex + 1));
                                    } else {
                                        appendValue(item, line);
                                    }
                                    extra.appendChild(item);
                                });
                            }

                            if (primary) {
                                primary.textContent = card.getAttribute('data-action-primary') || 'Primary Action';
                                const href = card.getAttribute('data-action-primary-href') || '#';
                                if (primary.tagName === 'A') {
                                    primary.setAttribute('href', href);
                                }
                                const disabled = card.getAttribute('data-action-primary-disabled') === '1';
                                primary.classList.toggle('disabled', disabled);
                                primary.setAttribute('aria-disabled', disabled ? 'true' : 'false');
                            }
                            if (secondary) {
                                secondary.textContent = card.getAttribute('data-action-secondary') || 'Secondary Action';
                                const href = card.getAttribute('data-action-secondary-href') || '#';
                                const secondaryForm = secondary.closest('form');
                                if (secondaryForm) {
                                    secondaryForm.setAttribute('action', href);
                                } else if (secondary.tagName === 'A') {
                                    secondary.setAttribute('href', href);
                                }
                                const disabled = card.getAttribute('data-action-secondary-disabled') === '1';
                                secondary.classList.toggle('disabled', disabled);
                                secondary.setAttribute('aria-disabled', disabled ? 'true' : 'false');
                                if (secondary.tagName === 'BUTTON') {
                                    secondary.toggleAttribute('disabled', disabled);
                                }
                            }
                            if (tertiary) {
                                const tertiaryLabel = card.getAttribute('data-action-tertiary');
                                if (tertiaryLabel) {
                                    tertiary.textContent = tertiaryLabel;
                                    const href = card.getAttribute('data-action-tertiary-href') || '#';
                                    if (tertiary.tagName === 'A') {
                                        tertiary.setAttribute('href', href);
                                    }
                                    const disabled = card.getAttribute('data-action-tertiary-disabled') === '1';
                                    tertiary.classList.toggle('disabled', disabled);
                                    tertiary.setAttribute('aria-disabled', disabled ? 'true' : 'false');
                                    tertiary.classList.remove('d-none');
                                } else {
                                    tertiary.classList.add('d-none');
                                }
                            }

                            panel.classList.remove('d-none');
                            panel.classList.add('is-open');
                            return;
                        }
                    }

                    const href = card.getAttribute('data-href');
                    if (href && href !== '#') {
                        window.location.href = href;
                    }
                });
            });
        </script>
    </body>
</html>
