<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Talent Bridge{% endblock %}</title>
        <link rel="icon" type="image/png" href="{{ asset('assets/team_uploads/logo.png') }}">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        <link href="https://cdn.jsdelivr.net/npm/@tabler/core@latest/dist/css/tabler.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
        <link rel="stylesheet" href="{{ asset('css/app.css') }}?v=20260404-2">
        {% block stylesheets %}{% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body class="tb-body">
        {# Identify if we are in an Admin/Backoffice route #}
        {% set routeName = app.request.attributes.get('_route') %}
        {% set isAdminPage = routeName starts with 'management_' or routeName == 'back_dashboard' or routeName starts with 'app_admin' %}
        
        {# Get session data for roles #}
        {% set userRoles = app.session.get('user_roles')|default([]) %}
        
        <div class="page tb-page-shell">
            {% if not isAdminPage %}
            <header class="navbar navbar-expand-md navbar-light d-print-none tb-topbar">
                <div class="container-xl">
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#tbMainNav" aria-controls="tbMainNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <h1 class="navbar-brand navbar-brand-autodark mb-0 d-flex align-items-center">
                        <img src="{{ asset('assets/team_uploads/logo.png') }}" alt="Talent Bridge logo" class="tb-logo me-2">
                        <span class="tb-brand-text">Talent Bridge</span>
                    </h1>
                    
                    <div class="collapse navbar-collapse" id="tbMainNav">
                        <ul class="navbar-nav tb-main-nav me-auto">
                            <li class="nav-item"><a class="nav-link" href="{{ path('front_home') }}"><span class="nav-link-icon d-md-none d-lg-inline-block"><i class="ti ti-home"></i></span><span class="nav-link-title">Home</span></a></li>
                            <li class="nav-item"><a class="nav-link" href="{{ path('front_job_offers') }}"><span class="nav-link-icon d-md-none d-lg-inline-block"><i class="ti ti-briefcase-2"></i></span><span class="nav-link-title">Job Offers</span></a></li>
                            <li class="nav-item"><a class="nav-link" href="{{ path('front_events') }}"><span class="nav-link-icon d-md-none d-lg-inline-block"><i class="ti ti-calendar-event"></i></span><span class="nav-link-title">Events</span></a></li>
                        </ul>
                    </div>

                    <div class="navbar-nav flex-row order-md-last">
                        {% if app.session.get('user_id') %}
                            {# --- USER IS LOGGED IN --- #}
                            
                            <div class="nav-item d-none d-md-flex me-3">
                                <span class="navbar-text">Welcome, <strong>{{ app.session.get('user_name') }}</strong></span>
                            </div>

                            <div class="nav-item d-none d-md-flex me-2">
                                {# Show Admin Panel button ONLY for Admins #}
                                {% if 'ROLE_ADMIN' in userRoles %}
                                    <a class="btn btn-sm btn-dark" href="{{ path('back_dashboard') }}">Admin Panel</a>
                                {# Show Recruiter link ONLY for Recruiters #}
                                {% elseif 'ROLE_RECRUITER' in userRoles %}
                                    <a class="btn btn-sm btn-outline-primary" href="{{ path('front_home') }}">Recruiter Space</a>
                                {# Everyone else (Candidates) sees Applications #}
                                {% else %}
                                    <a class="btn btn-sm btn-primary" href="{{ path('front_job_applications') }}">My Applications</a>
                                {% endif %}
                            </div>

                            <div class="nav-item d-none d-md-flex">
                                <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_logout') }}">
                                    <i class="ti ti-logout me-1"></i>Logout
                                </a>
                            </div>

                        {% else %}
                            {# --- USER IS LOGGED OUT --- #}
                            <div class="nav-item d-none d-md-flex me-2">
                                <a class="btn btn-sm btn-outline-primary" href="{{ path('app_login') }}">
                                    <i class="ti ti-user-circle me-1"></i>User Login
                                </a>
                            </div>
                            <div class="nav-item d-none d-md-flex">
                                <a class="btn btn-sm btn-primary" href="{{ path('app_register') }}">Register</a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </header>
            {% endif %}

            <div class="container-xl mt-2">
                {% for label in ['success', 'warning', 'error'] %}
                    {% for message in app.flashes(label) %}
                        <div class="alert alert-{{ label == 'error' ? 'danger' : (label == 'warning' ? 'warning' : 'success') }}" role="alert">{{ message }}</div>
                    {% endfor %}
                {% endfor %}
            </div>

            {% block body %}{% endblock %}
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
        <script src="https://cdn.jsdelivr.net/npm/@tabler/core@latest/dist/js/tabler.min.js"></script>
    </body>
</html>