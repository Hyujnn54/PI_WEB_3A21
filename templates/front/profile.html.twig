{% extends 'base.html.twig' %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block title %}My Profile - Talent Bridge{% endblock %}
{% block body %}
{% set role = authUser.role|default('candidate') %}
<div class="container-xl py-5">
    <div class="row g-4 align-items-start">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body d-flex flex-wrap align-items-center justify-content-between gap-3">
                    <div class="d-flex align-items-center gap-3">
                        <img src="{{ asset('assets/team_upload/logo.png') }}" alt="Talent Bridge" style="width: 56px; height: 56px; object-fit: contain;" onerror="this.style.display='none'">
                        <div>
                            <h1 class="h3 mb-1 fw-bold">My Profile</h1>
                            <p class="text-muted mb-0">Manage your account settings and keep your information up to date.</p>
                        </div>
                    </div>
                    <span class="badge bg-blue-lt text-blue text-uppercase">{{ role }}</span>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-7">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h3 class="card-title mb-0">Account Information</h3>
                </div>
                <div class="card-body p-4">
                    {% if form %}
                        {{ form_start(form, {'attr': {'class': 'row g-3'}}) }}
                            <input type="hidden" name="profile_action" value="profile_update">

                            <div class="col-md-6">
                                {{ form_row(form.firstName) }}
                            </div>

                            <div class="col-md-6">
                                {{ form_row(form.lastName) }}
                            </div>

                            <div class="col-12">
                                {{ form_row(form.email) }}
                            </div>

                            <div class="col-12">
                                {{ form_row(form.phone) }}
                            </div>

                            <div class="col-12">
                                {{ form_row(form.plainPassword) }}
                            </div>

                            <div class="col-12 mt-3">
                                <button type="submit" class="btn btn-primary btn-lg px-4">
                                    <i class="ti ti-device-floppy me-2"></i>Save Changes
                                </button>
                            </div>
                        {{ form_end(form) }}
                    {% else %}
                        <div class="alert alert-warning mb-0">
                            Profile form not ready yet.
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {% if role == 'candidate' %}
            <div class="col-12 col-xl-5">
                <div class="card shadow-sm">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h3 class="card-title mb-0">My Skills</h3>
                        <span class="badge bg-azure-lt text-azure">Candidate Only</span>
                    </div>
                    <div class="card-body">
                        <form method="post" class="row g-2 mb-3" novalidate>
                            <input type="hidden" name="profile_action" value="skill_add">
                            <div class="col-12">
                                <label class="form-label mb-1">Skill Name</label>
                                    <input
                                        type="text"
                                        name="skill_name"
                                        id="skillInput"
                                        class="form-control"
                                        placeholder="e.g. Symfony, React, QA Automation"
                                        maxlength="100"
                                        autocomplete="off"
                                    >

                                    <div id="skillSuggestions" class="list-group mt-1"></div>
                            </div>
                            <div class="col-8">
                                <label class="form-label mb-1">Level</label>
                                <select name="skill_level" class="form-select">
                                    <option value="beginner">Beginner</option>
                                    <option value="intermediate">Intermediate</option>
                                    <option value="advanced">Advanced</option>
                                </select>
                            </div>
                            <div class="col-4 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary w-100">Add</button>
                            </div>
                        </form>

                        {% if candidateSkills is defined and candidateSkills is not empty %}
                            <div class="list-group list-group-flush">
                                {% for skill in candidateSkills %}
                                    <div class="list-group-item px-0">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <div class="fw-semibold">{{ skill.skillName }}</div>
                                                <small class="text-muted text-capitalize">{{ skill.level }}</small>
                                            </div>
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#skillEdit{{ skill.id }}" aria-expanded="false" aria-controls="skillEdit{{ skill.id }}">
                                                    <i class="ti ti-edit"></i>
                                                </button>
                                                <form method="post" class="d-inline" onsubmit="return confirm('Remove this skill?');">
                                                    <input type="hidden" name="profile_action" value="skill_delete">
                                                    <input type="hidden" name="skill_id" value="{{ skill.id }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        <i class="ti ti-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </div>

                                        <div class="collapse mt-3" id="skillEdit{{ skill.id }}">
                                            <form method="post" class="row g-2" novalidate>
                                                <input type="hidden" name="profile_action" value="skill_update">
                                                <input type="hidden" name="skill_id" value="{{ skill.id }}">

                                                <div class="col-12">
                                                    <input type="text" name="skill_name" class="form-control" maxlength="100" value="{{ skill.skillName }}">
                                                </div>
                                                <div class="col-8">
                                                    <select name="skill_level" class="form-select">
                                                        <option value="beginner" {{ skill.level == 'beginner' ? 'selected' : '' }}>Beginner</option>
                                                        <option value="intermediate" {{ skill.level == 'intermediate' ? 'selected' : '' }}>Intermediate</option>
                                                        <option value="advanced" {{ skill.level == 'advanced' ? 'selected' : '' }}>Advanced</option>
                                                    </select>
                                                </div>
                                                <div class="col-4 d-flex align-items-end">
                                                    <button type="submit" class="btn btn-primary w-100">Update</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="text-secondary">No skills added yet.</div>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endif %}

        <div class="col-12">
            <div class="text-center mt-2">
                <a href="{{ path('front_home') }}" class="btn btn-link text-muted">
                    <- Back to {{ role|capitalize }} Portal
                </a>
            </div>
        </div>
    </div>
</div>




<script>
(() => {
    const endpoint = "{{ path('api_skill_suggestions') }}";

    const initSkillSuggestions = () => {
        const input = document.getElementById("skillInput");
        const suggestionsBox = document.getElementById("skillSuggestions");
        if (!input || !suggestionsBox || input.dataset.suggestBound === "1") {
            return;
        }

        input.dataset.suggestBound = "1";

        let debounceTimer = null;
        let abortController = null;
        const localCache = new Map();

        const clearSuggestions = () => {
            suggestionsBox.innerHTML = "";
            suggestionsBox.classList.add("d-none");
        };

        const renderSuggestions = (skills) => {
            suggestionsBox.innerHTML = "";

            if (!Array.isArray(skills) || skills.length === 0) {
                clearSuggestions();
                return;
            }

            skills.forEach((skill) => {
                const item = document.createElement("button");
                item.type = "button";
                item.className = "list-group-item list-group-item-action";
                item.textContent = skill;
                item.addEventListener("click", () => {
                    input.value = skill;
                    clearSuggestions();
                    input.focus();
                });
                suggestionsBox.appendChild(item);
            });

            suggestionsBox.classList.remove("d-none");
        };

        input.addEventListener("input", () => {
            const query = input.value.trim();

            if (query.length < 2) {
                clearTimeout(debounceTimer);
                if (abortController) {
                    abortController.abort();
                }
                clearSuggestions();
                return;
            }

            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => {
                const normalized = query.toLowerCase();
                if (localCache.has(normalized)) {
                    renderSuggestions(localCache.get(normalized));
                    return;
                }

                if (abortController) {
                    abortController.abort();
                }
                abortController = new AbortController();

                fetch(endpoint + "?q=" + encodeURIComponent(query), {
                    signal: abortController.signal,
                    headers: { "X-Requested-With": "XMLHttpRequest" }
                })
                    .then((response) => response.ok ? response.json() : [])
                    .then((data) => {
                        localCache.set(normalized, data);
                        renderSuggestions(data);
                    })
                    .catch((error) => {
                        if (error.name !== "AbortError") {
                            clearSuggestions();
                        }
                    });
            }, 220);
        });

        input.addEventListener("blur", () => {
            setTimeout(clearSuggestions, 120);
        });

        input.addEventListener("focus", () => {
            const query = input.value.trim().toLowerCase();
            if (query.length >= 2 && localCache.has(query)) {
                renderSuggestions(localCache.get(query));
            }
        });
    };

    document.addEventListener("DOMContentLoaded", initSkillSuggestions);
    document.addEventListener("turbo:load", initSkillSuggestions);
})();
</script>
{% endblock %}
