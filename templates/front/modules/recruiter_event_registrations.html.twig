{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Event Registrations{% endblock %}

{% block body %}
{% set role = authUser.role|default('recruiter') %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h2 class="page-title"><i class="ti ti-users-group me-1"></i>Event Registrations</h2>
                <p class="text-secondary mb-0">View and manage candidate registrations for your events.</p>
            </div>
            <div class="d-flex gap-2">
                <a href="{{ path('front_events', {'role': 'recruiter'}) }}" class="btn btn-outline-primary">Back to Events</a>
            </div>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl">
            {% if role == 'recruiter' and urgentNotifications is defined and urgentNotifications is not empty %}
                <div class="alert alert-danger mb-4" role="alert">
                    <div class="d-flex align-items-start gap-2">
                        <i class="ti ti-alert-triangle fs-3"></i>
                        <div>
                            <h4 class="alert-title mb-2">Urgent Pending Event Decisions</h4>
                            <div class="small">Some events are approaching and still have candidate registrations waiting for your action.</div>
                            <ul class="mb-0 mt-2 ps-3">
                                {% for item in urgentNotifications %}
                                    <li>
                                        <strong>{{ item.title }}</strong>
                                        : {{ item.pending_count }} pending {{ item.pending_count > 1 ? 'registrations' : 'registration' }} | starts {{ item.event_date|time_diff }} ({{ item.event_date|date('d M Y H:i') }})
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>
                </div>
            {% endif %}

            {% if events is not empty %}
                {% for event in events %}
                    <div class="card mb-4 {{ role == 'recruiter' and event.is_urgent ? 'border-danger shadow-sm' : '' }}">
                        <div class="card-header {{ role == 'recruiter' and event.is_urgent ? 'bg-danger-lt' : 'bg-light' }}">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h4 class="card-title mb-1">{{ event.title }}</h4>
                                    <p class="text-muted mb-0">{{ event.meta }}</p>
                                </div>
                                <div class="d-flex gap-2 align-items-center">
                                    <span class="badge bg-light text-dark border">{{ event.event_type }}</span>
                                    {% if role == 'recruiter' and event.is_urgent %}
                                        <span class="badge bg-danger">Urgent</span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            {% if role == 'recruiter' and event.is_urgent %}
                                <div class="alert alert-danger mb-3 py-2" role="alert">
                                    <i class="ti ti-bell-ringing me-2"></i>
                                    This event starts <strong>{{ event.date|time_diff }}</strong> and still has
                                    <strong>{{ event.pending_actions_count }}</strong> pending {{ event.pending_actions_count > 1 ? 'registrations' : 'registration' }} to review.
                                </div>
                            {% endif %}

                            <div class="row mb-3">
                                <div class="col-md-3">
                                    <dl class="small">
                                        <dt class="text-muted">Location</dt>
                                        <dd>{{ event.location }}</dd>
                                    </dl>
                                </div>
                                <div class="col-md-3">
                                    <dl class="small">
                                        <dt class="text-muted">Capacity</dt>
                                        <dd>{{ event.capacity }}</dd>
                                    </dl>
                                </div>
                                <div class="col-md-6">
                                    <div class="alert alert-info mb-0">
                                        <i class="ti ti-users me-2"></i>
                                        <strong>Registered Candidates:</strong> {{ event.registration_count }} / {{ event.capacity }}
                                        {% if role == 'recruiter' %}
                                            <br>
                                            <strong>Pending Actions:</strong> {{ event.pending_actions_count }}
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            
                            <div class="table-responsive">
                                <table class="table table-sm mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Candidate Name</th>
                                            <th>Email</th>
                                            <th>Registration Date</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% if event.registrations is not empty %}
                                            {% for candidate in event.registrations %}
                                                <tr>
                                                    <td>{{ candidate.name }}</td>
                                                    <td>{{ candidate.email }}</td>
                                                    <td>{{ candidate.registered_at|date('d M Y H:i') }}</td>
                                                    <td>
                                                        {% if candidate.status == 'confirmed' %}
                                                            <span class="badge bg-success">Confirmed</span>
                                                        {% elseif candidate.status == 'rejected' %}
                                                            <span class="badge bg-danger">Rejected</span>
                                                        {% else %}
                                                            <span class="badge bg-warning">Under Review</span>
                                                        {% endif %}
                                                    </td>
                                                    <td>
                                                        <div class="btn-list flex-nowrap">
                                                            <form method="post" action="{{ path('recruiter_update_registration_status', {'id': candidate.registration_id}) }}" class="d-inline">
                                                                <input type="hidden" name="status" value="confirmed">
                                                                <button type="submit" class="btn btn-icon btn-outline-success btn-sm" title="Confirm Attendance"><i class="ti ti-check"></i></button>
                                                            </form>
                                                            <form method="post" action="{{ path('recruiter_update_registration_status', {'id': candidate.registration_id}) }}" class="d-inline">
                                                                <input type="hidden" name="status" value="rejected">
                                                                <button type="submit" class="btn btn-icon btn-outline-danger btn-sm" title="Reject"><i class="ti ti-x"></i></button>
                                                            </form>
                                                        </div>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        {% else %}
                                            <tr class="text-muted">
                                                <td colspan="5" class="text-center py-3">No candidates registered for this event yet.</td>
                                            </tr>
                                        {% endif %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                {% endfor %}

                {% if eventsPagination is defined and eventsPagination.getPageCount() > 1 %}
                    <div class="d-flex justify-content-center mt-4">
                        {{ knp_pagination_render(eventsPagination) }}
                    </div>
                {% endif %}
            {% else %}
                <div class="card">
                    <div class="card-body text-center text-secondary">
                        You haven't created any events yet. Create an event to start receiving candidate registrations.
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
