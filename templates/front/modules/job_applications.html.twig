{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Job Applications{% endblock %}

{% block body %}
{% set role = authUser.role|default('candidate') %}
<style>
    .tb-create-locked,
    .tb-create-locked:hover,
    .tb-create-locked:focus,
    .tb-create-locked:active {
        pointer-events: none !important;
        cursor: not-allowed !important;
        transform: none !important;
        box-shadow: none !important;
        filter: none !important;
        opacity: 1 !important;
        background: #8e9aac !important;
        border-color: #8e9aac !important;
        color: #ffffff !important;
    }

    .tb-dock-reason {
        font-size: 0.82rem;
        color: #c06d00;
        white-space: nowrap;
    }
</style>
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h2 class="page-title"><i class="ti ti-file-check me-1"></i>Job Applications</h2>
                <p class="text-secondary mb-0">{{ role == 'recruiter' ? 'Evaluate applicant profiles and move them through your pipeline.' : 'Track each application and monitor your progress.' }}</p>
            </div>
            <div class="d-flex gap-2">
                <a href="#" class="btn btn-primary">{{ role == 'recruiter' ? 'Review Queue' : 'My Pipeline' }}</a>
                <a href="#" class="btn btn-outline-primary">Status Timeline</a>
            </div>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl tb-interviews-page">
            <div class="row g-3 tb-interviews-layout">
                <div class="col-12 col-xl-8">
            <div class="card tb-admin-card mb-3 tb-filter-bar">
                <div class="card-body py-2">
                    <div class="tb-filter-form d-flex flex-wrap align-items-center gap-2" data-target="#applicationCardsGrid">
                        <div class="input-icon">
                            <span class="input-icon-addon"><i class="ti ti-search"></i></span>
                            <input type="text" class="form-control" placeholder="Search applications by id, offer, status..." data-filter-search>
                        </div>
                        <select class="form-select" style="max-width: 220px;" data-filter-criteria>
                            <option value="all">Search In: All</option>
                            <option value="title">Title</option>
                            <option value="meta">Meta</option>
                            <option value="description">Description</option>
                        </select>
                        <select class="form-select" style="max-width: 230px;" data-filter-sort>
                            <option value="default">Default Order</option>
                            <option value="title_asc">Title A-Z</option>
                            <option value="title_desc">Title Z-A</option>
                            <option value="meta_asc">Meta A-Z</option>
                            <option value="meta_desc">Meta Z-A</option>
                        </select>
                        <div class="small text-secondary ms-auto" data-filter-results></div>
                    </div>
                </div>
            </div>

            <div id="applicationCardsGrid" class="row row-cards">
                {% for card in cards %}
                    {% set canCreateInterview = card.can_create_interview|default(true) %}
                    <div class="col-md-6 col-xl-4 tb-filter-item" data-filter-text="{{ (card.meta ~ ' ' ~ card.title ~ ' ' ~ card.text)|lower }}" data-filter-title="{{ card.title|lower }}" data-filter-meta="{{ card.meta|lower }}" data-filter-description="{{ card.text|lower }}" data-sort-title="{{ card.title|lower }}" data-sort-meta="{{ card.meta|lower }}">
                        <div class="tb-module-card h-100" data-detail-target="#applicationDetailPanel" data-detail-meta="{{ card.meta }}" data-detail-title="{{ card.title }}" data-detail-text="{{ card.text }}" data-accept-url="{{ card.accept_url|default('#') }}" data-decline-url="{{ card.decline_url|default('#') }}" data-create-url="{{ card.create_interview_url|default('#') }}" data-create-disabled="{{ canCreateInterview ? '0' : '1' }}" data-create-reason="{{ card.interview_block_reason|default('Interview already exists for this application.')|e('html_attr') }}" data-detail-extra="Application: {{ card.meta }}{% if role == 'recruiter' and not canCreateInterview %}||Reason: {{ card.interview_block_reason|default('Interview already exists for this application.') }}{% endif %}">
                            <div class="tb-module-meta">{{ card.meta }}</div>
                            <h3>{{ card.title }}</h3>
                            <p>{{ card.text }}</p>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12">
                        <div class="card tb-admin-card">
                            <div class="card-body text-secondary">No job applications found in the database.</div>
                        </div>
                    </div>
                {% endfor %}
            </div>

                </div>
                <div class="col-12 col-xl-4">
            <div id="applicationDetailPanel" class="card tb-detail-panel tb-detail-panel-side">
                <div class="card-header">
                    <div>
                        <div class="small text-secondary tb-detail-meta"></div>
                        <h3 class="card-title mb-0 tb-detail-title">Application Details</h3>
                    </div>
                </div>
                <div class="card-body">
                    <p class="mb-3 tb-detail-text">Select an application card to display details here.</p>
                    <div class="tb-detail-extra small text-secondary mb-0"></div>
                </div>
            </div>
                </div>
            </div>

            <div id="applicationActionDock" class="tb-interview-action-dock d-none">
                <div class="container-xl">
                    <div class="tb-interview-action-dock-inner">
                        <div class="small text-secondary" id="applicationActionLabel">Select an application to unlock actions</div>
                        <div class="d-flex gap-2 align-items-center tb-interview-action-buttons">
                            <form method="post" action="#" class="d-inline" id="applicationAcceptForm">
                                <button type="submit" class="btn btn-outline-success" id="applicationAcceptBtn"><i class="ti ti-check me-1"></i>Accept</button>
                            </form>
                            <form method="post" action="#" class="d-inline" id="applicationDeclineForm">
                                <button type="submit" class="btn btn-outline-danger" id="applicationDeclineBtn"><i class="ti ti-x me-1"></i>Decline</button>
                            </form>
                            <button type="button" class="btn btn-primary" id="applicationCreateBtn"><i class="ti ti-calendar-plus me-1"></i>Create Interview</button>
                            <span class="tb-dock-reason d-none" id="applicationCreateReason"><i class="ti ti-alert-circle me-1"></i><span></span></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="createInterviewModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-lg modal-dialog-centered">
                    <div class="modal-content tb-admin-card">
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="ti ti-calendar-plus me-1"></i>Create Interview</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <form id="createInterviewForm" method="post">
                            <div class="modal-body row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Scheduled At</label>
                                    <input type="datetime-local" name="scheduled_at" class="form-control" required>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Duration</label>
                                    <input type="number" min="15" max="240" name="duration_minutes" class="form-control" value="60" required>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Mode</label>
                                    <select name="mode" class="form-select" required>
                                        <option value="online">Online</option>
                                        <option value="onsite">Onsite</option>
                                    </select>
                                </div>
                                <div class="col-md-6" data-online-field>
                                    <label class="form-label">Meeting Link (online)</label>
                                    <input type="url" name="meeting_link" class="form-control" placeholder="https://...">
                                </div>
                                <div class="col-md-6" data-onsite-field>
                                    <label class="form-label">Room (onsite)</label>
                                    <input type="text" name="location" class="form-control" placeholder="Room / Office location">
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Additional Notes</label>
                                    <textarea name="notes" rows="3" class="form-control"></textarea>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Confirm</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const modalEl = document.getElementById('createInterviewModal');
        const formEl = document.getElementById('createInterviewForm');
        if (!modalEl || !formEl || typeof bootstrap === 'undefined') {
            return;
        }

        const modal = new bootstrap.Modal(modalEl);
        const modeSelect = formEl.querySelector('select[name="mode"]');
        const scheduleInput = formEl.querySelector('input[name="scheduled_at"]');
        const meetingInput = formEl.querySelector('input[name="meeting_link"]');
        const locationInput = formEl.querySelector('input[name="location"]');
        const onlineField = formEl.querySelector('[data-online-field]');
        const onsiteField = formEl.querySelector('[data-onsite-field]');
        const actionDock = document.getElementById('applicationActionDock');
        const actionLabel = document.getElementById('applicationActionLabel');
        const acceptForm = document.getElementById('applicationAcceptForm');
        const declineForm = document.getElementById('applicationDeclineForm');
        const createBtn = document.getElementById('applicationCreateBtn');
        const createReason = document.getElementById('applicationCreateReason');
        let selectedCard = null;

        const now = new Date();
        const minValue = new Date(now.getTime() - now.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
        if (scheduleInput) {
            scheduleInput.min = minValue;
        }

        const applyModeFields = function () {
            const mode = modeSelect ? modeSelect.value : 'online';
            if (mode === 'onsite') {
                if (onlineField) onlineField.classList.add('d-none');
                if (onsiteField) onsiteField.classList.remove('d-none');
                if (meetingInput) {
                    meetingInput.value = '';
                    meetingInput.required = false;
                }
                if (locationInput) locationInput.required = true;
            } else {
                if (onsiteField) onsiteField.classList.add('d-none');
                if (onlineField) onlineField.classList.remove('d-none');
                if (locationInput) {
                    locationInput.value = '';
                    locationInput.required = false;
                }
                if (meetingInput) meetingInput.required = true;
            }
        };

        if (modeSelect) {
            modeSelect.addEventListener('change', applyModeFields);
        }

        const openCreateModal = function (createUrl) {
            if (!createUrl || createUrl === '#') return;
            formEl.setAttribute('action', createUrl);
            if (modeSelect) modeSelect.value = 'online';
            if (scheduleInput) scheduleInput.min = minValue;
            applyModeFields();
            modal.show();
        };

        const syncDockFromCard = function (card) {
            if (!card || !actionDock) return;
            const acceptUrl = card.getAttribute('data-accept-url') || '#';
            const declineUrl = card.getAttribute('data-decline-url') || '#';
            const createUrl = card.getAttribute('data-create-url') || '#';
            const createDisabled = card.getAttribute('data-create-disabled') === '1';
            const reason = card.getAttribute('data-create-reason') || 'Interview already exists for this application.';

            if (acceptForm) acceptForm.setAttribute('action', acceptUrl);
            if (declineForm) declineForm.setAttribute('action', declineUrl);

            if (createBtn) {
                createBtn.setAttribute('data-create-url', createUrl);
                createBtn.classList.toggle('tb-create-locked', createDisabled);
                createBtn.toggleAttribute('disabled', createDisabled);
                createBtn.setAttribute('aria-disabled', createDisabled ? 'true' : 'false');
            }

            if (createReason) {
                const text = createReason.querySelector('span');
                if (createDisabled) {
                    if (text) text.textContent = reason;
                    createReason.classList.remove('d-none');
                } else {
                    createReason.classList.add('d-none');
                    if (text) text.textContent = '';
                }
            }

            if (actionLabel) {
                actionLabel.textContent = (card.getAttribute('data-detail-title') || 'Selected application') + ' actions';
            }

            actionDock.classList.remove('d-none');
        };

        document.querySelectorAll('#applicationCardsGrid .tb-module-card').forEach(function (card) {
            card.addEventListener('click', function () {
                selectedCard = card;
                setTimeout(function () {
                    syncDockFromCard(card);
                }, 0);
            });
        });

        if (createBtn) {
            createBtn.addEventListener('click', function () {
                if (!selectedCard) return;
                if (createBtn.disabled || createBtn.classList.contains('tb-create-locked')) return;
                openCreateModal(createBtn.getAttribute('data-create-url') || '#');
            });
        }

        const params = new URLSearchParams(window.location.search);
        const openCreateFor = params.get('openCreateFor');
        if (openCreateFor) {
            const card = document.querySelector('#applicationCardsGrid .tb-module-card[data-create-url*="/' + openCreateFor + '"]');
            if (card) {
                selectedCard = card;
                syncDockFromCard(card);
                if (card.getAttribute('data-create-disabled') !== '1') {
                    openCreateModal(card.getAttribute('data-create-url') || '#');
                }
            }
        }

        applyModeFields();
    });
</script>
{% endblock %}
