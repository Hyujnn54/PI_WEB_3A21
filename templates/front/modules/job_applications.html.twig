{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Job Applications{% endblock %}

{% block body %}
{% set role = authUser.role|default('candidate') %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h2 class="page-title"><i class="ti ti-file-check me-1"></i>Job Applications</h2>
                <p class="text-secondary mb-0">{{ role == 'recruiter' ? 'Evaluate applicant profiles and move them through your pipeline.' : 'Track each application and monitor your progress.' }}</p>
            </div>
            <div class="d-flex gap-2">
                <a href="#" class="btn btn-primary">{{ role == 'recruiter' ? 'Review Queue' : 'My Pipeline' }}</a>
                <a href="#" class="btn btn-outline-primary">Status Timeline</a>
            </div>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl">
            <div class="card tb-admin-card mb-3 tb-filter-bar">
                <div class="card-body py-2">
                    <div class="tb-filter-form d-flex flex-wrap align-items-center gap-2" data-target="#applicationCardsGrid">
                        <div class="input-icon">
                            <span class="input-icon-addon"><i class="ti ti-search"></i></span>
                            <input type="text" class="form-control" placeholder="Search applications by id, offer, status..." data-filter-search>
                        </div>
                        <select class="form-select" style="max-width: 230px;" data-filter-sort>
                            <option value="default">Default Order</option>
                            <option value="title_asc">Title A-Z</option>
                            <option value="title_desc">Title Z-A</option>
                            <option value="meta_asc">Meta A-Z</option>
                            <option value="meta_desc">Meta Z-A</option>
                        </select>
                        <div class="small text-secondary ms-auto" data-filter-results></div>
                    </div>
                </div>
            </div>

            <div id="applicationCardsGrid" class="row row-cards">
                {% for card in cards %}
                    <div class="col-md-6 col-xl-4 tb-filter-item" data-filter-text="{{ (card.meta ~ ' ' ~ card.title ~ ' ' ~ card.text)|lower }}" data-sort-title="{{ card.title|lower }}" data-sort-meta="{{ card.meta|lower }}">
                        <div class="tb-module-card h-100" data-detail-target="#applicationDetailPanel" data-detail-meta="{{ card.meta }}" data-detail-title="{{ card.title }}" data-detail-text="{{ card.text }}" data-action-primary="{{ role == 'recruiter' ? 'Advance Stage' : 'Track Status' }}" data-action-secondary="{{ role == 'recruiter' ? 'Add Interview' : 'Update Profile' }}" data-action-tertiary="{{ role == 'recruiter' ? 'Add Feedback' : 'Withdraw Application' }}">
                            <div class="tb-module-meta">{{ card.meta }}</div>
                            <h3>{{ card.title }}</h3>
                            <p>{{ card.text }}</p>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12">
                        <div class="card tb-admin-card">
                            <div class="card-body text-secondary">No job applications found in the database.</div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <div id="applicationDetailPanel" class="card tb-detail-panel mt-4 d-none">
                <div class="card-header">
                    <div>
                        <div class="small text-secondary tb-detail-meta"></div>
                        <h3 class="card-title mb-0 tb-detail-title">Application Details</h3>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary tb-detail-close tb-detail-close-icon ms-auto" aria-label="Close details panel"><i class="ti ti-x"></i></button>
                </div>
                <div class="card-body">
                    <p class="mb-3 tb-detail-text">Click an application card to reveal timeline and action placeholders.</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="#" class="btn btn-primary tb-detail-primary">Primary Action</a>
                        <a href="#" class="btn btn-outline-primary tb-detail-secondary">Secondary Action</a>
                        <a href="#" class="btn btn-outline-secondary tb-detail-tertiary">Tertiary Action</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
