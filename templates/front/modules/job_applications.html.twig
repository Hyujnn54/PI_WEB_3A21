{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Job Applications{% endblock %}

{% block body %}
{% set role = authUser.role|default('candidate') %}
{% set filters = applicationFilters|default({'search': '', 'status': 'all', 'sort': 'date_desc'}) %}
<style>
    .tb-create-locked,
    .tb-create-locked:hover,
    .tb-create-locked:focus,
    .tb-create-locked:active {
        pointer-events: none !important;
        cursor: not-allowed !important;
        transform: none !important;
        box-shadow: none !important;
        filter: none !important;
        opacity: 1 !important;
        background: #8e9aac !important;
        border-color: #8e9aac !important;
        color: #ffffff !important;
    }

</style>
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2 tb-front-page-head">
            <div>
                <h2 class="page-title"><i class="ti ti-file-check me-1"></i>Job Applications</h2>
                <p class="text-secondary mb-0">
                    {{ role == 'recruiter'
                        ? 'Evaluate applicant profiles and move them through your pipeline.'
                        : (role == 'admin'
                            ? 'Read-only overview of all applications with full inspection access.'
                            : 'Track each application and monitor your progress.') }}
                </p>
            </div>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl tb-interviews-page">
            <div class="row g-3 tb-interviews-layout">
                <div class="col-12 col-xl-8">
            <div class="card tb-admin-card mb-3 tb-filter-bar">
                <div class="card-body py-2">
                    {% if role == 'recruiter' %}
                        <form method="get" action="{{ path('front_job_applications') }}" class="d-flex flex-wrap align-items-center gap-2">
                            <input type="hidden" name="role" value="recruiter">
                            <input type="hidden" name="ai_rank" value="{{ filters.ai_rank|default(false) ? '1' : '0' }}">
                            <input type="hidden" name="page" value="1">
                            <div class="input-icon">
                                <span class="input-icon-addon"><i class="ti ti-search"></i></span>
                                <input type="text" name="search" class="form-control" value="{{ filters.search|default('') }}" placeholder="Search by offer, candidate, phone, status...">
                            </div>
                            <select name="status" class="form-select" style="max-width: 220px;">
                                <option value="all" {{ (filters.status|default('all')) == 'all' ? 'selected' : '' }}>All Statuses</option>
                                <option value="submitted" {{ (filters.status|default('all')) == 'submitted' ? 'selected' : '' }}>Submitted</option>
                                <option value="in_review" {{ (filters.status|default('all')) == 'in_review' ? 'selected' : '' }}>In Review</option>
                                <option value="shortlisted" {{ (filters.status|default('all')) == 'shortlisted' ? 'selected' : '' }}>Shortlisted</option>
                                <option value="rejected" {{ (filters.status|default('all')) == 'rejected' ? 'selected' : '' }}>Rejected</option>
                                <option value="interview" {{ (filters.status|default('all')) == 'interview' ? 'selected' : '' }}>Interview</option>
                                <option value="hired" {{ (filters.status|default('all')) == 'hired' ? 'selected' : '' }}>Hired</option>
                            </select>
                            <select name="sort" class="form-select" style="max-width: 230px;">
                                <option value="date_desc" {{ (filters.sort|default('date_desc')) == 'date_desc' ? 'selected' : '' }}>Date Newest</option>
                                <option value="date_asc" {{ (filters.sort|default('date_desc')) == 'date_asc' ? 'selected' : '' }}>Date Oldest</option>
                                <option value="title_asc" {{ (filters.sort|default('date_desc')) == 'title_asc' ? 'selected' : '' }}>Title A-Z</option>
                                <option value="title_desc" {{ (filters.sort|default('date_desc')) == 'title_desc' ? 'selected' : '' }}>Title Z-A</option>
                                <option value="status_asc" {{ (filters.sort|default('date_desc')) == 'status_asc' ? 'selected' : '' }}>Status A-Z</option>
                                <option value="status_desc" {{ (filters.sort|default('date_desc')) == 'status_desc' ? 'selected' : '' }}>Status Z-A</option>
                            </select>
                            <button type="submit" class="btn btn-primary" onclick="this.form.querySelector('input[name=ai_rank]').value='{{ filters.ai_rank|default(false) ? '1' : '0' }}';"><i class="ti ti-filter me-1"></i>Apply</button>
                            <button type="submit" class="btn btn-outline-primary" onclick="this.form.querySelector('input[name=ai_rank]').value='1';"><i class="ti ti-robot me-1"></i>Ranking using AI</button>
                            <a href="{{ path('front_job_applications', {role: 'recruiter'}) }}" class="btn btn-outline-secondary"><i class="ti ti-rotate-clockwise-2 me-1"></i>Reset</a>
                            {% if filters.ai_rank|default(false) %}
                                <span class="badge bg-purple-lt text-purple">AI ranking enabled</span>
                            {% endif %}
                            <div class="small text-secondary ms-auto">{{ cards|length }} result(s)</div>
                        </form>
                        <form id="recruiterBulkStatusForm" method="post" action="{{ path('app_recruiter_application_bulk_update_status') }}" class="d-flex flex-wrap align-items-center gap-2 mt-2 pt-2 border-top">
                            <input type="hidden" name="search" value="{{ filters.search|default('') }}">
                            <input type="hidden" name="status_filter" value="{{ filters.status|default('all') }}">
                            <input type="hidden" name="sort" value="{{ filters.sort|default('date_desc') }}">
                            <div class="form-check m-0">
                                <input class="form-check-input" type="checkbox" id="recruiterBulkSelectAll">
                                <label class="form-check-label small" for="recruiterBulkSelectAll">Select all</label>
                            </div>
                            <select id="recruiterBulkStatusSelect" name="status" class="form-select" style="max-width: 220px;" required>
                                <option value="">Bulk status...</option>
                                <option value="SUBMITTED">Submitted</option>
                                <option value="IN_REVIEW">In Review</option>
                                <option value="SHORTLISTED">Shortlisted</option>
                                <option value="REJECTED">Rejected</option>
                                <option value="INTERVIEW">Interview</option>
                                <option value="HIRED">Hired</option>
                            </select>
                            <input type="text" name="note" class="form-control" style="max-width: 340px;" placeholder="Optional note for all selected applications">
                            <button id="recruiterBulkSubmitBtn" type="submit" class="btn btn-primary" disabled>
                                <i class="ti ti-checks me-1"></i>Apply to selected
                            </button>
                            <span class="small text-secondary" id="recruiterBulkCount">0 selected</span>
                        </form>
                    {% else %}
                        <div class="tb-filter-form d-flex flex-wrap align-items-center gap-2" data-target="#applicationCardsGrid">
                            <div class="input-icon">
                                <span class="input-icon-addon"><i class="ti ti-search"></i></span>
                                <input type="text" class="form-control" placeholder="Search applications by id, offer, status..." data-filter-search>
                            </div>
                            <select class="form-select" style="max-width: 220px;" data-filter-criteria>
                                <option value="all">Search In: All</option>
                                <option value="title">Title</option>
                                <option value="meta">Meta</option>
                                <option value="description">Description</option>
                            </select>
                            <select class="form-select" style="max-width: 230px;" data-filter-sort>
                                <option value="default">Default Order</option>
                                <option value="title_asc">Title A-Z</option>
                                <option value="title_desc">Title Z-A</option>
                                <option value="meta_asc">Meta A-Z</option>
                                <option value="meta_desc">Meta Z-A</option>
                            </select>
                            <div class="small text-secondary ms-auto" data-filter-results></div>
                        </div>
                    {% endif %}
                </div>
            </div>

            <div id="applicationCardsGrid" class="row row-cards">
                {% for card in cards %}
                    {% set canCreateInterview = card.can_create_interview|default(true) %}
                    {% set detailExtra = card.detail_extra|default([]) %}
                    {% if detailExtra is empty %}
                        {% set detailExtra = ['Status: ' ~ card.meta, card.title] %}
                    {% endif %}
                    {% if role == 'admin' %}
                        {% set detailExtra = detailExtra|merge(['Inspect URL: ' ~ card.details_url|default('#')]) %}
                    {% endif %}
                    {% if role == 'recruiter' and not canCreateInterview %}
                        {% set detailExtra = detailExtra|merge(['Reason: ' ~ card.interview_block_reason|default('Interview already created for this application.')]) %}
                    {% endif %}
                    <div class="col-md-6 col-xl-4 tb-filter-item" data-filter-text="{{ (card.meta ~ ' ' ~ card.title ~ ' ' ~ card.text)|lower }}" data-filter-title="{{ card.title|lower }}" data-filter-meta="{{ card.meta|lower }}" data-filter-description="{{ card.text|lower }}" data-sort-title="{{ card.title|lower }}" data-sort-meta="{{ card.meta|lower }}">
                        <div class="tb-module-card h-100" 
                            data-application-id="{{ card.id|default(0) }}" 
                            data-detail-target="#applicationDetailPanel" 
                            data-detail-meta="{{ card.meta }}" 
                            data-detail-title="{{ card.title }}" 
                            data-detail-text="{{ card.text }}"
                            {# Recruiter data attributes #}
                            {% if role == 'recruiter' %}
                                data-accept-url="{{ card.accept_url|default('#') }}" 
                                data-decline-url="{{ card.decline_url|default('#') }}" 
                                data-create-url="{{ card.create_interview_url|default('#') }}" 
                                data-create-check-url="{{ card.create_interview_check_url|default('') }}"
                                data-create-disabled="{{ canCreateInterview ? '0' : '1' }}" 
                                data-create-reason="{{ card.interview_block_reason|default('Interview already created for this application.')|e('html_attr') }}"
                                data-details-url="{{ card.details_url|default('#') }}"
                            {% endif %}
                            {# Candidate data attributes #}
                            {% if role == 'candidate' %}
                                data-details-url="{{ card.details_url|default('#') }}"
                                data-can-edit="{{ card.can_edit|default(false) ? '1' : '0' }}"
                                data-edit-url="{{ card.edit_url|default('#') }}"
                                data-can-withdraw="{{ card.can_withdraw|default(false) ? '1' : '0' }}"
                                data-withdraw-url="{{ card.withdraw_url|default('#') }}"
                            {% endif %}
                            {% if role == 'admin' %}
                                data-details-url="{{ card.details_url|default('#') }}"
                            {% endif %}
                            data-detail-extra="{{ detailExtra|join('||')|e('html_attr') }}">
                            {% if role == 'recruiter' %}
                                <div class="form-check mb-2" onclick="event.stopPropagation();">
                                    <input
                                        class="form-check-input tb-bulk-app-checkbox"
                                        type="checkbox"
                                        name="application_ids[]"
                                        value="{{ card.id|default(0) }}"
                                        form="recruiterBulkStatusForm"
                                        id="bulkApplication{{ loop.index }}"
                                    >
                                    <label class="form-check-label small text-secondary" for="bulkApplication{{ loop.index }}">Select</label>
                                </div>
                            {% endif %}
                            <div class="tb-module-meta">{{ card.meta }}</div>
                            <h3>{{ card.title }}</h3>
                            <p>{{ card.text }}</p>
                            {% if role == 'recruiter' and card.ai_score is not null %}
                                <div class="mt-2">
                                    <span class="badge bg-purple text-white">AI {{ card.ai_score }}/100</span>
                                </div>
                            {% endif %}
                            {# Recruiter inline buttons for quick actions #}
                            {% if role == 'recruiter' %}
                                <div class="d-flex flex-wrap gap-2 mt-3">
                                    <a href="{{ card.details_url|default('#') }}" class="btn btn-sm btn-outline-primary"><i class="ti ti-eye me-1"></i>Review</a>
                                    <form method="post" action="{{ card.shortlist_url|default('#') }}" class="d-inline">
                                        <input type="hidden" name="status" value="SHORTLISTED">
                                        <input type="hidden" name="return_to" value="list">
                                        <button type="submit" class="btn btn-sm btn-outline-success">Shortlist</button>
                                    </form>
                                    <form method="post" action="{{ card.reject_url|default('#') }}" class="d-inline">
                                        <input type="hidden" name="status" value="REJECTED">
                                        <input type="hidden" name="return_to" value="list">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Reject</button>
                                    </form>
                                    {% if canCreateInterview %}
                                        <button type="button" class="btn btn-sm btn-primary tb-open-interview-modal" 
                                            data-application-id="{{ card.id|default(0) }}" 
                                            data-create-url="{{ card.create_interview_url|default('#') }}">
                                            <i class="ti ti-calendar-plus me-1"></i>Create Interview
                                        </button>
                                    {% else %}
                                        <span class="btn btn-sm btn-secondary disabled" title="{{ card.interview_block_reason|default('Interview already created') }}" aria-disabled="true">
                                            <i class="ti ti-check me-1"></i>Interview Already Created
                                        </span>
                                    {% endif %}
                                </div>
                            {% endif %}
                            {# Candidate inline buttons #}
                            {% if role == 'candidate' %}
                                <div class="d-flex flex-wrap gap-2 mt-3">
                                    <a href="{{ card.details_url|default('#') }}" class="btn btn-sm btn-outline-primary"><i class="ti ti-eye me-1"></i>View Details</a>
                                    {% if card.can_edit|default(false) %}
                                        <a href="{{ card.edit_url|default('#') }}" class="btn btn-sm btn-outline-secondary"><i class="ti ti-edit me-1"></i>Edit</a>
                                    {% endif %}
                                    {% if card.can_withdraw|default(false) %}
                                        <form method="post" action="{{ card.withdraw_url|default('#') }}" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to withdraw this application?');"><i class="ti ti-trash me-1"></i>Withdraw</button>
                                        </form>
                                    {% endif %}
                                </div>
                            {% endif %}
                            {% if role == 'admin' %}
                                <div class="d-flex flex-wrap gap-2 mt-3">
                                    <a href="{{ card.details_url|default('#') }}" class="btn btn-sm btn-outline-primary"><i class="ti ti-eye me-1"></i>Inspect Details</a>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% else %}
                    <div class="col-12">
                        <div class="card tb-admin-card">
                            <div class="card-body text-secondary">No job applications found in the database.</div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            {% set pager = pagination|default({}) %}
            {% if pager.enabled|default(false) %}
                {% set baseParams = pager.route_params_base|default({'role': role}) %}
                <div class="d-flex justify-content-center mt-3">
                    <nav aria-label="Applications pagination">
                        <ul class="pagination mb-0">
                            <li class="page-item {{ pager.has_previous|default(false) ? '' : 'disabled' }}">
                                <a class="page-link" href="{{ pager.has_previous|default(false) ? path('front_job_applications', baseParams|merge({'page': pager.previous_page|default(1)})) : '#' }}" aria-label="Previous">
                                    <span aria-hidden="true">&laquo;</span>
                                </a>
                            </li>

                            {% for p in pager.pages|default([1]) %}
                                <li class="page-item {{ p == (pager.current_page|default(1)) ? 'active' : '' }}">
                                    <a class="page-link" href="{{ path('front_job_applications', baseParams|merge({'page': p})) }}">{{ p }}</a>
                                </li>
                            {% endfor %}

                            <li class="page-item {{ pager.has_next|default(false) ? '' : 'disabled' }}">
                                <a class="page-link" href="{{ pager.has_next|default(false) ? path('front_job_applications', baseParams|merge({'page': pager.next_page|default(1)})) : '#' }}" aria-label="Next">
                                    <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            {% endif %}

                </div>
                <div class="col-12 col-xl-4">
            <div id="applicationDetailPanel" class="card tb-detail-panel tb-detail-panel-side">
                <div class="card-header">
                    <div>
                        <div class="small text-secondary tb-detail-meta"></div>
                        <h3 class="card-title mb-0 tb-detail-title">Application Details</h3>
                    </div>
                </div>
                <div class="card-body">
                    <p class="mb-3 tb-detail-text">Select an application card to display details here.</p>
                    <div class="tb-detail-extra small text-secondary mb-0"></div>
                </div>
            </div>
                </div>
            </div>

            <div class="modal fade" id="createInterviewModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-lg modal-dialog-centered">
                    <div class="modal-content tb-admin-card tb-modal-shell">
                        <div class="modal-header tb-modal-header">
                            <h5 class="modal-title"><i class="ti ti-calendar-plus me-1"></i>Create Interview</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <form id="createInterviewForm" method="post" data-generate-link-url="{{ path('front_interview_generate_meeting_link', app.request.query.all|merge({role: role})) }}">
                            <div class="modal-body row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Scheduled At</label>
                                    <input type="datetime-local" name="scheduled_at" class="form-control" required>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Duration</label>
                                    <input type="number" min="15" max="240" name="duration_minutes" class="form-control" value="60" required>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Mode</label>
                                    <select name="mode" class="form-select" required>
                                        <option value="online">Online</option>
                                        <option value="onsite">Onsite</option>
                                    </select>
                                </div>
                                <div class="col-md-6" data-online-field>
                                    <label class="form-label">Meeting Link (online)</label>
                                    <div class="input-group">
                                        <input type="url" name="meeting_link" class="form-control" placeholder="https://meet.example.com/room-123" maxlength="500">
                                        <button type="button" class="btn btn-outline-primary" data-create-generate-meeting-link>Generate Jitsi Link</button>
                                    </div>
                                    <div class="form-hint">Use a complete http(s) URL.</div>
                                    <div class="form-hint" data-create-meeting-link-feedback></div>
                                </div>
                                <div class="col-md-6" data-onsite-field>
                                    <label class="form-label">Location (onsite)</label>
                                    <div class="input-group">
                                        <input type="text" name="location" class="form-control" placeholder="Google HQ, Restaurant Bla Bla, 1600 Amphitheatre Pkwy..." minlength="3" maxlength="120">
                                        <button type="button" class="btn btn-outline-primary" data-create-map-picker-trigger>Select on Map</button>
                                    </div>
                                    <div class="form-hint">Click Select on Map, choose a place, and we will fill this field with a readable location name for the reminder QR code.</div>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Additional Notes</label>
                                    <textarea name="notes" rows="3" class="form-control" maxlength="1000"></textarea>
                                    <div class="form-hint"><span data-notes-count>0</span>/1000 characters</div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Confirm</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% include 'front/modules/_interview_map_picker.html.twig' %}
<script>
    const ensureMapPickerService = async function () {
        return window.tbInterviewMapPickerService || null;
    };

    const initJobApplicationsPage = async function () {
        const pageRoot = document.querySelector('.tb-interviews-page');
        if (!pageRoot) {
            return;
        }

        if (pageRoot.dataset.tbApplicationsInitialized === '1') {
            return;
        }
        pageRoot.dataset.tbApplicationsInitialized = '1';

        const modalEl = document.getElementById('createInterviewModal');
        const formEl = document.getElementById('createInterviewForm');
        if (!formEl) {
            return;
        }

        const modal = (modalEl && typeof bootstrap !== 'undefined') ? new bootstrap.Modal(modalEl) : null;
        const mapPickerService = await ensureMapPickerService();
        const modeSelect = formEl.querySelector('select[name="mode"]');
        const scheduleInput = formEl.querySelector('input[name="scheduled_at"]');
        const meetingInput = formEl.querySelector('input[name="meeting_link"]');
        const generateMeetingButton = formEl.querySelector('[data-create-generate-meeting-link]');
        const generateMeetingFeedback = formEl.querySelector('[data-create-meeting-link-feedback]');
        const locationInput = formEl.querySelector('input[name="location"]');
        const mapPickerTrigger = formEl.querySelector('[data-create-map-picker-trigger]');
        const onlineField = formEl.querySelector('[data-online-field]');
        const onsiteField = formEl.querySelector('[data-onsite-field]');
        const notesInput = formEl.querySelector('textarea[name="notes"]');
        const notesCount = formEl.querySelector('[data-notes-count]');
        const bulkForm = document.getElementById('recruiterBulkStatusForm');
        const bulkSelectAll = document.getElementById('recruiterBulkSelectAll');
        const bulkStatusSelect = document.getElementById('recruiterBulkStatusSelect');
        const bulkSubmitBtn = document.getElementById('recruiterBulkSubmitBtn');
        const bulkCount = document.getElementById('recruiterBulkCount');
        const bulkCheckboxes = Array.from(document.querySelectorAll('.tb-bulk-app-checkbox'));
        let selectedCard = null;

        if (mapPickerService && locationInput && mapPickerTrigger) {
            mapPickerService.attach(locationInput, mapPickerTrigger);
        }

        const syncBulkSelection = function () {
            if (!bulkCheckboxes.length) {
                return;
            }

            const selectedCount = bulkCheckboxes.filter(function (checkbox) {
                return checkbox.checked;
            }).length;

            if (bulkCount) {
                bulkCount.textContent = selectedCount + ' selected';
            }

            if (bulkSelectAll) {
                bulkSelectAll.checked = selectedCount > 0 && selectedCount === bulkCheckboxes.length;
                bulkSelectAll.indeterminate = selectedCount > 0 && selectedCount < bulkCheckboxes.length;
            }

            if (bulkSubmitBtn) {
                const hasStatus = bulkStatusSelect && bulkStatusSelect.value !== '';
                bulkSubmitBtn.disabled = !(selectedCount > 0 && hasStatus);
            }
        };

        if (bulkCheckboxes.length) {
            bulkCheckboxes.forEach(function (checkbox) {
                checkbox.addEventListener('click', function (event) {
                    event.stopPropagation();
                });

                checkbox.addEventListener('change', function () {
                    syncBulkSelection();
                });
            });
        }

        if (bulkSelectAll && bulkCheckboxes.length) {
            bulkSelectAll.addEventListener('change', function () {
                bulkCheckboxes.forEach(function (checkbox) {
                    checkbox.checked = bulkSelectAll.checked;
                });
                syncBulkSelection();
            });
        }

        if (bulkStatusSelect) {
            bulkStatusSelect.addEventListener('change', function () {
                syncBulkSelection();
            });
        }

        if (bulkForm) {
            bulkForm.addEventListener('submit', function (event) {
                const selectedCount = bulkCheckboxes.filter(function (checkbox) {
                    return checkbox.checked;
                }).length;

                if (selectedCount === 0) {
                    event.preventDefault();
                    alert('Please select at least one application.');
                    return;
                }

                if (!bulkStatusSelect || bulkStatusSelect.value === '') {
                    event.preventDefault();
                    alert('Please select a status for bulk update.');
                    return;
                }

                if (!confirm('Apply this status to ' + selectedCount + ' selected application(s)?')) {
                    event.preventDefault();
                }
            });

            syncBulkSelection();
        }

        const now = new Date();
        const minValue = new Date(now.getTime() - now.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
        if (scheduleInput) {
            scheduleInput.min = minValue;
        }

        const setGenerateFeedback = function (message, type) {
            if (!generateMeetingFeedback) return;
            generateMeetingFeedback.textContent = message || '';
            generateMeetingFeedback.classList.remove('text-success', 'text-danger', 'text-secondary');
            if (type === 'success') {
                generateMeetingFeedback.classList.add('text-success');
            } else if (type === 'error') {
                generateMeetingFeedback.classList.add('text-danger');
            } else {
                generateMeetingFeedback.classList.add('text-secondary');
            }
        };

        const applyModeFields = function () {
            const mode = modeSelect ? modeSelect.value : 'online';
            if (mode === 'onsite') {
                if (onlineField) onlineField.classList.add('d-none');
                if (onsiteField) onsiteField.classList.remove('d-none');
                if (meetingInput) {
                    meetingInput.value = '';
                    meetingInput.required = false;
                    meetingInput.setCustomValidity('');
                }
                setGenerateFeedback('', 'info');
                if (locationInput) locationInput.required = true;
            } else {
                if (onsiteField) onsiteField.classList.add('d-none');
                if (onlineField) onlineField.classList.remove('d-none');
                if (locationInput) {
                    locationInput.value = '';
                    locationInput.required = false;
                    locationInput.setCustomValidity('');
                }
                if (meetingInput) meetingInput.required = true;
            }
        };

        if (modeSelect) {
            modeSelect.addEventListener('change', applyModeFields);
        }

        if (locationInput) {
            locationInput.addEventListener('input', function () {
                const value = locationInput.value.trim();
                if (value === '' || (value.length >= 3 && value.length <= 120 && !/[<>]/.test(value))) {
                    locationInput.setCustomValidity('');
                } else {
                    locationInput.setCustomValidity('Use 3-120 visible characters and avoid angle brackets.');
                }
            });
        }

        if (notesInput && notesCount) {
            const syncNotesCount = function () {
                notesCount.textContent = String(notesInput.value.length);
            };
            notesInput.addEventListener('input', syncNotesCount);
            syncNotesCount();
        }

        const openCreateModal = function (createUrl, card) {
            if (!createUrl || createUrl === '#' || !modal) return;
            formEl.setAttribute('action', createUrl);
            formEl.setAttribute('data-application-id', card ? (card.getAttribute('data-application-id') || '') : '');
            formEl.setAttribute('data-interview-id', '');
            if (modeSelect) modeSelect.value = 'online';
            if (scheduleInput) scheduleInput.min = minValue;
            if (meetingInput) meetingInput.value = '';
            if (locationInput) locationInput.value = '';
            if (notesInput) notesInput.value = '';
            if (notesCount && notesInput) notesCount.textContent = String(notesInput.value.length);
            setGenerateFeedback('', 'info');
            applyModeFields();
            modal.show();
        };

        if (generateMeetingButton) {
            generateMeetingButton.addEventListener('click', async function () {
                if (!meetingInput) return;

                const mode = modeSelect ? modeSelect.value : 'online';
                if (mode !== 'online') {
                    setGenerateFeedback('Switch mode to Online to generate a meeting link.', 'error');
                    return;
                }

                const endpoint = formEl.getAttribute('data-generate-link-url') || '';
                if (endpoint === '') {
                    setGenerateFeedback('Meeting link endpoint is missing.', 'error');
                    return;
                }

                generateMeetingButton.disabled = true;
                setGenerateFeedback('Generating Jitsi link...', 'info');

                const payload = new URLSearchParams();
                payload.set('mode', mode);
                payload.set('application_id', formEl.getAttribute('data-application-id') || '');
                payload.set('interview_id', formEl.getAttribute('data-interview-id') || '');

                try {
                    const response = await fetch(endpoint, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: payload.toString(),
                    });

                    const data = await response.json();
                    if (!response.ok || !data.ok || !data.meetingLink) {
                        setGenerateFeedback(data.error || 'Unable to generate a meeting link.', 'error');
                        return;
                    }

                    meetingInput.value = data.meetingLink;
                    setGenerateFeedback('Jitsi meeting link generated.', 'success');
                } catch (error) {
                    setGenerateFeedback('Unable to generate a meeting link right now.', 'error');
                } finally {
                    generateMeetingButton.disabled = false;
                }
            });
        }

        const syncInlineCreateButton = function (card) {
            if (!card) return;
            const inlineBtn = card.querySelector('.tb-open-interview-modal');
            if (!inlineBtn) return;

            const createDisabled = card.getAttribute('data-create-disabled') === '1';
            const createReason = card.getAttribute('data-create-reason') || 'Interview already created for this application.';

            inlineBtn.classList.toggle('tb-create-locked', createDisabled);
            inlineBtn.toggleAttribute('disabled', createDisabled);
            inlineBtn.setAttribute('aria-disabled', createDisabled ? 'true' : 'false');
            inlineBtn.setAttribute('title', createDisabled ? createReason : '');
            inlineBtn.innerHTML = createDisabled
                ? '<i class="ti ti-lock me-1"></i>Interview Exists'
                : '<i class="ti ti-calendar-plus me-1"></i>Create Interview';
        };

        const refreshCreateAvailability = async function (card) {
            if (!card) return false;
            const checkUrl = card.getAttribute('data-create-check-url') || '';
            if (!checkUrl) {
                syncInlineCreateButton(card);
                return card.getAttribute('data-create-disabled') !== '1';
            }

            try {
                const response = await fetch(checkUrl, {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                if (!response.ok) {
                    syncInlineCreateButton(card);
                    return card.getAttribute('data-create-disabled') !== '1';
                }

                const payload = await response.json();
                if (!payload || payload.ok !== true) {
                    syncInlineCreateButton(card);
                    return card.getAttribute('data-create-disabled') !== '1';
                }

                card.setAttribute('data-create-disabled', payload.canCreateInterview ? '0' : '1');
                card.setAttribute('data-create-url', payload.createUrl || '#');
                card.setAttribute('data-create-reason', payload.reason || 'Interview already created for this application.');
            } catch (e) {
                // Keep existing card state when live check fails.
            }

            syncInlineCreateButton(card);
            return card.getAttribute('data-create-disabled') !== '1';
        };

        const refreshAllCreateAvailability = function () {
            document.querySelectorAll('#applicationCardsGrid .tb-module-card[data-create-check-url]').forEach(function (card) {
                refreshCreateAvailability(card);
            });
        };

        document.querySelectorAll('#applicationCardsGrid .tb-module-card').forEach(function (card) {
            syncInlineCreateButton(card);
            card.addEventListener('click', function () {
                selectedCard = card;
            });
        });

        document.querySelectorAll('.tb-open-interview-modal').forEach(function (btn) {
            btn.addEventListener('click', function (event) {
                event.preventDefault();
                event.stopPropagation();

                const card = btn.closest('.tb-module-card');
                if (!card) return;

                const createDisabled = card.getAttribute('data-create-disabled') === '1';
                if (createDisabled) {
                    syncInlineCreateButton(card);
                    return;
                }

                const initialUrl = card.getAttribute('data-create-url') || '#';
                openCreateModal(initialUrl, card);

                refreshCreateAvailability(card).then(function (canCreate) {
                    if (!canCreate) {
                        if (modal) {
                            modal.hide();
                        }
                        return;
                    }

                    const freshUrl = card.getAttribute('data-create-url') || initialUrl;
                    formEl.setAttribute('action', freshUrl);
                });
            });
        });

        const params = new URLSearchParams(window.location.search);
        const openCreateFor = params.get('openCreateFor');
        if (openCreateFor) {
            const card = document.querySelector('#applicationCardsGrid .tb-module-card[data-application-id="' + openCreateFor + '"]');
            if (card) {
                selectedCard = card;
                refreshCreateAvailability(card).then(function () {
                    if (card.getAttribute('data-create-disabled') !== '1') {
                        openCreateModal(card.getAttribute('data-create-url') || '#', card);
                    }
                });
            }
        }

        const initiallySelected = document.querySelector('#applicationCardsGrid .tb-module-card.is-selected');
        if (initiallySelected) {
            selectedCard = initiallySelected;
            refreshCreateAvailability(initiallySelected);
        }

        refreshAllCreateAvailability();

        window.addEventListener('pageshow', function () {
            refreshAllCreateAvailability();
        });

        applyModeFields();
    };

    document.addEventListener('DOMContentLoaded', function () { void initJobApplicationsPage(); });
    document.addEventListener('turbo:load', initJobApplicationsPage);
</script>
{% endblock %}
