{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Job Applications{% endblock %}

{% block body %}
{% set role = authUser.role|default('candidate') %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h2 class="page-title"><i class="ti ti-file-check me-1"></i>Job Applications</h2>
                <p class="text-secondary mb-0">{{ role == 'recruiter' ? 'Evaluate applicant profiles and move them through your pipeline.' : 'Track each application and monitor your progress.' }}</p>
            </div>
            <div class="d-flex gap-2">
                <a href="#" class="btn btn-primary">{{ role == 'recruiter' ? 'Review Queue' : 'My Pipeline' }}</a>
                <a href="#" class="btn btn-outline-primary">Status Timeline</a>
            </div>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl">
            <div class="row row-cards">
                <div class="col-md-6 col-xl-4">
                    <div class="tb-module-card h-100" data-detail-target="#applicationDetailPanel" data-detail-meta="Application #A-101" data-detail-title="{{ role == 'recruiter' ? 'Candidate: Aya Trabelsi' : 'Backend Engineer Application' }}" data-detail-text="Detailed stage history, scoring notes, and next pipeline actions will appear here." data-action-primary="{{ role == 'recruiter' ? 'Advance Stage' : 'Track Status' }}" data-action-secondary="{{ role == 'recruiter' ? 'Add Interview' : 'Update Profile' }}" data-action-tertiary="{{ role == 'recruiter' ? 'Add Feedback' : 'Withdraw Application' }}">
                        <div class="tb-module-meta">Application #A-101</div>
                        <h3>{{ role == 'recruiter' ? 'Candidate: Aya Trabelsi' : 'Position: Backend Engineer' }}</h3>
                        <p>{{ role == 'recruiter' ? 'Strong API and SQL experience, currently at interview stage.' : 'Your application is currently under technical review.' }}</p>
                        <div class="tb-module-actions">
                            <a href="#" class="btn btn-sm btn-outline-primary">Open Details</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-4">
                    <div class="tb-module-card h-100" data-detail-target="#applicationDetailPanel" data-detail-meta="Application #A-102" data-detail-title="{{ role == 'recruiter' ? 'Candidate: Mehdi Gharbi' : 'HR Data Analyst Application' }}" data-detail-text="Candidate strengths, matching score, and timeline actions can be handled from this section." data-action-primary="{{ role == 'recruiter' ? 'Advance Stage' : 'Track Status' }}" data-action-secondary="{{ role == 'recruiter' ? 'Add Interview' : 'Update Profile' }}" data-action-tertiary="{{ role == 'recruiter' ? 'Add Feedback' : 'Withdraw Application' }}">
                        <div class="tb-module-meta">Application #A-102</div>
                        <h3>{{ role == 'recruiter' ? 'Candidate: Mehdi Gharbi' : 'Position: HR Data Analyst' }}</h3>
                        <p>{{ role == 'recruiter' ? 'Needs follow-up on interview scheduling and profile completion.' : 'Recruiter requested an additional profile update.' }}</p>
                        <div class="tb-module-actions">
                            <a href="#" class="btn btn-sm btn-outline-primary">Open Details</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-xl-4">
                    <div class="tb-module-card h-100" data-detail-target="#applicationDetailPanel" data-detail-meta="Application #A-103" data-detail-title="{{ role == 'recruiter' ? 'Candidate: Sara Ben Amor' : 'Interview Coordinator Application' }}" data-detail-text="Use the action area for shortlisting decisions, interview scheduling, and post-evaluation updates." data-action-primary="{{ role == 'recruiter' ? 'Advance Stage' : 'Track Status' }}" data-action-secondary="{{ role == 'recruiter' ? 'Add Interview' : 'Update Profile' }}" data-action-tertiary="{{ role == 'recruiter' ? 'Add Feedback' : 'Withdraw Application' }}">
                        <div class="tb-module-meta">Application #A-103</div>
                        <h3>{{ role == 'recruiter' ? 'Candidate: Sara Ben Amor' : 'Position: Interview Coordinator' }}</h3>
                        <p>{{ role == 'recruiter' ? 'Interview feedback pending from panel member.' : 'Decision expected after final panel review.' }}</p>
                        <div class="tb-module-actions">
                            <a href="#" class="btn btn-sm btn-outline-primary">Open Details</a>
                        </div>
                    </div>
                </div>
            </div>

            <div id="applicationDetailPanel" class="card tb-detail-panel mt-4 d-none">
                <div class="card-header">
                    <div>
                        <div class="small text-secondary tb-detail-meta"></div>
                        <h3 class="card-title mb-0 tb-detail-title">Application Details</h3>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary tb-detail-close">Close</button>
                </div>
                <div class="card-body">
                    <p class="mb-3 tb-detail-text">Click an application card to reveal timeline and action placeholders.</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="#" class="btn btn-primary tb-detail-primary">Primary Action</a>
                        <a href="#" class="btn btn-outline-primary tb-detail-secondary">Secondary Action</a>
                        <a href="#" class="btn btn-outline-secondary tb-detail-tertiary">Tertiary Action</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
