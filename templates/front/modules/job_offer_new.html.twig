{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Create Job Offer{% endblock %}

{% block body %}
{% set role = authUser.role|default('candidate') %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h2 class="page-title"><i class="ti ti-briefcase-2 me-1"></i>Create Job Offer</h2>
                <p class="text-secondary mb-0">Recruiter ID is fixed in the backend for now.</p>
            </div>
            <a href="{{ path('front_job_offers', {role: role}) }}" class="btn btn-outline-primary">Back to Offers</a>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            <div class="card tb-admin-card">
                <div class="card-body">
                    <form method="post" class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Title</label>
                            <input type="text" name="title" class="form-control" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Contract Type</label>
                            <select name="contract_type" class="form-select" required>
                                <option value="">Choose contract type</option>
                                {% for contractType in contractTypes %}
                                    <option value="{{ contractType }}">{{ contractType }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea name="description" class="form-control" rows="4" required></textarea>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Location</label>
                            <input type="text" name="location" class="form-control" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Deadline</label>
                            <input type="datetime-local" name="deadline" class="form-control" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Latitude (optional)</label>
                            <input type="number" step="0.000001" name="latitude" class="form-control" value="0">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Longitude (optional)</label>
                            <input type="number" step="0.000001" name="longitude" class="form-control" value="0">
                        </div>

                        <div class="col-12 d-flex justify-content-end gap-2">
                            <a href="{{ path('front_job_offers', {role: role}) }}" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">Create Offer</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
