{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Create Job Offer{% endblock %}

{% block body %}
{% set role = authUser.role|default('candidate') %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h2 class="page-title"><i class="ti ti-briefcase-2 me-1"></i>Create Job Offer</h2>
                <p class="text-secondary mb-0">Recruiter ID is fixed in the backend for now.</p>
            </div>
            <a href="{{ path('front_job_offers', {role: role}) }}" class="btn btn-outline-primary">Back to Offers</a>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            <div class="card tb-admin-card">
                <div class="card-body">
                    <form method="post" class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Title</label>
                            <input type="text" name="title" class="form-control" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Contract Type</label>
                            <select name="contract_type" class="form-select" required>
                                <option value="">Choose contract type</option>
                                {% for contractType in contractTypes %}
                                    <option value="{{ contractType }}">{{ contractType }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Status</label>
                            <select name="status" class="form-select" required>
                                {% for status in jobStatuses %}
                                    <option value="{{ status }}" {{ status == 'open' ? 'selected' : '' }}>{{ status|capitalize }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="col-12">
                            <label class="form-label d-block">Required Skills</label>
                            <div id="skillsContainer" class="d-flex flex-column gap-2">
                                <div class="row g-2 skill-row">
                                    <div class="col-md-6">
                                        <input type="text" name="skills[0][name]" class="form-control" placeholder="e.g. Symfony" required>
                                    </div>
                                    <div class="col-md-4">
                                        <select name="skills[0][level]" class="form-select" required>
                                            <option value="">Choose skill level</option>
                                            {% for skillLevel in skillLevels %}
                                                <option value="{{ skillLevel }}">{{ skillLevel|capitalize }}</option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                    <div class="col-md-2">
                                        <button type="button" class="btn btn-outline-danger w-100 remove-skill-btn" disabled>Remove</button>
                                    </div>
                                </div>
                            </div>
                            <button type="button" id="addSkillBtn" class="btn btn-outline-primary btn-sm mt-2">Add Skill</button>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea name="description" class="form-control" rows="4" required></textarea>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Location</label>
                            <input type="text" name="location" class="form-control" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Deadline</label>
                            <input type="datetime-local" name="deadline" class="form-control" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Latitude (optional)</label>
                            <input type="number" step="0.000001" name="latitude" class="form-control" value="0">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Longitude (optional)</label>
                            <input type="number" step="0.000001" name="longitude" class="form-control" value="0">
                        </div>

                        <div class="col-12 d-flex justify-content-end gap-2">
                            <a href="{{ path('front_job_offers', {role: role}) }}" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">Create Offer</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const container = document.getElementById('skillsContainer');
        const addBtn = document.getElementById('addSkillBtn');
        if (!container || !addBtn) return;

        const levelOptionsHtml = `{% for skillLevel in skillLevels %}<option value="{{ skillLevel }}">{{ skillLevel|capitalize }}</option>{% endfor %}`;

        const refreshIndexes = function () {
            const rows = Array.from(container.querySelectorAll('.skill-row'));
            rows.forEach(function (row, index) {
                const nameInput = row.querySelector('input');
                const levelSelect = row.querySelector('select');
                const removeBtn = row.querySelector('.remove-skill-btn');
                if (nameInput) nameInput.name = 'skills[' + index + '][name]';
                if (levelSelect) levelSelect.name = 'skills[' + index + '][level]';
                if (removeBtn) removeBtn.disabled = rows.length === 1;
            });
        };

        addBtn.addEventListener('click', function () {
            const row = document.createElement('div');
            row.className = 'row g-2 skill-row';
            row.innerHTML =
                '<div class="col-md-6"><input type="text" class="form-control" placeholder="e.g. Symfony" required></div>' +
                '<div class="col-md-4"><select class="form-select" required><option value="">Choose skill level</option>' + levelOptionsHtml + '</select></div>' +
                '<div class="col-md-2"><button type="button" class="btn btn-outline-danger w-100 remove-skill-btn">Remove</button></div>';
            container.appendChild(row);
            refreshIndexes();
        });

        container.addEventListener('click', function (event) {
            const target = event.target;
            if (!(target instanceof HTMLElement) || !target.classList.contains('remove-skill-btn')) return;
            const row = target.closest('.skill-row');
            if (!row) return;
            row.remove();
            refreshIndexes();
        });

        refreshIndexes();
    })();
</script>
{% endblock %}
