{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Create Job Offer{% endblock %}

{% block body %}
{% set role = authUser.role|default('candidate') %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h2 class="page-title"><i class="ti ti-briefcase-2 me-1"></i>Create Job Offer</h2>
                <p class="text-secondary mb-0">Recruiter ID is fixed in the backend for now.</p>
            </div>
            <a href="{{ path('front_job_offers', {role: role}) }}" class="btn btn-outline-primary">Back to Offers</a>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            <div class="card tb-admin-card">
                <div class="card-body">
                    <form method="post" class="row g-3" novalidate id="jobOfferCreateForm">
                        <div class="col-md-6">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <label class="form-label mb-0">Title</label>
                                <button type="button" id="generateAiBtn" class="btn btn-outline-primary btn-sm">Generate with AI</button>
                            </div>
                            <input type="text" name="title" class="form-control {{ fieldErrors.title|default(null) ? 'is-invalid' : '' }}" value="{{ formData.title|default('') }}">
                            <small id="aiGenerateStatus" class="text-secondary d-block mt-1"></small>
                            <div class="invalid-feedback d-block" data-error-for="title"></div>
                            {% if fieldErrors.title|default(null) %}
                                <div class="invalid-feedback d-block fw-semibold">{{ fieldErrors.title }}</div>
                            {% endif %}
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Contract Type</label>
                            <select name="contract_type" class="form-select {{ fieldErrors.contract_type|default(null) ? 'is-invalid' : '' }}">
                                <option value="">Choose contract type</option>
                                {% for contractType in contractTypes %}
                                    <option value="{{ contractType }}" {{ formData.contract_type|default('') == contractType ? 'selected' : '' }}>{{ contractType }}</option>
                                {% endfor %}
                            </select>
                            <div class="invalid-feedback d-block" data-error-for="contract_type"></div>
                            {% if fieldErrors.contract_type|default(null) %}
                                <div class="invalid-feedback d-block">{{ fieldErrors.contract_type }}</div>
                            {% endif %}
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Status</label>
                            <select name="status" class="form-select {{ fieldErrors.status|default(null) ? 'is-invalid' : '' }}">
                                {% for status in jobStatuses %}
                                    <option value="{{ status }}" {{ formData.status|default('open') == status ? 'selected' : '' }}>{{ status|capitalize }}</option>
                                {% endfor %}
                            </select>
                            <div class="invalid-feedback d-block" data-error-for="status"></div>
                            {% if fieldErrors.status|default(null) %}
                                <div class="invalid-feedback d-block">{{ fieldErrors.status }}</div>
                            {% endif %}
                        </div>

                        <div class="col-12">
                            <label class="form-label d-block">Required Skills</label>
                            <div id="skillsContainer" class="d-flex flex-column gap-2">
                                {% for skill in formData.skills|default([{'name':'','level':''}]) %}
                                    {% set skillError = fieldErrors.skills[loop.index0]|default({}) %}
                                    <div class="row g-2 skill-row">
                                        <div class="col-md-6">
                                            <input type="text" name="skills[{{ loop.index0 }}][name]" class="form-control {{ skillError.name|default(null) ? 'is-invalid' : '' }}" placeholder="e.g. Symfony" value="{{ skill.name|default('') }}">
                                            <div class="invalid-feedback d-block" data-skill-error="name"></div>
                                            {% if skillError.name|default(null) %}
                                                <div class="invalid-feedback d-block">{{ skillError.name }}</div>
                                            {% endif %}
                                        </div>
                                        <div class="col-md-4">
                                            <select name="skills[{{ loop.index0 }}][level]" class="form-select {{ skillError.level|default(null) ? 'is-invalid' : '' }}">
                                                <option value="">Choose skill level</option>
                                                {% for skillLevel in skillLevels %}
                                                    <option value="{{ skillLevel }}" {{ skill.level|default('') == skillLevel ? 'selected' : '' }}>{{ skillLevel|capitalize }}</option>
                                                {% endfor %}
                                            </select>
                                            <div class="invalid-feedback d-block" data-skill-error="level"></div>
                                            {% if skillError.level|default(null) %}
                                                <div class="invalid-feedback d-block">{{ skillError.level }}</div>
                                            {% endif %}
                                        </div>
                                        <div class="col-md-2">
                                            <button type="button" class="btn btn-outline-danger w-100 remove-skill-btn" {{ loop.length == 1 ? 'disabled' : '' }}>Remove</button>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                            <button type="button" id="addSkillBtn" class="btn btn-outline-primary btn-sm mt-2">Add Skill</button>
                            <div class="invalid-feedback d-block fw-semibold" data-error-for="skills"></div>
                            {% if fieldErrors.skills|default(null) %}
                                <div class="invalid-feedback d-block fw-semibold">Please complete the required skills section.</div>
                            {% endif %}
                        </div>

                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea name="description" class="form-control {{ fieldErrors.description|default(null) ? 'is-invalid' : '' }}" rows="4">{{ formData.description|default('') }}</textarea>
                            <div class="invalid-feedback d-block" data-error-for="description"></div>
                            {% if fieldErrors.description|default(null) %}
                                <div class="invalid-feedback d-block">{{ fieldErrors.description }}</div>
                            {% endif %}
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Location</label>
                            <input type="text"
                                   id="locationInput"
                                   name="location"
                                   list="locationSuggestionList"
                                   autocomplete="off"
                                   class="form-control {{ fieldErrors.location|default(null) ? 'is-invalid' : '' }}"
                                   value="{{ formData.location|default('') }}"
                                   placeholder="Start typing a city or address...">
                            <datalist id="locationSuggestionList"></datalist>
                            <small id="locationSuggestionHint" class="text-secondary d-block mt-1">Type at least 2 characters to get location suggestions.</small>
                            <div class="invalid-feedback d-block" data-error-for="location"></div>
                            {% if fieldErrors.location|default(null) %}
                                <div class="invalid-feedback d-block">{{ fieldErrors.location }}</div>
                            {% endif %}
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Deadline</label>
                            <input type="datetime-local" name="deadline" class="form-control {{ fieldErrors.deadline|default(null) ? 'is-invalid' : '' }}" value="{{ formData.deadline|default('') }}" min="{{ 'now'|date('Y-m-d\\TH:i') }}">
                            <div class="invalid-feedback d-block" data-error-for="deadline"></div>
                            {% if fieldErrors.deadline|default(null) %}
                                <div class="invalid-feedback d-block">{{ fieldErrors.deadline }}</div>
                            {% endif %}
                        </div>

                        <div class="col-12 d-flex justify-content-end gap-2">
                            <a href="{{ path('front_job_offers', {role: role}) }}" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">Create Offer</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const container = document.getElementById('skillsContainer');
        const addBtn = document.getElementById('addSkillBtn');
        const form = document.getElementById('jobOfferCreateForm');
        const generateAiBtn = document.getElementById('generateAiBtn');
        const aiGenerateStatus = document.getElementById('aiGenerateStatus');
        const locationInput = document.getElementById('locationInput');
        const locationSuggestionList = document.getElementById('locationSuggestionList');
        const locationSuggestionHint = document.getElementById('locationSuggestionHint');
        const locationSuggestionUrl = '{{ path('front_job_offer_location_suggestions') }}';
        if (!container || !addBtn || !form) return;

        let locationDebounceTimer = null;
        let lastLocationQuery = '';

        const levelOptionsHtml = `{% for skillLevel in skillLevels %}<option value="{{ skillLevel }}">{{ skillLevel|capitalize }}</option>{% endfor %}`;

        const setError = function (fieldName, message) {
            const target = form.querySelector('[data-error-for="' + fieldName + '"]');
            if (!target) return;
            target.textContent = message || '';
        };

        const setInvalidState = function (field, isInvalid) {
            if (!field) return;
            field.classList.toggle('is-invalid', isInvalid);
        };

        const setAiStatus = function (message, isError) {
            if (!aiGenerateStatus) return;
            aiGenerateStatus.textContent = message || '';
            aiGenerateStatus.classList.toggle('text-danger', Boolean(isError));
            aiGenerateStatus.classList.toggle('text-secondary', !isError);
        };

        const setLocationHint = function (message, isError) {
            if (!locationSuggestionHint) return;
            locationSuggestionHint.textContent = message || '';
            locationSuggestionHint.classList.toggle('text-danger', Boolean(isError));
            locationSuggestionHint.classList.toggle('text-secondary', !isError);
        };

        const renderLocationSuggestions = function (suggestions) {
            if (!locationSuggestionList) return;
            locationSuggestionList.innerHTML = '';
            suggestions.forEach(function (entry) {
                const option = document.createElement('option');
                option.value = entry;
                locationSuggestionList.appendChild(option);
            });
        };

        const fetchLocationSuggestions = async function (rawQuery) {
            const query = rawQuery.trim();
            if (query.length < 2) {
                renderLocationSuggestions([]);
                setLocationHint('Type at least 2 characters to get location suggestions.', false);
                return;
            }

            lastLocationQuery = query;

            try {
                const response = await fetch(locationSuggestionUrl + '?q=' + encodeURIComponent(query), {
                    headers: {
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                const payload = await response.json();
                if (query !== lastLocationQuery) {
                    return;
                }

                if (!response.ok || !payload || payload.ok !== true) {
                    throw new Error((payload && payload.error) ? payload.error : 'Unable to fetch location suggestions.');
                }

                const suggestions = Array.isArray(payload.suggestions) ? payload.suggestions : [];
                const values = suggestions
                    .map(function (item) { return (item && typeof item.label === 'string') ? item.label : ''; })
                    .filter(function (value) { return value.trim() !== ''; });

                renderLocationSuggestions(values);

                if (values.length > 0) {
                    setLocationHint('Choose one of the suggested locations.', false);
                } else {
                    setLocationHint('No suggestion found. You can still type location manually.', false);
                }
            } catch (error) {
                renderLocationSuggestions([]);
                setLocationHint((error && error.message) ? error.message : 'Unable to fetch location suggestions.', true);
            }
        };

        const clearSkillRowErrors = function (row) {
            row.querySelectorAll('[data-skill-error]').forEach(function (node) {
                node.textContent = '';
            });
        };

        const validateSkillRow = function (row, index) {
            clearSkillRowErrors(row);

            const nameInput = row.querySelector('input');
            const levelSelect = row.querySelector('select');
            let valid = true;

            if (nameInput && nameInput.value.trim() === '') {
                const errorNode = row.querySelector('[data-skill-error="name"]');
                if (errorNode) errorNode.textContent = 'Skill name is required.';
                setInvalidState(nameInput, true);
                valid = false;
            } else {
                setInvalidState(nameInput, false);
            }

            if (levelSelect && levelSelect.value.trim() === '') {
                const errorNode = row.querySelector('[data-skill-error="level"]');
                if (errorNode) errorNode.textContent = 'Skill level is required.';
                setInvalidState(levelSelect, true);
                valid = false;
            } else {
                setInvalidState(levelSelect, false);
            }

            return valid;
        };

        const validateForm = function () {
            let valid = true;
            const title = form.querySelector('[name="title"]');
            const contractType = form.querySelector('[name="contract_type"]');
            const status = form.querySelector('[name="status"]');
            const description = form.querySelector('[name="description"]');
            const location = form.querySelector('[name="location"]');
            const deadline = form.querySelector('[name="deadline"]');
            ['title', 'contract_type', 'status', 'description', 'location', 'deadline', 'skills'].forEach(function (fieldName) {
                setError(fieldName, '');
            });

            if (!title || title.value.trim() === '') {
                setError('title', 'You need to fill in the title.');
                setInvalidState(title, true);
                valid = false;
            } else {
                setInvalidState(title, false);
            }

            if (!contractType || contractType.value.trim() === '') {
                setError('contract_type', 'You need to choose a contract type.');
                setInvalidState(contractType, true);
                valid = false;
            } else {
                setInvalidState(contractType, false);
            }

            if (!status || status.value.trim() === '') {
                setError('status', 'You need to choose a status.');
                setInvalidState(status, true);
                valid = false;
            } else {
                setInvalidState(status, false);
            }

            if (!description || description.value.trim() === '') {
                setError('description', 'You need to fill in the description.');
                setInvalidState(description, true);
                valid = false;
            } else {
                setInvalidState(description, false);
            }

            if (!location || location.value.trim() === '') {
                setError('location', 'You need to fill in the location.');
                setInvalidState(location, true);
                valid = false;
            } else {
                setInvalidState(location, false);
            }

            if (!deadline || deadline.value.trim() === '') {
                setError('deadline', 'You need to choose a deadline.');
                setInvalidState(deadline, true);
                valid = false;
            } else {
                const deadlineDate = new Date(deadline.value);
                const now = new Date();
                if (isNaN(deadlineDate.getTime()) || deadlineDate <= now) {
                    setError('deadline', 'Deadline must be greater than today.');
                    setInvalidState(deadline, true);
                    valid = false;
                } else {
                    setInvalidState(deadline, false);
                }
            }

            const rows = Array.from(container.querySelectorAll('.skill-row'));
            let atLeastOneSkillFilled = false;
            rows.forEach(function (row, index) {
                const rowValid = validateSkillRow(row, index);
                const nameInput = row.querySelector('input');
                const levelSelect = row.querySelector('select');
                if (nameInput && nameInput.value.trim() !== '') atLeastOneSkillFilled = true;
                if (levelSelect && levelSelect.value.trim() !== '') atLeastOneSkillFilled = true;
                if (!rowValid) valid = false;
            });

            if (!atLeastOneSkillFilled) {
                setError('skills', 'You need to fill in at least one skill.');
                valid = false;
            }

            return valid;
        };

        const refreshIndexes = function () {
            const rows = Array.from(container.querySelectorAll('.skill-row'));
            rows.forEach(function (row, index) {
                const nameInput = row.querySelector('input');
                const levelSelect = row.querySelector('select');
                const removeBtn = row.querySelector('.remove-skill-btn');
                if (nameInput) nameInput.name = 'skills[' + index + '][name]';
                if (levelSelect) levelSelect.name = 'skills[' + index + '][level]';
                if (removeBtn) removeBtn.disabled = rows.length === 1;
            });
        };

        const createSkillRow = function (skill) {
            const row = document.createElement('div');
            row.className = 'row g-2 skill-row';
            const safeName = typeof skill.name === 'string' ? skill.name.replace(/"/g, '&quot;') : '';
            const safeLevel = typeof skill.level === 'string' ? skill.level : '';

            row.innerHTML =
                '<div class="col-md-6"><input type="text" class="form-control" placeholder="e.g. Symfony" value="' + safeName + '"><div class="invalid-feedback d-block" data-skill-error="name"></div></div>' +
                '<div class="col-md-4"><select class="form-select"><option value="">Choose skill level</option>' + levelOptionsHtml + '</select><div class="invalid-feedback d-block" data-skill-error="level"></div></div>' +
                '<div class="col-md-2"><button type="button" class="btn btn-outline-danger w-100 remove-skill-btn">Remove</button></div>';

            const levelSelect = row.querySelector('select');
            if (levelSelect && safeLevel !== '') {
                levelSelect.value = safeLevel;
            }

            return row;
        };

        const populateSkills = function (skills) {
            if (!Array.isArray(skills) || skills.length === 0) {
                return;
            }

            container.innerHTML = '';
            skills.forEach(function (skill) {
                container.appendChild(createSkillRow(skill || {}));
            });
            refreshIndexes();
            setError('skills', '');
        };

        const generateWithAi = async function () {
            const titleInput = form.querySelector('[name="title"]');
            const descriptionInput = form.querySelector('[name="description"]');
            if (!titleInput) return;

            const title = titleInput.value.trim();
            if (title === '') {
                setAiStatus('Please enter a job title first.', true);
                setInvalidState(titleInput, true);
                return;
            }

            setAiStatus('Generating suggestion...');
            if (generateAiBtn) {
                generateAiBtn.disabled = true;
            }

            try {
                const response = await fetch('{{ path('front_job_offer_ai_generate') }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ title: title })
                });

                const result = await response.json();
                if (!response.ok || !result || result.ok !== true) {
                    setAiStatus((result && result.error) ? result.error : 'Unable to generate suggestion.', true);
                    return;
                }

                const data = result.data || {};
                if (typeof data.description === 'string' && descriptionInput) {
                    descriptionInput.value = data.description;
                    setInvalidState(descriptionInput, false);
                    setError('description', '');
                }

                if (Array.isArray(data.skills)) {
                    populateSkills(data.skills);
                }

                setAiStatus('Description and skills generated. Please fill location and contract type manually.');
            } catch (error) {
                setAiStatus('Network error while generating suggestion.', true);
            } finally {
                if (generateAiBtn) {
                    generateAiBtn.disabled = false;
                }
            }
        };

        form.addEventListener('submit', function (event) {
            if (!validateForm()) {
                event.preventDefault();
            }
        });

        form.addEventListener('input', function (event) {
            const field = event.target;
            if (!(field instanceof HTMLElement)) return;

            const name = field.getAttribute('name');
            if (name === 'title') {
                setError('title', '');
                setInvalidState(field, field.value.trim() === '');
            }
            if (name === 'contract_type') {
                setError('contract_type', '');
                setInvalidState(field, field.value.trim() === '');
            }
            if (name === 'status') {
                setError('status', '');
                setInvalidState(field, field.value.trim() === '');
            }
            if (name === 'description') {
                setError('description', '');
                setInvalidState(field, field.value.trim() === '');
            }
            if (name === 'location') {
                setError('location', '');
                setInvalidState(field, field.value.trim() === '');
            }
            if (name === 'deadline') {
                const deadlineValue = field.value.trim();
                if (deadlineValue === '') {
                    setError('deadline', '');
                    setInvalidState(field, true);
                } else {
                    const typedDeadline = new Date(deadlineValue);
                    const now = new Date();
                    if (isNaN(typedDeadline.getTime()) || typedDeadline <= now) {
                        setError('deadline', 'Deadline must be greater than today.');
                        setInvalidState(field, true);
                    } else {
                        setError('deadline', '');
                        setInvalidState(field, false);
                    }
                }
            }

            const row = field.closest('.skill-row');
            if (row) {
                const rowNameInput = row.querySelector('input');
                const rowLevelSelect = row.querySelector('select');
                setError('skills', '');
                if (rowNameInput) setInvalidState(rowNameInput, rowNameInput.value.trim() === '');
                if (rowLevelSelect) setInvalidState(rowLevelSelect, rowLevelSelect.value.trim() === '');

                const rowErrorName = row.querySelector('[data-skill-error="name"]');
                const rowErrorLevel = row.querySelector('[data-skill-error="level"]');
                if (rowNameInput && rowNameInput.value.trim() !== '' && rowErrorName) rowErrorName.textContent = '';
                if (rowLevelSelect && rowLevelSelect.value.trim() !== '' && rowErrorLevel) rowErrorLevel.textContent = '';
            }
        });

        addBtn.addEventListener('click', function () {
            const row = createSkillRow({ name: '', level: '' });
            container.appendChild(row);
            refreshIndexes();
        });

        if (generateAiBtn) {
            generateAiBtn.addEventListener('click', function () {
                generateWithAi();
            });
        }

        if (locationInput) {
            locationInput.addEventListener('input', function () {
                if (locationDebounceTimer) {
                    clearTimeout(locationDebounceTimer);
                }

                locationDebounceTimer = setTimeout(function () {
                    fetchLocationSuggestions(locationInput.value || '');
                }, 300);
            });
        }

        container.addEventListener('click', function (event) {
            const target = event.target;
            if (!(target instanceof HTMLElement) || !target.classList.contains('remove-skill-btn')) return;
            const row = target.closest('.skill-row');
            if (!row) return;
            row.remove();
            refreshIndexes();
        });

        refreshIndexes();
    })();
</script>
{% endblock %}
