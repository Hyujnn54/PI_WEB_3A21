{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | {{ mode == 'edit' ? 'Edit Interview' : 'Create Interview' }}{% endblock %}

{% block body %}
{% set role = authUser.role|default('recruiter') %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2 tb-front-page-head">
            <div>
                <h2 class="page-title"><i class="ti ti-calendar-plus me-1"></i>{{ mode == 'edit' ? 'Modify Interview' : 'Create Interview' }}</h2>
                <p class="text-secondary mb-0">Scheduling window: future date only, maximum 90 days ahead.</p>
            </div>
            <a href="{{ path('front_interviews', app.request.query.all|merge({role: role})) }}" class="btn btn-outline-primary">Back to Interviews</a>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            <div class="card tb-admin-card">
                <div class="card-body">
                    <form method="post" class="row g-3" data-generate-link-url="{{ path('front_interview_generate_meeting_link', app.request.query.all|merge({role: role})) }}" data-application-id="{{ applicationId|default('') }}" data-interview-id="{{ interviewId|default('') }}">
                        <div class="col-md-6">
                            <label class="form-label">Scheduled At</label>
                            <input type="datetime-local" name="scheduled_at" class="form-control" value="{{ formData.scheduled_at|default('') }}" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Duration (minutes)</label>
                            <input type="number" min="15" max="240" name="duration_minutes" class="form-control" value="{{ formData.duration_minutes|default('60') }}" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Mode</label>
                            <select name="mode" class="form-select" required>
                                <option value="online" {{ formData.mode|default('online') == 'online' ? 'selected' : '' }}>Online</option>
                                <option value="onsite" {{ formData.mode|default('online') == 'onsite' ? 'selected' : '' }}>Onsite</option>
                            </select>
                        </div>
                        <div class="col-md-6" data-online-field>
                            <label class="form-label">Meeting Link (required for online)</label>
                            <div class="input-group">
                                <input type="url" name="meeting_link" class="form-control" placeholder="https://meet.example.com/room-123" value="{{ formData.meeting_link|default('') }}" maxlength="500">
                                <button type="button" class="btn btn-outline-primary" data-generate-meeting-link>Generate Jitsi Link</button>
                            </div>
                            <div class="form-hint">Use a complete http(s) URL.</div>
                            <div class="form-hint" data-meeting-link-feedback></div>
                        </div>
                        <div class="col-md-6" data-onsite-field>
                            <label class="form-label">Room (required for onsite)</label>
                            <input type="text" name="location" class="form-control" placeholder="Room / Office location" value="{{ formData.location|default('') }}" minlength="3" maxlength="120" pattern="[A-Za-z0-9 ,./#()\-]{3,120}">
                            <div class="form-hint">3-120 chars. Letters, numbers and , . / # ( ) - only.</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Additional Notes</label>
                            <textarea name="notes" rows="4" class="form-control" placeholder="Additional interview details..." maxlength="1000">{{ formData.notes|default('') }}</textarea>
                            <div class="form-hint"><span data-notes-count>0</span>/1000 characters</div>
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button type="submit" class="btn btn-primary">{{ mode == 'edit' ? 'Save Changes' : 'Create Interview' }}</button>
                            <a href="{{ path('front_interviews', app.request.query.all|merge({role: role})) }}" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const initInterviewFormPage = function () {
        const form = document.querySelector('form');
        if (!form) return;
        if (form.dataset.tbInterviewFormInitialized === '1') return;
        form.dataset.tbInterviewFormInitialized = '1';

        const modeSelect = form.querySelector('select[name="mode"]');
        const meetingInput = form.querySelector('input[name="meeting_link"]');
        const locationInput = form.querySelector('input[name="location"]');
        const generateButton = form.querySelector('[data-generate-meeting-link]');
        const generateFeedback = form.querySelector('[data-meeting-link-feedback]');
        const onlineField = form.querySelector('[data-online-field]');
        const onsiteField = form.querySelector('[data-onsite-field]');
        const notesInput = form.querySelector('textarea[name="notes"]');
        const notesCount = form.querySelector('[data-notes-count]');

        const setGenerateFeedback = function (message, type) {
            if (!generateFeedback) return;
            generateFeedback.textContent = message || '';
            generateFeedback.classList.remove('text-success', 'text-danger', 'text-secondary');
            if (type === 'success') {
                generateFeedback.classList.add('text-success');
            } else if (type === 'error') {
                generateFeedback.classList.add('text-danger');
            } else {
                generateFeedback.classList.add('text-secondary');
            }
        };

        const applyModeFields = function () {
            const mode = modeSelect ? modeSelect.value : 'online';
            if (mode === 'onsite') {
                if (onlineField) onlineField.classList.add('d-none');
                if (onsiteField) onsiteField.classList.remove('d-none');
                if (meetingInput) {
                    meetingInput.value = '';
                    meetingInput.required = false;
                    meetingInput.setCustomValidity('');
                }
                setGenerateFeedback('', 'info');
                if (locationInput) locationInput.required = true;
            } else {
                if (onsiteField) onsiteField.classList.add('d-none');
                if (onlineField) onlineField.classList.remove('d-none');
                if (locationInput) {
                    locationInput.value = '';
                    locationInput.required = false;
                    locationInput.setCustomValidity('');
                }
                if (meetingInput) meetingInput.required = true;
            }
        };

        if (modeSelect) {
            modeSelect.addEventListener('change', applyModeFields);
        }

        if (locationInput) {
            locationInput.addEventListener('input', function () {
                if (!locationInput.value || locationInput.checkValidity()) {
                    locationInput.setCustomValidity('');
                } else {
                    locationInput.setCustomValidity('Use 3-120 chars: letters, numbers and , . / # ( ) - only.');
                }
            });
        }

        if (notesInput && notesCount) {
            const syncNotesCount = function () {
                notesCount.textContent = String(notesInput.value.length);
            };
            notesInput.addEventListener('input', syncNotesCount);
            syncNotesCount();
        }

        if (generateButton) {
            generateButton.addEventListener('click', async function () {
                if (!meetingInput) return;

                const mode = modeSelect ? modeSelect.value : 'online';
                if (mode !== 'online') {
                    setGenerateFeedback('Switch mode to Online to generate a meeting link.', 'error');
                    return;
                }

                const endpoint = form.getAttribute('data-generate-link-url') || '';
                if (endpoint === '') {
                    setGenerateFeedback('Meeting link endpoint is missing.', 'error');
                    return;
                }

                generateButton.disabled = true;
                setGenerateFeedback('Generating Jitsi link...', 'info');

                const payload = new URLSearchParams();
                payload.set('mode', mode);
                payload.set('application_id', form.getAttribute('data-application-id') || '');
                payload.set('interview_id', form.getAttribute('data-interview-id') || '');

                try {
                    const response = await fetch(endpoint, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: payload.toString(),
                    });

                    const data = await response.json();
                    if (!response.ok || !data.ok || !data.meetingLink) {
                        setGenerateFeedback(data.error || 'Unable to generate a meeting link.', 'error');
                        return;
                    }

                    meetingInput.value = data.meetingLink;
                    setGenerateFeedback('Jitsi meeting link generated.', 'success');
                } catch (error) {
                    setGenerateFeedback('Unable to generate a meeting link right now.', 'error');
                } finally {
                    generateButton.disabled = false;
                }
            });
        }

        applyModeFields();
    };

    document.addEventListener('DOMContentLoaded', initInterviewFormPage);
    document.addEventListener('turbo:load', initInterviewFormPage);
</script>
{% endblock %}
