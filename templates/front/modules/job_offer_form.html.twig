{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | {{ action }} Job Offer{% endblock %}

{% block body %}
{% set role = authUser.role|default('candidate') %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <a href="{{ path('front_job_offers', { role: role }) }}" class="btn btn-outline-secondary mb-3">
                    <i class="ti ti-arrow-left me-2"></i> Back to Offers
                </a>
                <h2 class="page-title"><i class="ti ti-briefcase me-1"></i>{{ action }} Job Offer</h2>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl" style="max-width: 800px;">
            {{ display_flashes() }}

            <div class="card tb-admin-card shadow-sm">
                <div class="card-body">
                    {{ form_start(form) }}
                    
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            {{ form_row(form.title) }}
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            {{ form_row(form.description) }}
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.location) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.contract_type) }}
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.latitude) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.longitude) }}
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-12 mb-4">
                            {{ form_row(form.deadline) }}
                        </div>
                    </div>
                    
                    <div class="d-flex justify-content-end gap-2">
                        <a href="{{ path('front_job_offers', { role: role }) }}" class="btn btn-link link-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">{{ action == 'Create' ? 'Publish Offer' : 'Save Changes' }}</button>
                    </div>
                    
                    {{ form_end(form) }}
                </div>
            </div>
            
        </div>
    </div>
</div>
{% endblock %}
