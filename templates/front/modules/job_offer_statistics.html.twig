{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Offer Statistics{% endblock %}

{% block body %}
{% set role = authUser.role|default('candidate') %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2 tb-front-page-head">
            <div>
                <h2 class="page-title"><i class="ti ti-chart-pie me-1"></i>Offer Statistics</h2>
                <p class="text-secondary mb-0">Recruiter-only analytics for your offers.</p>
            </div>
            <div class="d-flex gap-2">
                <a href="{{ path('front_job_offers_statistics_export_pdf') }}" class="btn btn-primary">
                    <i class="ti ti-file-type-pdf me-1"></i>Export PDF
                </a>
                <a href="{{ path('front_job_offers', {role: 'recruiter'}) }}" class="btn btn-outline-primary">Back to Job Offers</a>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl tb-interviews-page">
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <div class="card border shadow-sm h-100">
                        <div class="card-body">
                            <div class="small text-secondary mb-1">Published Offers</div>
                            <div class="h2 mb-0">{{ offerStats.total_published }}</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border border-success shadow-sm h-100">
                        <div class="card-body">
                            <div class="small text-secondary mb-1">Open Offers</div>
                            <div class="h2 mb-1">{{ offerStats.total_open }}</div>
                            <span class="badge bg-success-lt text-success">{{ offerStats.open_percentage }}%</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border border-danger shadow-sm h-100">
                        <div class="card-body">
                            <div class="small text-secondary mb-1">Closed Offers</div>
                            <div class="h2 mb-1">{{ offerStats.total_closed }}</div>
                            <span class="badge bg-red-lt text-danger">{{ offerStats.closed_percentage }}%</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-12 col-xl-6">
                    <div class="card border shadow-sm">
                        <div class="card-header">
                            <h3 class="card-title mb-0">Open vs Closed</h3>
                        </div>
                        <div class="card-body d-flex justify-content-center">
                            <canvas id="recruiterStatusPie" width="210" height="210" style="max-width:210px; max-height:210px;"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-xl-6">
                    <div class="card border shadow-sm">
                        <div class="card-header">
                            <h3 class="card-title mb-0">Contract Types</h3>
                        </div>
                        <div class="card-body d-flex justify-content-center">
                            <canvas id="recruiterContractPie" width="210" height="210" style="max-width:210px; max-height:210px;"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-12 col-xl-7">
                    <div class="card border shadow-sm">
                        <div class="card-header">
                            <h3 class="card-title mb-0">By City</h3>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm card-table mb-0">
                                <thead>
                                    <tr>
                                        <th>City</th>
                                        <th>Total</th>
                                        <th>Open</th>
                                        <th>Closed</th>
                                        <th>Open Rate</th>
                                        <th>Closed Rate</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for city in offerStats.city_stats %}
                                        <tr>
                                            <td>{{ city.city }}</td>
                                            <td>{{ city.total }}</td>
                                            <td>{{ city.open }}</td>
                                            <td>{{ city.closed }}</td>
                                            <td>{{ city.open_rate }}%</td>
                                            <td>{{ city.closed_rate }}%</td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="6" class="text-secondary">No data.</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-xl-5">
                    <div class="card border shadow-sm">
                        <div class="card-header">
                            <h3 class="card-title mb-0">By Contract</h3>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm card-table mb-0">
                                <thead>
                                    <tr>
                                        <th>Type</th>
                                        <th>Total</th>
                                        <th>Share</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for contract in offerStats.contract_stats %}
                                        <tr>
                                            <td>{{ contract.contract_type }}</td>
                                            <td>{{ contract.total }}</td>
                                            <td>{{ contract.percentage }}%</td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="3" class="text-secondary">No data.</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const stats = {{ offerStats is not null ? offerStats|json_encode|raw : 'null' }};
        if (!stats) return;

        const initCharts = function () {
            if (!window.Chart) return;
            const statusCanvas = document.getElementById('recruiterStatusPie');
            const contractCanvas = document.getElementById('recruiterContractPie');

            if (statusCanvas) {
                new Chart(statusCanvas, {
                    type: 'doughnut',
                    data: {
                        labels: ['Open', 'Closed'],
                        datasets: [{
                            data: [Number(stats.total_open || 0), Number(stats.total_closed || 0)],
                            backgroundColor: ['#2fb344', '#d63939']
                        }]
                    },
                    options: { responsive: true, cutout: '68%', radius: '78%', plugins: { legend: { position: 'bottom' } } }
                });
            }

            if (contractCanvas) {
                const labels = (stats.contract_stats || []).map(function (item) { return item.contract_type; });
                const values = (stats.contract_stats || []).map(function (item) { return Number(item.total || 0); });
                new Chart(contractCanvas, {
                    type: 'doughnut',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: values,
                            backgroundColor: ['#206bc4', '#4299e1', '#17a2b8', '#f59f00', '#2fb344', '#d63939', '#7950f2']
                        }]
                    },
                    options: { responsive: true, cutout: '68%', radius: '78%', plugins: { legend: { position: 'bottom' } } }
                });
            }
        };

        if (window.Chart) {
            initCharts();
            return;
        }

        const chartScript = document.createElement('script');
        chartScript.src = 'https://cdn.jsdelivr.net/npm/chart.js';
        chartScript.onload = initCharts;
        document.head.appendChild(chartScript);
    })();
</script>
{% endblock %}
