{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Events{% endblock %}

{% block body %}
{% set role = authUser.role|default('candidate') %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h2 class="page-title"><i class="ti ti-calendar-event me-1"></i>Events</h2>
                <p class="text-secondary mb-0">{{ role == 'recruiter' ? 'Plan and promote talent events with targeted audiences.' : 'Join hiring events and build direct connections with recruiters.' }}</p>
            </div>
            <div class="d-flex gap-2">
                {% if role == 'recruiter' %}
                    <a href="#" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createEventModal">Create Event</a>
                {% else %}
                    <a href="#" class="btn btn-primary">My Registrations</a>
                {% endif %}
                <a href="#" class="btn btn-outline-primary">Calendar View</a>
            </div>
        </div>
    </div>
    <div class="page-body">
        {% if app.flashes('success') %}
            <div class="container-xl">
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <div class="d-flex">
                            <div>
                                <i class="ti ti-check me-2"></i>
                                {{ message }}
                            </div>
                        </div>
                        <a class="btn-close" data-bs-dismiss="alert" aria-label="Close"></a>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
        <div class="container-xl tb-interviews-page">
            <div class="row g-3 tb-interviews-layout">
                <div class="col-12 col-xl-8">
            <div class="card tb-admin-card mb-3 tb-filter-bar">
                <div class="card-body py-2">
                    <div class="tb-filter-form d-flex flex-wrap align-items-center gap-2" data-target="#eventCardsGrid">
                        <div class="input-icon">
                            <span class="input-icon-addon"><i class="ti ti-search"></i></span>
                            <input type="text" class="form-control" placeholder="Search events by title, date, location..." data-filter-search>
                        </div>
                        <select class="form-select" style="max-width: 220px;" data-filter-criteria>
                            <option value="all">Search In: All</option>
                            <option value="title">Title</option>
                            <option value="meta">Meta</option>
                            <option value="description">Description</option>
                        </select>
                        <select class="form-select" style="max-width: 230px;" data-filter-sort>
                            <option value="default">Default Order</option>
                            <option value="title_asc">Title A-Z</option>
                            <option value="title_desc">Title Z-A</option>
                            <option value="meta_asc">Meta A-Z</option>
                            <option value="meta_desc">Meta Z-A</option>
                        </select>
                        <div class="small text-secondary ms-auto" data-filter-results></div>
                    </div>
                </div>
            </div>

            <div id="eventCardsGrid" class="row row-cards">
                {% for card in cards %}
                    <div class="col-lg-4 col-md-6 tb-filter-item" data-filter-text="{{ (card.meta ~ ' ' ~ card.title ~ ' ' ~ card.text)|lower }}" data-filter-title="{{ card.title|lower }}" data-filter-meta="{{ card.meta|lower }}" data-filter-description="{{ card.text|lower }}" data-sort-title="{{ card.title|lower }}" data-sort-meta="{{ card.meta|lower }}">
                        <div class="tb-module-card h-100" data-detail-target="#eventDetailPanel" data-detail-meta="{{ card.meta }}" data-detail-title="{{ card.title }}" data-detail-text="{{ card.text }}" data-action-primary="{{ role == 'recruiter' ? 'Modify Event' : 'Register' }}" data-action-primary-href="#" data-action-primary-disabled="0" data-action-secondary="{{ role == 'recruiter' ? 'Manage Registrations' : 'Add to Calendar' }}" data-action-secondary-href="#" data-action-secondary-disabled="0" data-action-tertiary="{{ role == 'recruiter' ? 'Review Event Feedback' : 'Event Details' }}" data-action-tertiary-href="#" data-action-tertiary-disabled="0" data-detail-extra="Date & Place: {{ card.meta }}">
                            <div class="tb-module-meta">{{ card.meta }}</div>
                            <h3>{{ card.title }}</h3>
                            <p>{{ card.text }}</p>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12">
                        <div class="card tb-admin-card">
                            <div class="card-body text-secondary">No events found in the database.</div>
                        </div>
                    </div>
                {% endfor %}
            </div>

                </div>
                <div class="col-12 col-xl-4">
            <div id="eventDetailPanel" class="card tb-detail-panel tb-detail-panel-side">
                <div class="card-header">
                    <div>
                        <div class="small text-secondary tb-detail-meta"></div>
                        <h3 class="card-title mb-0 tb-detail-title">Event Details</h3>
                    </div>
                </div>
                <div class="card-body">
                    <p class="mb-3 tb-detail-text">Select an event card to display details here.</p>
                    <div class="tb-detail-extra small text-secondary mb-0"></div>
                </div>
            </div>
                </div>
            </div>

            <div id="eventActionDock" class="tb-interview-action-dock tb-generic-action-dock d-none">
                <div class="container-xl">
                    <div class="tb-interview-action-dock-inner">
                        <div class="small text-secondary">Selected event actions</div>
                        <div class="d-flex gap-2 align-items-center tb-interview-action-buttons">
                            <a href="#" class="btn btn-primary tb-dock-primary"><i class="ti ti-edit me-1"></i>Primary Action</a>
                            <form method="post" action="#" class="d-inline tb-dock-secondary-form">
                                <button type="submit" class="btn btn-outline-danger tb-dock-secondary"><i class="ti ti-trash me-1"></i>Secondary Action</button>
                            </form>
                            <a href="#" class="btn btn-outline-primary tb-dock-tertiary"><i class="ti ti-link me-1"></i>Tertiary Action</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% if role == 'recruiter' %}
    <div class="modal fade" id="createEventModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content tb-admin-card">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="ti ti-calendar-plus me-1"></i>Create Recruitment Event</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="createEventForm" method="post" action="{{ path('recruiter_create_event') }}">
                    <div class="modal-body row g-3">
                        <div class="col-md-12">
                            <label class="form-label">Event Title</label>
                            <input type="text" name="title" class="form-control" required placeholder="e.g. Tech Hiring Day">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Date & Time</label>
                            <input type="datetime-local" name="event_date" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Event Type</label>
                            <select name="event_type" class="form-control" required>
                                <option value="Workshop">Workshop</option>
                                <option value="Hiring Day">Hiring Day</option>
                                <option value="Webinar">Webinar</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Location</label>
                            <input type="text" name="location" class="form-control" required placeholder="Tunis, Sfax, or Remote">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Capacity</label>
                            <input type="number" name="capacity" min="1" max="1000" value="50" class="form-control" required>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Meeting Link (if remote)</label>
                            <input type="url" name="meet_link" class="form-control" placeholder="https://meet.google.com/xyz">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea name="description" rows="4" class="form-control" required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Create Event</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endif %}

{% endblock %}
