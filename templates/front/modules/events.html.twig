{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Events{% endblock %}

{% block body %}
{% set role = authUser.role|default('candidate') %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h2 class="page-title"><i class="ti ti-calendar-event me-1"></i>Events</h2>
                <p class="text-secondary mb-0">{{ role == 'recruiter' ? 'Plan and promote talent events with targeted audiences.' : 'Join hiring events and build direct connections with recruiters.' }}</p>
            </div>
            <div class="d-flex gap-2">
                <a href="#" class="btn btn-primary">{{ role == 'recruiter' ? 'Create Event' : 'My Registrations' }}</a>
                <a href="#" class="btn btn-outline-primary">Calendar View</a>
            </div>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl">
            <div class="row row-cards">
                <div class="col-lg-4">
                    <div class="tb-module-card h-100" data-href="#">
                        <div class="tb-module-meta">12 Apr 2026 | Tunis</div>
                        <h3>Talent Networking Day</h3>
                        <p>Meet hiring teams, attend quick interviews, and discover open positions in one place.</p>
                        <div class="tb-module-actions">
                            <a href="#" class="btn btn-sm btn-primary">{{ role == 'recruiter' ? 'Manage Event' : 'Register' }}</a>
                            <a href="#" class="btn btn-sm btn-outline-primary">Agenda</a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="tb-module-card h-100" data-href="#">
                        <div class="tb-module-meta">18 Apr 2026 | Online</div>
                        <h3>Recruiter Workshop</h3>
                        <p>Practical session on improving interview quality and reducing drop-off in hiring steps.</p>
                        <div class="tb-module-actions">
                            <a href="#" class="btn btn-sm btn-primary">{{ role == 'recruiter' ? 'Publish Seats' : 'Join Workshop' }}</a>
                            <a href="#" class="btn btn-sm btn-outline-primary">Speakers</a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="tb-module-card h-100" data-href="#">
                        <div class="tb-module-meta">27 Apr 2026 | Hybrid</div>
                        <h3>Tech Hiring Sprint</h3>
                        <p>Fast-track event with coding challenges, portfolio review, and offer pre-screening.</p>
                        <div class="tb-module-actions">
                            <a href="#" class="btn btn-sm btn-primary">{{ role == 'recruiter' ? 'Track Registrations' : 'Reserve Spot' }}</a>
                            <a href="#" class="btn btn-sm btn-outline-primary">Rules</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
