{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Job Offers{% endblock %}

{% block body %}
{% set role = authUser.role|default('candidate') %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2 tb-front-page-head">
            <div>
                <h2 class="page-title"><i class="ti ti-briefcase-2 me-1"></i>Job Offers</h2>
                <p class="text-secondary mb-0">{{ role == 'recruiter' ? 'Manage your offers and monitor candidate interest.' : 'Explore detailed roles and apply directly.' }}</p>
            </div>
            <div class="d-flex gap-2">
                <a href="#" class="btn btn-primary">{{ role == 'recruiter' ? 'Create Offer' : 'Recommended For You' }}</a>
                <a href="#" class="btn btn-outline-primary">{{ role == 'recruiter' ? 'Offer Analytics' : 'Saved Jobs' }}</a>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl tb-interviews-page">
            <div class="row g-3 tb-interviews-layout">
                <div class="col-12 col-xl-8">
            <div class="card tb-admin-card mb-3 tb-filter-bar">
                <div class="card-body py-2">
                    <div class="tb-filter-form d-flex flex-wrap align-items-center gap-2" data-target="#offerCardsGrid">
                        <div class="input-icon">
                            <span class="input-icon-addon"><i class="ti ti-search"></i></span>
                            <input type="text" class="form-control" placeholder="Search offers by title, location, contract..." data-filter-search>
                        </div>
                        <select class="form-select" style="max-width: 220px;" data-filter-criteria>
                            <option value="all">Search In: All</option>
                            <option value="title">Title</option>
                            <option value="meta">Meta</option>
                            <option value="description">Description</option>
                        </select>
                        <select class="form-select" style="max-width: 230px;" data-filter-sort>
                            <option value="default">Default Order</option>
                            <option value="title_asc">Title A-Z</option>
                            <option value="title_desc">Title Z-A</option>
                            <option value="meta_asc">Meta A-Z</option>
                            <option value="meta_desc">Meta Z-A</option>
                        </select>
                        <div class="small text-secondary ms-auto" data-filter-results></div>
                    </div>
                </div>
            </div>

            <div id="offerCardsGrid" class="row row-cards">
                {% for card in cards %}
                    <div class="col-lg-4 col-md-6 tb-filter-item" data-filter-text="{{ (card.meta ~ ' ' ~ card.title ~ ' ' ~ card.text)|lower }}" data-filter-title="{{ card.title|lower }}" data-filter-meta="{{ card.meta|lower }}" data-filter-description="{{ card.text|lower }}" data-sort-title="{{ card.title|lower }}" data-sort-meta="{{ card.meta|lower }}">
                        <div class="tb-module-card h-100" data-detail-target="#offerDetailPanel" data-detail-meta="{{ card.meta }}" data-detail-title="{{ card.title }}" data-detail-text="{{ card.text }}" data-action-primary="{{ role == 'recruiter' ? 'Modify Offer' : (card.already_applied ? 'Already Applied' : 'Apply') }}" data-action-primary-href="{{ role == 'recruiter' ? '#' : (card.already_applied ? '#' : path('app_candidate_apply', {'offerId': card.id})) }}" data-action-primary-disabled="{{ role == 'recruiter' ? '0' : (card.already_applied ? '1' : '0') }}" data-action-secondary="{{ role == 'recruiter' ? 'View Applicants' : 'Save Offer' }}" data-action-secondary-href="#" data-action-secondary-disabled="0" data-action-tertiary="{{ role == 'recruiter' ? 'Add Interview' : 'Compare Offer' }}" data-action-tertiary-href="#" data-action-tertiary-disabled="0" data-detail-extra="Type: {{ card.meta|split(' | ')|last }}||Location: {{ card.meta|split(' | ')|first }}">
                            <div class="tb-module-meta">{{ card.meta }}</div>
                            <h3>{{ card.title }}</h3>
                            <p>{{ card.text }}</p>
                            {# Candidate Apply Button #}
                            {% if role == 'candidate' %}
                                <div class="d-flex flex-wrap gap-2 mt-3">
                                    {% if card.already_applied %}
                                        <span class="btn btn-sm btn-secondary disabled"><i class="ti ti-check me-1"></i>Already Applied</span>
                                    {% else %}
                                        <a href="{{ path('app_candidate_apply', {'offerId': card.id}) }}" class="btn btn-sm btn-primary"><i class="ti ti-send me-1"></i>Apply Now</a>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {% else %}
                    <div class="col-12">
                        <div class="card tb-admin-card">
                            <div class="card-body text-secondary">No job offers found in the database.</div>
                        </div>
                    </div>
                {% endfor %}
            </div>

                </div>
                <div class="col-12 col-xl-4">
            <div id="offerDetailPanel" class="card tb-detail-panel tb-detail-panel-side">
                <div class="card-header">
                    <div>
                        <div class="small text-secondary tb-detail-meta"></div>
                        <h3 class="card-title mb-0 tb-detail-title">Offer Details</h3>
                    </div>
                </div>
                <div class="card-body">
                    <p class="mb-3 tb-detail-text">Select an offer card to display details here.</p>
                    <div class="tb-detail-extra small text-secondary mb-0"></div>
                </div>
            </div>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
