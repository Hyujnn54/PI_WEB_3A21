{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Job Offers{% endblock %}

{% block body %}
{% set role = authUser.role|default('candidate') %}
{% set isAdminReadOnly = role == 'admin' %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2 tb-front-page-head">
            <div>
                <h2 class="page-title"><i class="ti ti-briefcase-2 me-1"></i>Job Offers</h2>
                <p class="text-secondary mb-0">{{ role == 'recruiter' ? 'Manage your offers and monitor candidate interest.' : (isAdminReadOnly ? 'Read-only view of all published job offers.' : 'Browse the list of available job offers.') }}</p>
            </div>
            {% if role == 'recruiter' %}
                <div class="d-flex gap-2">
                    <a href="{{ path('front_job_offer_new', {role: 'recruiter'}) }}" class="btn btn-primary">Create Offer</a>
                    <a href="{{ path('front_job_offers_statistics', {role: 'recruiter'}) }}" class="btn btn-outline-primary">Offer Statistics</a>
                </div>
            {% endif %}
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl tb-interviews-page">
            {% if role == 'recruiter' and expiredOffers|default([])|length > 0 %}
                <div class="card border-danger mb-3">
                    <div class="card-header">
                        <h3 class="card-title text-danger mb-0"><i class="ti ti-clock-exclamation me-1"></i>Expired Offers (Auto-Closed)</h3>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th>Location</th>
                                        <th>Contract</th>
                                        <th>Status</th>
                                        <th>Deadline</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for expired in expiredOffers %}
                                        <tr>
                                            <td>{{ expired.title }}</td>
                                            <td>{{ expired.location|default('-') }}</td>
                                            <td>{{ expired.contract_type|default('-') }}</td>
                                            <td><span class="badge bg-danger">{{ expired.status|default('closed')|capitalize }}</span></td>
                                            <td>{{ expired.deadline|default('-') }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            {% endif %}

            {% if role == 'recruiter' and warnings|default([])|length > 0 %}
                <div class="card tb-admin-card border-warning mb-3">
                    <div class="card-header">
                        <h3 class="card-title text-warning-emphasis mb-0"><i class="ti ti-alert-triangle me-1"></i>Warnings from Admin</h3>
                    </div>
                    <div class="card-body d-flex flex-column gap-2">
                        {% for warning in warnings %}
                            <div class="border rounded p-2 bg-warning-subtle">
                                <div class="fw-semibold">{{ warning.title }}</div>
                                <div class="small text-secondary mb-2">Reason: {{ warning.reason }}</div>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a href="{{ path('front_job_offer_edit', {id: warning.job_offer_id, role: 'recruiter'}) }}" class="btn btn-sm btn-outline-primary">Modify Job</a>
                                    <form method="post" action="{{ path('front_job_offer_delete', {id: warning.job_offer_id, role: 'recruiter'}) }}" onsubmit="return confirm('Delete this warned job offer?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete Job</button>
                                    </form>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            <div class="row g-3 tb-interviews-layout">
                <div class="col-12 col-xl-8">
            <div class="card tb-admin-card mb-3 tb-filter-bar">
                <div class="card-body py-2">
                    <div class="d-flex flex-wrap align-items-center gap-2" id="offerMultiFilter">
                        {% if role != 'admin' %}
                            {{ form_start(filterForm, {
                                action: path('front_job_offers'),
                                method: 'GET',
                                attr: {
                                    class: 'd-flex flex-wrap align-items-center gap-2',
                                    id: 'jobOfferFilterForm'
                                }
                            }) }}
                                {{ form_widget(filterForm.search, {
                                    attr: {
                                        class: 'form-control',
                                        style: 'max-width: 260px;',
                                        placeholder: 'Search title, description, location...',
                                        id: 'filterLocation'
                                    }
                                }) }}
                                {{ form_widget(filterForm.contract_type, {
                                    attr: {
                                        class: 'form-select',
                                        style: 'max-width: 190px;',
                                        id: 'filterContractType'
                                    }
                                }) }}
                                {{ form_widget(filterForm.status, {
                                    attr: {
                                        class: 'form-select',
                                        style: 'max-width: 170px;',
                                        id: 'filterStatus'
                                    }
                                }) }}
                                {{ form_widget(filterForm.deadline, {
                                    attr: {
                                        class: 'form-control',
                                        style: 'max-width: 180px;',
                                        id: 'filterDeadline'
                                    }
                                }) }}
                                <button type="submit" class="btn btn-primary btn-sm">Search</button>
                                {% if hasActiveFilters|default(false) %}
                                    <a href="{{ path('front_job_offers', {role: role}) }}" class="btn btn-outline-secondary btn-sm">Clear Search</a>
                                {% endif %}
                            {{ form_end(filterForm) }}
                        {% endif %}
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="clearOfferFilters">Reset</button>
                        <div class="small text-secondary ms-auto" id="offerFilterResults">{{ resultCount|default(cards|length) }} result(s)</div>
                    </div>
                </div>
            </div>

            <div id="offerCardsGrid" class="row row-cards">
                {% for card in cards %}
                    {% set isPendingReview = card.warning_status|default(null) == 'RESOLVED' %}
                    <div class="col-lg-4 col-md-6">
                        <div class="tb-module-card h-100 {{ isPendingReview ? 'border-info border-2' : '' }}" style="{{ isPendingReview ? 'background-color: #f0f7ff; box-shadow: 0 0 8px rgba(0, 123, 255, 0.3);' : '' }}" data-offer-id="{{ card.id }}" data-detail-target="#offerDetailPanel" data-detail-meta="{{ card.meta }}" data-detail-title="{{ card.title }}" data-detail-text="{{ card.text }}" data-match-score="{{ card.match_score|default('') }}" data-match-label="{{ card.match_label|default('') }}" data-match-summary="{{ card.match_summary|default('')|e('html_attr') }}" data-match-matching-skills="{{ card.match_matching_skills|default('')|e('html_attr') }}" data-match-missing-skills="{{ card.match_missing_skills|default('')|e('html_attr') }}" data-match-explanation="{{ card.match_explanation|default('')|e('html_attr') }}" data-action-primary="{{ role == 'recruiter' ? 'Modify Offer' : (isAdminReadOnly ? 'Read Only' : (card.already_applied ? 'Already Applied' : (card.can_apply|default(false) ? 'Apply' : 'Offer Unavailable'))) }}" data-action-primary-href="{{ role == 'recruiter' and card.can_delete|default(false) ? path('front_job_offer_edit', {id: card.id, role: 'recruiter'}) : (isAdminReadOnly ? '#' : (card.can_apply|default(false) ? path('app_candidate_apply', {'offerId': card.id}) : '#')) }}" data-action-primary-disabled="{{ isAdminReadOnly ? '1' : (role == 'recruiter' and not card.can_delete|default(false) ? '1' : (role == 'candidate' and (card.already_applied or not card.can_apply|default(false)) ? '1' : '0')) }}" data-action-secondary="{{ role == 'recruiter' ? 'Delete Offer' : (isAdminReadOnly ? '' : 'Save Offer') }}" data-action-secondary-href="{{ role == 'recruiter' and card.can_delete|default(false) ? path('front_job_offer_delete', {id: card.id, role: 'recruiter'}) : '#' }}" data-action-secondary-disabled="{{ isAdminReadOnly ? '1' : (role == 'recruiter' and not card.can_delete|default(false) ? '1' : '0') }}" data-action-tertiary="{{ role == 'recruiter' ? 'View Applicants' : (isAdminReadOnly ? '' : 'Compare Offer') }}" data-action-tertiary-href="#" data-action-tertiary-disabled="{{ isAdminReadOnly ? '1' : '0' }}" data-detail-extra="{{ card.detail_extra is defined ? card.detail_extra|join('||') : ('Type: ' ~ card.meta|split(' | ')|last ~ '||Location: ' ~ card.meta|split(' | ')|first) }}">
                            {% if role == 'candidate' and card.match_score is defined and card.match_score is not null %}
                                {% set matchTone = card.match_score >= 85 ? 'success' : (card.match_score >= 70 ? 'warning' : 'danger') %}
                                <div class="badge bg-{{ matchTone }}-lt text-{{ matchTone }} mb-2">Match {{ card.match_score }}%{{ card.match_label|default('') ? ' - ' ~ card.match_label|capitalize : '' }}</div>
                            {% endif %}
                            {% if isPendingReview %}
                                <div class="badge bg-info mb-2" style="position: absolute; top: 8px; right: 8px;">Pending Review</div>
                            {% endif %}
                            <div class="tb-module-meta">{{ card.meta }}</div>
                            <h3>{{ card.title }}</h3>
                            <p>{{ card.text }}</p>
                            {% if role == 'candidate' %}
                                <div class="d-flex flex-wrap gap-2 mt-3">
                                    {% if card.already_applied %}
                                        <span class="btn btn-sm btn-secondary disabled"><i class="ti ti-check me-1"></i>Already Applied</span>
                                    {% elseif card.can_apply|default(false) %}
                                        <a href="{{ path('app_candidate_apply', {'offerId': card.id}) }}" class="btn btn-sm btn-primary"><i class="ti ti-send me-1"></i>Apply Now</a>
                                    {% else %}
                                        <span class="btn btn-sm btn-secondary disabled"><i class="ti ti-lock me-1"></i>Closed / Expired</span>
                                    {% endif %}
                                </div>
                            {% endif %}
                            {% if role == 'recruiter' and card.can_delete|default(false) %}
                                <a href="{{ path('front_job_offer_edit', {id: card.id, role: 'recruiter'}) }}" class="btn btn-sm btn-outline-primary mt-2">Edit</a>
                                <form method="post" action="{{ path('front_job_offer_delete', {id: card.id, role: 'recruiter'}) }}" onsubmit="return confirm('Delete this job offer?');" class="mt-2">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                {% else %}
                    <div class="col-12">
                        <div class="card tb-admin-card">
                            <div class="card-body text-secondary">No job offers found in the database.</div>
                        </div>
                    </div>
                {% endfor %}
            </div>

                </div>
                    <div class="col-12 col-xl-4">
                <div id="offerDetailPanel" class="card tb-detail-panel tb-detail-panel-side">
                    <div class="card-header">
                        <div>
                            <div class="small text-secondary tb-detail-meta"></div>
                            <h3 class="card-title mb-0 tb-detail-title">Offer Details</h3>
                        </div>
                    </div>
                    <div class="card-body">
                        <p class="mb-3 tb-detail-text">Select an offer card to display details here.</p>
                        {% if role == 'candidate' %}
                            <div class="border rounded-3 p-3 mb-3 bg-azure-lt">
                                <div class="small text-uppercase text-secondary fw-semibold mb-2">Candidate Match</div>
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <span class="badge bg-success-lt text-success tb-match-score">0%</span>
                                    <span class="fw-semibold tb-match-label">Select an offer to see the match score.</span>
                                </div>
                                <div class="small text-secondary tb-match-summary mb-2"></div>
                                <div class="small mb-2"><strong>Matching skills:</strong> <span class="tb-match-matching">-</span></div>
                                <div class="small mb-2"><strong>Missing skills:</strong> <span class="tb-match-missing">-</span></div>
                                <div class="small text-secondary tb-match-explanation"></div>
                            </div>
                            <div id="offerCommentWidget"
                                 class="border rounded-3 p-3 mb-3"
                                 data-analyze-url="{{ path('front_job_offer_comment_analyze') }}"
                                 data-list-url-template="{{ path('front_job_offer_comments_list', {id: 0}) }}"
                                 data-create-url-template="{{ path('front_job_offer_comment_create', {id: 0}) }}">
                                <div class="small text-uppercase text-secondary fw-semibold mb-2">Comment Analyzer</div>
                                <div class="small text-secondary mb-2" id="offerCommentHint">Select an offer card before posting a comment.</div>
                                <textarea id="offerCommentText" class="form-control mb-2" rows="3" placeholder="Write your comment about this offer..."></textarea>
                                <div class="d-flex gap-2 mb-2">
                                    <button type="button" id="offerCommentAnalyzeBtn" class="btn btn-sm btn-outline-primary">Analyze</button>
                                    <button type="button" id="offerCommentSubmitBtn" class="btn btn-sm btn-primary">Post Comment</button>
                                </div>
                                <div id="offerCommentAnalysis" class="small text-secondary"></div>
                                <hr class="my-2">
                                <div class="small text-uppercase text-secondary fw-semibold mb-2">Recent Comments</div>
                                <div id="offerCommentList" class="small text-secondary">No comments loaded.</div>
                            </div>
                        {% endif %}
                        <div class="tb-detail-extra small text-secondary mb-0"></div>
                    </div>
                </div>
                    </div>
            </div>

            {% if role == 'recruiter' %}
                <div id="offerActionDock" class="tb-interview-action-dock tb-generic-action-dock d-none">
                    <div class="container-xl">
                        <div class="tb-interview-action-dock-inner">
                            <div class="small text-secondary">Selected offer actions</div>
                            <div class="d-flex gap-2 align-items-center tb-interview-action-buttons">
                                <a href="#" class="btn btn-primary tb-dock-primary"><i class="ti ti-edit me-1"></i>Primary Action</a>
                                <form method="post" action="#" class="d-inline tb-dock-secondary-form">
                                    <button type="submit" class="btn btn-outline-danger tb-dock-secondary"><i class="ti ti-trash me-1"></i>Secondary Action</button>
                                </form>
                                <a href="#" class="btn btn-outline-primary tb-dock-tertiary"><i class="ti ti-link me-1"></i>Tertiary Action</a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<script>
    (function () {
        const filterForm = document.getElementById('jobOfferFilterForm');
        const locationInput = document.getElementById('filterLocation');
        const contractTypeInput = document.getElementById('filterContractType');
        const statusSelect = document.getElementById('filterStatus');
        const deadlineInput = document.getElementById('filterDeadline');
        const resetBtn = document.getElementById('clearOfferFilters');
        if (filterForm && locationInput) {
            let searchDebounceTimer = null;

            locationInput.addEventListener('input', function () {
                if (searchDebounceTimer) {
                    clearTimeout(searchDebounceTimer);
                }

                searchDebounceTimer = setTimeout(function () {
                    filterForm.requestSubmit();
                }, 350);
            });

            const autoSubmitFilter = function () {
                filterForm.requestSubmit();
            };

            if (contractTypeInput) contractTypeInput.addEventListener('change', autoSubmitFilter);
            if (statusSelect) statusSelect.addEventListener('change', autoSubmitFilter);
            if (deadlineInput) deadlineInput.addEventListener('change', autoSubmitFilter);
        }

        if (resetBtn) {
            resetBtn.addEventListener('click', function () {
                if (locationInput) locationInput.value = '';
                if (contractTypeInput) contractTypeInput.value = '';
                if (statusSelect) statusSelect.value = '';
                if (deadlineInput) deadlineInput.value = '';

                if (filterForm) {
                    filterForm.requestSubmit();
                    return;
                }
            });
        }
    })();

    (function () {
        const widget = document.getElementById('offerCommentWidget');
        if (!widget) {
            return;
        }

        const analyzeUrl = widget.getAttribute('data-analyze-url') || '';
        const listTemplate = widget.getAttribute('data-list-url-template') || '';
        const createTemplate = widget.getAttribute('data-create-url-template') || '';
        const hint = document.getElementById('offerCommentHint');
        const textarea = document.getElementById('offerCommentText');
        const analyzeBtn = document.getElementById('offerCommentAnalyzeBtn');
        const submitBtn = document.getElementById('offerCommentSubmitBtn');
        const analysisBox = document.getElementById('offerCommentAnalysis');
        const listBox = document.getElementById('offerCommentList');

        let selectedOfferId = '';

        const buildCommentsUrl = function (template, offerId) {
            return template.replace(/\/0\/comments$/, '/' + offerId + '/comments');
        };

        const setHint = function (text) {
            if (hint) {
                hint.textContent = text;
            }
        };

        const renderAnalysis = function (analysis) {
            if (!analysisBox) return;
            if (!analysis) {
                analysisBox.textContent = '';
                return;
            }

            const labels = Array.isArray(analysis.labels) ? analysis.labels.join(', ') : '';
            const line = 'toxicityScore=' + Number(analysis.toxicityScore || 0).toFixed(3)
                + ' | spamScore=' + Number(analysis.spamScore || 0).toFixed(3)
                + ' | sentiment=' + String(analysis.sentiment || 'neutral')
                + (labels ? ' | labels=' + labels : '')
                + (analysis.flagged ? ' | FLAGGED' : ' | OK')
                + (analysis.autoHidden ? ' | AUTO-HIDDEN' : '');

            analysisBox.textContent = line;
            analysisBox.className = 'small ' + (analysis.flagged ? 'text-danger' : 'text-success');
        };

        const renderComments = function (comments) {
            if (!listBox) return;
            if (!Array.isArray(comments) || comments.length === 0) {
                listBox.textContent = 'No comments yet for this offer.';
                return;
            }

            const escapeHtml = function (value) {
                return String(value || '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            };

            listBox.innerHTML = comments.map(function (comment) {
                const status = String(comment.status || 'APPROVED');
                const visibility = String(comment.visibility || 'VISIBLE');
                const sentiment = String(comment.sentiment || 'neutral');
                const author = String(comment.author || 'Candidate');
                const createdAt = String(comment.createdAt || '');
                const text = String(comment.text || '');

                return '<div class="border rounded p-2 mb-2">'
                    + '<div class="fw-semibold">' + escapeHtml(author) + '</div>'
                    + '<div class="text-secondary mb-1">' + escapeHtml(createdAt) + '</div>'
                    + '<div class="mb-1">' + escapeHtml(text) + '</div>'
                    + '<div class="small text-secondary">sentiment=' + escapeHtml(sentiment) + ' | status=' + escapeHtml(status) + ' | visibility=' + escapeHtml(visibility) + '</div>'
                    + '</div>';
            }).join('');
        };

        const loadComments = async function () {
            if (!selectedOfferId || !listTemplate) {
                if (listBox) listBox.textContent = 'Select an offer to load comments.';
                return;
            }

            if (listBox) listBox.textContent = 'Loading comments...';
            try {
                const response = await fetch(buildCommentsUrl(listTemplate, selectedOfferId), {
                    headers: {
                        'Accept': 'application/json',
                    },
                });
                const payload = await response.json();
                if (!response.ok || !payload.ok) {
                    throw new Error(payload.error || 'Unable to load comments');
                }

                renderComments(payload.comments || []);
            } catch (error) {
                if (listBox) {
                    listBox.textContent = String(error && error.message ? error.message : 'Unable to load comments.');
                }
            }
        };

        document.querySelectorAll('#offerCardsGrid .tb-module-card[data-offer-id]').forEach(function (card) {
            card.addEventListener('click', function () {
                selectedOfferId = card.getAttribute('data-offer-id') || '';
                setHint(selectedOfferId ? 'Offer #' + selectedOfferId + ' selected.' : 'Select an offer card before posting a comment.');
                renderAnalysis(null);
                loadComments();
            });
        });

        if (analyzeBtn) {
            analyzeBtn.addEventListener('click', async function () {
                const text = textarea ? textarea.value.trim() : '';
                if (!text) {
                    renderAnalysis({
                        toxicityScore: 0,
                        spamScore: 0,
                        sentiment: 'neutral',
                        labels: [],
                        flagged: false,
                        autoHidden: false,
                    });
                    if (analysisBox) {
                        analysisBox.textContent = 'Type a comment before running analysis.';
                        analysisBox.className = 'small text-warning';
                    }
                    return;
                }

                if (analysisBox) {
                    analysisBox.textContent = 'Analyzing...';
                    analysisBox.className = 'small text-secondary';
                }

                try {
                    const response = await fetch(analyzeUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json',
                        },
                        body: JSON.stringify({ comment: text }),
                    });
                    const payload = await response.json();
                    if (!response.ok || !payload.ok) {
                        throw new Error(payload.error || 'Analysis failed');
                    }

                    renderAnalysis(payload.analysis || null);
                } catch (error) {
                    if (analysisBox) {
                        analysisBox.textContent = String(error && error.message ? error.message : 'Unable to analyze comment.');
                        analysisBox.className = 'small text-danger';
                    }
                }
            });
        }

        if (submitBtn) {
            submitBtn.addEventListener('click', async function () {
                const text = textarea ? textarea.value.trim() : '';
                if (!selectedOfferId) {
                    setHint('Select an offer card before posting a comment.');
                    return;
                }

                if (!text) {
                    setHint('Comment cannot be empty.');
                    return;
                }

                submitBtn.setAttribute('disabled', 'disabled');
                setHint('Posting comment...');

                try {
                    const response = await fetch(buildCommentsUrl(createTemplate, selectedOfferId), {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json',
                        },
                        body: JSON.stringify({ comment: text }),
                    });
                    const payload = await response.json();
                    if (!response.ok || !payload.ok) {
                        throw new Error(payload.error || 'Unable to post comment');
                    }

                    if (textarea) textarea.value = '';
                    renderAnalysis(payload.analysis || null);
                    setHint('Comment posted with moderation status: ' + String((payload.comment && payload.comment.status) || 'APPROVED'));
                    loadComments();
                } catch (error) {
                    setHint(String(error && error.message ? error.message : 'Unable to post comment.'));
                } finally {
                    submitBtn.removeAttribute('disabled');
                }
            });
        }
    })();
</script>
{% endblock %}
