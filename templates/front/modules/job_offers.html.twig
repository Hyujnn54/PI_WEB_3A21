{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Job Offers{% endblock %}

{% block body %}
{% set role = authUser.role|default('candidate') %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h2 class="page-title"><i class="ti ti-briefcase-2 me-1"></i>Job Offers</h2>
                <p class="text-secondary mb-0">{{ role == 'recruiter' ? 'Manage your offers and monitor candidate interest.' : 'Explore detailed roles and apply directly.' }}</p>
            </div>
            <div class="d-flex gap-2">
                <a href="#" class="btn btn-primary">{{ role == 'recruiter' ? 'Create Offer' : 'Recommended For You' }}</a>
                <a href="#" class="btn btn-outline-primary">{{ role == 'recruiter' ? 'Offer Analytics' : 'Saved Jobs' }}</a>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            <div class="row row-cards">
                <div class="col-lg-4">
                    <div class="tb-module-card h-100" data-detail-target="#offerDetailPanel" data-detail-meta="Tunis | Full-time" data-detail-title="Senior Backend Engineer" data-detail-text="This role focuses on API scalability, architecture quality, and cross-team delivery. Use actions below for next steps." data-action-primary="{{ role == 'recruiter' ? 'Modify Offer' : 'Apply for Offer' }}" data-action-secondary="{{ role == 'recruiter' ? 'View Applicants' : 'Save Offer' }}" data-action-tertiary="{{ role == 'recruiter' ? 'Add Interview' : 'Compare Offer' }}">
                        <div class="tb-module-meta">Tunis | Full-time</div>
                        <h3>Senior Backend Engineer</h3>
                        <p>Build scalable APIs, improve hiring intelligence services, and work with data and AI pipelines.</p>
                        <div class="tb-tags"><span>Symfony</span><span>MySQL</span><span>REST</span></div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="tb-module-card h-100" data-detail-target="#offerDetailPanel" data-detail-meta="Sfax | Hybrid" data-detail-title="HR Data Analyst" data-detail-text="Analytics role for hiring conversion, recruiter productivity, and pipeline reporting. Open the actions for planned CRUD flow." data-action-primary="{{ role == 'recruiter' ? 'Modify Offer' : 'Apply for Offer' }}" data-action-secondary="{{ role == 'recruiter' ? 'View Applicants' : 'Save Offer' }}" data-action-tertiary="{{ role == 'recruiter' ? 'Add Interview' : 'Compare Offer' }}">
                        <div class="tb-module-meta">Sfax | Hybrid</div>
                        <h3>HR Data Analyst</h3>
                        <p>Analyze pipeline metrics, improve conversion ratios, and support recruiter decision-making with dashboards.</p>
                        <div class="tb-tags"><span>Analytics</span><span>SQL</span><span>BI</span></div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="tb-module-card h-100" data-detail-target="#offerDetailPanel" data-detail-meta="Remote | Contract" data-detail-title="Interview Coordinator" data-detail-text="Coordination-focused position for schedules, interview outcomes, and process quality across candidates and recruiters." data-action-primary="{{ role == 'recruiter' ? 'Modify Offer' : 'Apply for Offer' }}" data-action-secondary="{{ role == 'recruiter' ? 'View Applicants' : 'Save Offer' }}" data-action-tertiary="{{ role == 'recruiter' ? 'Add Interview' : 'Compare Offer' }}">
                        <div class="tb-module-meta">Remote | Contract</div>
                        <h3>Interview Coordinator</h3>
                        <p>Coordinate interview schedules, collect feedback, and streamline communication across candidate stages.</p>
                        <div class="tb-tags"><span>Coordination</span><span>Communication</span><span>ATS</span></div>
                    </div>
                </div>
            </div>

            <div id="offerDetailPanel" class="card tb-detail-panel mt-4 d-none">
                <div class="card-header">
                    <div>
                        <div class="small text-secondary tb-detail-meta"></div>
                        <h3 class="card-title mb-0 tb-detail-title">Offer Details</h3>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary tb-detail-close tb-detail-close-icon ms-auto" aria-label="Close details panel"><i class="ti ti-x"></i></button>
                </div>
                <div class="card-body">
                    <p class="mb-3 tb-detail-text">Select a card to preview details and available actions.</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="#" class="btn btn-primary tb-detail-primary">Primary Action</a>
                        <a href="#" class="btn btn-outline-primary tb-detail-secondary">Secondary Action</a>
                        <a href="#" class="btn btn-outline-secondary tb-detail-tertiary">Tertiary Action</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
