{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Job Offers{% endblock %}

{% block body %}
{% set role = authUser.role|default('candidate') %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h2 class="page-title"><i class="ti ti-briefcase-2 me-1"></i>Job Offers</h2>
                <p class="text-secondary mb-0">{{ role == 'recruiter' ? 'Manage your offers and monitor candidate interest.' : 'Explore detailed roles and apply directly.' }}</p>
            </div>
            <div class="d-flex gap-2">
                {% if role == 'recruiter' %}
                    <a href="{{ path('front_job_offers_new', { role: role }) }}" class="btn btn-primary"><i class="ti ti-plus me-1"></i>Create Offer</a>
                    <a href="#" class="btn btn-outline-primary">Offer Analytics</a>
                {% else %}
                    <a href="#" class="btn btn-primary">Recommended For You</a>
                    <a href="#" class="btn btn-outline-primary">Saved Jobs</a>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            <div class="card tb-admin-card mb-3 tb-filter-bar">
                <div class="card-body py-2">
                    <div class="tb-filter-form d-flex flex-wrap align-items-center gap-2" data-target="#offerCardsGrid">
                        <div class="input-icon">
                            <span class="input-icon-addon"><i class="ti ti-search"></i></span>
                            <input type="text" class="form-control" placeholder="Search offers by title, location, contract..." data-filter-search>
                        </div>
                        <select class="form-select" style="max-width: 220px;" data-filter-criteria>
                            <option value="all">Search In: All</option>
                            <option value="title">Title</option>
                            <option value="meta">Meta</option>
                            <option value="description">Description</option>
                        </select>
                        <select class="form-select" style="max-width: 230px;" data-filter-sort>
                            <option value="default">Default Order</option>
                            <option value="title_asc">Title A-Z</option>
                            <option value="title_desc">Title Z-A</option>
                            <option value="meta_asc">Meta A-Z</option>
                            <option value="meta_desc">Meta Z-A</option>
                        </select>
                        <div class="small text-secondary ms-auto" data-filter-results></div>
                    </div>
                </div>
            </div>

            <div id="offerCardsGrid" class="row row-cards">
                {% for card in cards %}
                    <div class="col-lg-4 col-md-6 tb-filter-item" data-filter-text="{{ (card.meta ~ ' ' ~ card.title ~ ' ' ~ card.text)|lower }}" data-filter-title="{{ card.title|lower }}" data-filter-meta="{{ card.meta|lower }}" data-filter-description="{{ card.text|lower }}" data-sort-title="{{ card.title|lower }}" data-sort-meta="{{ card.meta|lower }}">
                        <div class="tb-module-card h-100" data-detail-target="#offerDetailPanel" data-detail-meta="{{ card.meta }}" data-detail-title="{{ card.title }}" data-detail-text="{{ card.text }}" data-action-primary="{{ role == 'recruiter' ? 'Modify Offer' : 'Apply for Offer' }}" data-action-secondary="{{ role == 'recruiter' ? 'Delete Offer' : 'Save Offer' }}" data-action-tertiary="{{ role == 'recruiter' ? 'View Applicants' : 'Compare Offer' }}" data-action-primary-url="{{ role == 'recruiter' ? path('front_job_offers_edit', { id: card.id|default(0), role: role }) : '#' }}" data-action-secondary-url="{{ role == 'recruiter' ? path('front_job_offers_delete', { id: card.id|default(0), role: role }) : '#' }}" data-action-secondary-csrf="{{ csrf_token('delete' ~ card.id|default(0)) }}">
                            <div class="tb-module-meta">{{ card.meta }}</div>
                            <h3>{{ card.title }}</h3>
                            <p>{{ card.text }}</p>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12">
                        <div class="card tb-admin-card">
                            <div class="card-body text-secondary">No job offers found in the database.</div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <div id="offerDetailPanel" class="card tb-detail-panel mt-4 d-none">
                <div class="card-header">
                    <div>
                        <div class="small text-secondary tb-detail-meta"></div>
                        <h3 class="card-title mb-0 tb-detail-title">Offer Details</h3>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary tb-detail-close tb-detail-close-icon ms-auto" aria-label="Close details panel"><i class="ti ti-x"></i></button>
                </div>
                <div class="card-body">
                    <p class="mb-3 tb-detail-text">Select a card to preview details and available actions.</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="#" class="btn btn-primary tb-detail-primary">Primary Action</a>
                        {% if role == 'recruiter' %}
                            <form method="post" action="#" class="tb-detail-secondary-form d-inline-block">
                                <input type="hidden" name="_token" value="">
                                <button class="btn btn-outline-danger tb-detail-secondary">Secondary Action</button>
                            </form>
                        {% else %}
                            <a href="#" class="btn btn-outline-primary tb-detail-secondary">Secondary Action</a>
                        {% endif %}
                        <a href="#" class="btn btn-outline-secondary tb-detail-tertiary">Tertiary Action</a>
                    </div>
                </div>

                {# Add some inline JS or rely on base.html.twig behavior if it exists #}
                <script>
                    document.addEventListener('DOMContentLoaded', () => {
                        const panel = document.querySelector('#offerDetailPanel');
                        const primaryBtn = panel.querySelector('.tb-detail-primary');
                        const secondaryForm = panel.querySelector('.tb-detail-secondary-form');
                        const secondaryBtn = panel.querySelector('.tb-detail-secondary');
                        const tokenInput = panel.querySelector('input[name="_token"]');

                        document.querySelectorAll('.tb-module-card').forEach(card => {
                            card.addEventListener('click', () => {
                                const pUrl = card.dataset.actionPrimaryUrl;
                                if (pUrl && primaryBtn) primaryBtn.href = pUrl;
                                
                                const sUrl = card.dataset.actionSecondaryUrl;
                                const csrf = card.dataset.actionSecondaryCsrf;
                                if (sUrl && secondaryForm) {
                                    secondaryForm.action = sUrl;
                                    if (tokenInput) tokenInput.value = csrf;
                                    if (secondaryBtn) secondaryBtn.textContent = card.dataset.actionSecondary;
                                }
                            });
                        });
                    });
                </script>
            </div>
        </div>
    </div>
</div>
{% endblock %}
