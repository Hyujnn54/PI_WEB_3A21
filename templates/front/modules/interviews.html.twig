{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Interviews{% endblock %}

{% block body %}
{% set role = authUser.role|default('candidate') %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h2 class="page-title"><i class="ti ti-message-2 me-1"></i>Interviews</h2>
                <p class="text-secondary mb-0">{{ role == 'recruiter' ? 'Organize panels, evaluate candidates, and finalize outcomes.' : 'Stay prepared with schedules and decision updates.' }}</p>
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#interviewCalendarModal">Calendar</button>
            </div>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl">
            <div class="card tb-admin-card mb-3 tb-filter-bar">
                <div class="card-body py-2">
                    <div class="tb-filter-form d-flex flex-wrap align-items-center gap-2" data-target="#interviewCardsGrid">
                        <div class="input-icon">
                            <span class="input-icon-addon"><i class="ti ti-search"></i></span>
                            <input type="text" class="form-control" placeholder="Search interviews by title, date, status..." data-filter-search>
                        </div>
                        <select class="form-select" style="max-width: 220px;" data-filter-criteria>
                            <option value="all">Search In: All</option>
                            <option value="title">Title</option>
                            <option value="meta">Meta</option>
                            <option value="description">Description</option>
                        </select>
                        <select class="form-select" style="max-width: 230px;" data-filter-sort>
                            <option value="default">Default Order</option>
                            <option value="title_asc">Title A-Z</option>
                            <option value="title_desc">Title Z-A</option>
                            <option value="meta_asc">Meta A-Z</option>
                            <option value="meta_desc">Meta Z-A</option>
                        </select>
                        <div class="small text-secondary ms-auto" data-filter-results></div>
                    </div>
                </div>
            </div>

            <div id="interviewCardsGrid" class="row row-cards">
                {% for card in cards %}
                    <div class="col-md-6 col-xl-4 tb-filter-item" data-filter-text="{{ (card.meta ~ ' ' ~ card.title ~ ' ' ~ card.text)|lower }}" data-filter-title="{{ card.title|lower }}" data-filter-meta="{{ card.meta|lower }}" data-filter-description="{{ card.text|lower }}" data-sort-title="{{ card.title|lower }}" data-sort-meta="{{ card.meta|lower }}">
                        <div class="tb-module-card h-100" data-detail-target="#interviewDetailPanel" data-detail-meta="{{ card.meta }}" data-detail-title="{{ card.title }}" data-detail-text="{{ card.text }}" data-detail-extra="{{ card.detail_extra|join('||')|e('html_attr') }}" data-action-primary="Modify" data-action-primary-href="{{ card.edit_url }}" data-action-primary-disabled="{{ card.can_modify ? '0' : '1' }}" data-action-secondary="Delete" data-action-secondary-href="{{ card.delete_url }}" data-action-secondary-disabled="{{ card.can_modify ? '0' : '1' }}" data-action-tertiary="Review" data-action-tertiary-href="{{ card.feedback_url }}" data-action-tertiary-disabled="{{ card.can_feedback ? '0' : '1' }}">
                            <div class="tb-module-meta">{{ card.meta }}</div>
                            <h3>{{ card.title }}</h3>
                            <p>{{ card.text }}</p>
                            <div class="mt-2"><span class="badge {{ card.status_class|default('bg-blue-lt') }}">{{ card.status_label|default('Scheduled') }}</span></div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12">
                        <div class="card tb-admin-card">
                            <div class="card-body text-secondary">No interviews found in the database.</div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <div id="interviewDetailPanel" class="card tb-detail-panel mt-4 d-none">
                <div class="card-header">
                    <div>
                        <div class="small text-secondary tb-detail-meta"></div>
                        <h3 class="card-title mb-0 tb-detail-title">Interview Details</h3>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary tb-detail-close tb-detail-close-icon ms-auto" aria-label="Close details panel"><i class="ti ti-x"></i></button>
                </div>
                <div class="card-body">
                    <p class="mb-3 tb-detail-text">Select an interview card to open detailed actions and workflow controls.</p>
                    <div class="tb-detail-extra small text-secondary mb-3"></div>
                    {% if role == 'recruiter' %}
                        <div class="d-flex flex-wrap gap-2">
                            <a href="#" class="btn btn-primary tb-detail-primary">Modify</a>
                            <form id="tbDeleteInterviewForm" method="post" action="#" class="d-inline">
                                <button type="submit" class="btn btn-outline-danger tb-detail-secondary">Delete</button>
                            </form>
                            <a href="#" class="btn btn-outline-primary tb-detail-tertiary">Review</a>
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="modal fade" id="interviewCalendarModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
                    <div class="modal-content tb-admin-card">
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="ti ti-calendar-event me-1"></i>Upcoming Interviews Calendar</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="tb-calendar" id="tbInterviewCalendar" data-events='{{ upcomingInterviews|json_encode|e('html_attr') }}'></div>
                            <div class="small text-secondary mt-3">Highlighted dates contain upcoming interviews.</div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const calendarRoot = document.getElementById('tbInterviewCalendar');
        if (calendarRoot) {
            const raw = calendarRoot.getAttribute('data-events') || '[]';
            let events = [];
            try { events = JSON.parse(raw); } catch (e) { events = []; }

            const today = new Date();
            const year = today.getFullYear();
            const month = today.getMonth();
            const monthStart = new Date(year, month, 1);
            const monthEnd = new Date(year, month + 1, 0);
            const firstDay = (monthStart.getDay() + 6) % 7;
            const totalDays = monthEnd.getDate();
            const eventDays = new Set(events.map(function (e) {
                const parts = String(e.date || '').split(' ')[0].split('-');
                if (parts.length === 3) {
                    return new Date(parts[0], Number(parts[1]) - 1, parts[2]).toDateString();
                }
                const d = new Date(e.timestamp * 1000);
                return d.toDateString();
            }));

            const names = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
            const monthName = monthStart.toLocaleString('en-US', { month: 'long', year: 'numeric' });

            let html = '<div class="tb-calendar-title">' + monthName + '</div><div class="tb-calendar-grid tb-calendar-head">';
            names.forEach(function (n) { html += '<div>' + n + '</div>'; });
            html += '</div><div class="tb-calendar-grid">';

            for (let i = 0; i < firstDay; i++) {
                html += '<div class="tb-calendar-cell tb-empty"></div>';
            }
            for (let d = 1; d <= totalDays; d++) {
                const date = new Date(year, month, d);
                const key = date.toDateString();
                const hasEvent = eventDays.has(key);
                html += '<div class="tb-calendar-cell ' + (hasEvent ? 'tb-has-event' : '') + '">' + d + (hasEvent ? '<span class="tb-dot"></span>' : '') + '</div>';
            }
            html += '</div>';
            calendarRoot.innerHTML = html;
        }

    });
</script>
{% endblock %}
