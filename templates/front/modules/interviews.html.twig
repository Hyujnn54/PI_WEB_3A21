{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Interviews{% endblock %}

{% block body %}
{% set role = authUser.role|default('candidate') %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2 tb-front-page-head">
            <div>
                <h2 class="page-title"><i class="ti ti-message-2 me-1"></i>Interviews</h2>
                <p class="text-secondary mb-0">{{ role == 'recruiter' ? 'Organize panels, evaluate candidates, and finalize outcomes.' : 'Track all interview outcomes and decision progress.' }}</p>
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-primary" id="openInterviewCalendarBtn">Calendar</button>
            </div>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl tb-interviews-page">
            <div class="row g-3 tb-interviews-layout">
                <div class="col-12 col-xl-8">
                    <div class="card tb-admin-card mb-3 tb-filter-bar">
                        <div class="card-body py-2">
                            <div class="tb-filter-form d-flex flex-wrap align-items-center gap-2" data-target="#interviewCardsGrid">
                                <div class="input-icon">
                                    <span class="input-icon-addon"><i class="ti ti-search"></i></span>
                                    <input type="text" class="form-control" placeholder="Search interviews by title, date, status..." data-filter-search>
                                </div>
                                <select class="form-select" style="max-width: 220px;" data-filter-criteria>
                                    <option value="all">Search In: All</option>
                                    <option value="title">Title</option>
                                    <option value="meta">Meta</option>
                                    <option value="description">Description</option>
                                    <option value="status">Status</option>
                                </select>
                                <select class="form-select" style="max-width: 230px;" data-filter-sort>
                                    <option value="default">Default Order</option>
                                    <option value="date_desc">Date Newest</option>
                                    <option value="date_asc">Date Oldest</option>
                                    <option value="status_asc">Status A-Z</option>
                                    <option value="status_desc">Status Z-A</option>
                                    <option value="title_asc">Title A-Z</option>
                                    <option value="title_desc">Title Z-A</option>
                                    <option value="meta_asc">Meta A-Z</option>
                                    <option value="meta_desc">Meta Z-A</option>
                                </select>
                                <div class="small text-secondary ms-auto" data-filter-results></div>
                            </div>
                        </div>
                    </div>

                    <div id="interviewCardsGrid" class="row row-cards">
                        {% for card in cards %}
                            {% set statusLabel = card.status_label|default('Pending') %}
                            {% set statusKey = card.status_key|default('pending') %}
                            {% set detailExtra = card.detail_extra|default([]) %}
                            <div class="{{ role == 'candidate' ? 'col-12' : 'col-md-6 col-xl-4' }} tb-filter-item" data-filter-text="{{ (card.meta ~ ' ' ~ card.title ~ ' ' ~ card.text ~ ' ' ~ statusLabel)|lower }}" data-filter-title="{{ card.title|lower }}" data-filter-meta="{{ card.meta|lower }}" data-filter-description="{{ card.text|lower }}" data-filter-status="{{ statusLabel|lower }}" data-sort-title="{{ card.title|lower }}" data-sort-meta="{{ card.meta|lower }}" data-sort-status="{{ card.status_sort|default(statusLabel|lower) }}" data-sort-date="{{ card.scheduled_ts|default('0') }}">
                                <div class="tb-module-card h-100 {{ role == 'candidate' ? 'tb-candidate-card tb-status-' ~ statusKey : '' }}" data-interview-id="{{ card.id|default(0) }}" data-application-id="{{ card.application_id|default('') }}" data-edit-url="{{ card.edit_url|default('#') }}" data-edit-scheduled-at="{{ card.form_scheduled_at|default('') }}" data-edit-duration="{{ card.form_duration_minutes|default('60') }}" data-edit-mode="{{ card.form_mode|default('online') }}" data-edit-meeting-link="{{ card.form_meeting_link|default('')|e('html_attr') }}" data-edit-location="{{ card.form_location|default('')|e('html_attr') }}" data-edit-notes="{{ card.full_notes|default('')|e('html_attr') }}" data-review-score="{{ card.review_score|default('80') }}" data-review-decision="{{ card.review_decision|default('accepted') }}" data-review-comment="{{ card.review_comment|default('')|e('html_attr') }}" data-detail-target="#interviewDetailPanel" data-detail-meta="{{ card.meta }}" data-detail-title="{{ card.title }}" data-detail-text="{{ card.text }}" data-detail-extra="{{ detailExtra|join('||')|e('html_attr') }}" data-action-primary="{{ role == 'recruiter' ? 'Modify' : '' }}" data-action-primary-href="#" data-action-primary-disabled="{{ role == 'recruiter' and card.can_modify|default(false) ? '0' : '1' }}" data-action-secondary="{{ role == 'recruiter' ? 'Delete' : '' }}" data-action-secondary-href="{{ role == 'recruiter' ? card.delete_url|default('#') : '#' }}" data-action-secondary-disabled="{{ role == 'recruiter' and card.can_modify|default(false) ? '0' : '1' }}" data-action-tertiary="{{ role == 'recruiter' ? card.review_label|default('Review') : '' }}" data-action-tertiary-href="{{ role == 'recruiter' ? card.feedback_url|default('#') : '#' }}" data-action-tertiary-disabled="{{ role == 'recruiter' and card.can_feedback|default(false) ? '0' : '1' }}">
                                    <div class="d-flex align-items-start justify-content-between gap-2">
                                        <div class="tb-module-meta mb-0">{{ card.meta }}</div>
                                        <span class="badge tb-interview-status tb-status-anchor {{ card.status_class|default('bg-blue-lt') }}">{{ statusLabel }}</span>
                                    </div>
                                    <h3>{{ card.title }}</h3>
                                    <p>{{ card.text }}</p>
                                    {# Inline action buttons for recruiter #}
                                    {% if role == 'recruiter' %}
                                        <div class="d-flex flex-wrap gap-2 mt-3">
                                            <button type="button" class="btn btn-sm btn-primary tb-inline-modify {{ card.can_modify|default(false) ? '' : 'disabled' }}" 
                                                data-interview-id="{{ card.id|default(0) }}"
                                                {% if not card.can_modify|default(false) %}disabled title="Cannot modify - interview date has passed or is within 2 hours"{% endif %}>
                                                <i class="ti ti-edit me-1"></i>Modify
                                            </button>
                                            <form method="post" action="{{ card.delete_url|default('#') }}" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger {{ card.can_modify|default(false) ? '' : 'disabled' }}"
                                                    {% if not card.can_modify|default(false) %}disabled title="Cannot delete - interview date has passed or is within 2 hours"{% endif %}
                                                    onclick="return confirm('Are you sure you want to delete this interview?');">
                                                    <i class="ti ti-trash me-1"></i>Delete
                                                </button>
                                            </form>
                                            <button type="button" class="btn btn-sm btn-outline-primary tb-inline-review {{ card.can_feedback|default(false) ? '' : 'disabled' }}"
                                                data-interview-id="{{ card.id|default(0) }}"
                                                data-feedback-url="{{ card.feedback_url|default('#') }}"
                                                {% if not card.can_feedback|default(false) %}disabled title="Cannot review - interview has not ended yet"{% endif %}>
                                                <i class="ti ti-message-2-check me-1"></i>{{ card.review_label|default('Review') }}
                                            </button>
                                        </div>
                                    {% endif %}
                                    {# Candidate view is read-only in interview cards (no action buttons). #}
                                </div>
                            </div>
                        {% else %}
                            <div class="col-12">
                                <div class="card tb-admin-card">
                                    <div class="card-body text-secondary">No interviews found in the database.</div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <div class="col-12 col-xl-4">
                    <div id="interviewDetailPanel" class="card tb-detail-panel tb-detail-panel-side">
                        <div class="card-header">
                            <div>
                                <div class="small text-secondary tb-detail-meta"></div>
                                <h3 class="card-title mb-0 tb-detail-title">Interview Details</h3>
                            </div>
                        </div>
                        <div class="card-body">
                            <p class="mb-3 tb-detail-text">Select an interview card to display details here.</p>
                            <div class="tb-detail-extra small text-secondary mb-0"></div>
                        </div>
                    </div>
                </div>
            </div>

            {# Bottom dock removed - buttons are now inline on cards #}

            <div class="modal fade" id="interviewCalendarModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
                    <div class="modal-content tb-admin-card tb-modal-shell">
                        <div class="modal-header tb-modal-header">
                            <h5 class="modal-title"><i class="ti ti-calendar-event me-1"></i>Interviews Calendar</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="tb-calendar-tools">
                                <div class="btn-group btn-group-sm" role="group" aria-label="Calendar navigation">
                                    <button type="button" class="btn btn-outline-primary" id="tbCalendarPrevMonth"><i class="ti ti-chevron-left"></i></button>
                                    <button type="button" class="btn btn-outline-primary" id="tbCalendarToday">Today</button>
                                    <button type="button" class="btn btn-outline-primary" id="tbCalendarNextMonth"><i class="ti ti-chevron-right"></i></button>
                                </div>
                                <div class="tb-calendar-legend"><span class="tb-calendar-legend-dot"></span><span>Highlighted days contain interviews</span></div>
                            </div>
                            <h6 id="tbCalendarMonthLabel" class="tb-calendar-title"></h6>
                            <div id="tbCalendarSummary" class="tb-calendar-summary small"></div>
                            <div class="tb-calendar" id="tbInterviewCalendar" data-events='{{ upcomingInterviews|default([])|json_encode|e('html_attr') }}'></div>
                            <div id="tbCalendarDayDetails" class="tb-calendar-day-details mt-3"></div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>

            {% if role == 'recruiter' %}
                <div class="modal fade" id="editInterviewModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-lg modal-dialog-centered">
                        <div class="modal-content tb-admin-card tb-modal-shell">
                            <div class="modal-header tb-modal-header">
                                <h5 class="modal-title"><i class="ti ti-edit me-1"></i>Modify Interview</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <form id="editInterviewForm" method="post" data-generate-link-url="{{ path('front_interview_generate_meeting_link', app.request.query.all|merge({role: role})) }}">
                                <div class="modal-body row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Scheduled At</label>
                                        <input type="datetime-local" name="scheduled_at" class="form-control" required>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Duration</label>
                                        <input type="number" min="15" max="240" name="duration_minutes" class="form-control" required>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Mode</label>
                                        <select name="mode" class="form-select" required>
                                            <option value="online">Online</option>
                                            <option value="onsite">Onsite</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6" data-online-field>
                                        <label class="form-label">Meeting Link (online)</label>
                                        <div class="input-group">
                                            <input type="url" name="meeting_link" class="form-control" placeholder="https://meet.example.com/room-123" maxlength="500">
                                            <button type="button" class="btn btn-outline-primary" data-edit-generate-meeting-link>Generate Jitsi Link</button>
                                        </div>
                                        <div class="form-hint">Use a complete http(s) URL.</div>
                                        <div class="form-hint" data-edit-meeting-link-feedback></div>
                                    </div>
                                    <div class="col-md-6" data-onsite-field>
                                        <label class="form-label">Room (onsite)</label>
                                        <input type="text" name="location" class="form-control" placeholder="Room / Office location" minlength="3" maxlength="120" pattern="[A-Za-z0-9 ,./#()\-]{3,120}">
                                        <div class="form-hint">3-120 chars. Letters, numbers and , . / # ( ) - only.</div>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">Additional Notes</label>
                                        <textarea name="notes" rows="3" class="form-control" maxlength="1000"></textarea>
                                        <div class="form-hint"><span data-edit-notes-count>0</span>/1000 characters</div>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary">Confirm</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="reviewInterviewModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-lg modal-dialog-centered">
                        <div class="modal-content tb-admin-card tb-modal-shell">
                            <div class="modal-header tb-modal-header">
                                <h5 class="modal-title"><i class="ti ti-message-2-check me-1"></i>Interview Review</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <form id="reviewInterviewForm" method="post">
                                <div class="modal-body row g-3">
                                    <div class="col-md-4">
                                        <label class="form-label">Overall Score</label>
                                        <input type="number" name="overall_score" min="0" max="100" class="form-control" required>
                                    </div>
                                    <div class="col-md-8">
                                        <label class="form-label">Decision</label>
                                        <select name="decision" class="form-select" required>
                                            <option value="accepted">Accepted</option>
                                            <option value="rejected">Rejected</option>
                                        </select>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">Comment</label>
                                        <textarea name="comment" rows="4" class="form-control" required minlength="10" maxlength="1000"></textarea>
                                        <div class="form-hint"><span data-review-comment-count>0</span>/1000 characters, minimum 10.</div>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary">Save Review</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<script>
    const initInterviewsPage = function () {
        const pageRoot = document.querySelector('.tb-interviews-page');
        if (!pageRoot) {
            return;
        }

        if (pageRoot.dataset.tbInterviewsInitialized === '1') {
            return;
        }
        pageRoot.dataset.tbInterviewsInitialized = '1';

        const params = new URLSearchParams(window.location.search);
        const calendarRoot = document.getElementById('tbInterviewCalendar');
        const dayDetails = document.getElementById('tbCalendarDayDetails');
        const calendarModalEl = document.getElementById('interviewCalendarModal');
        const calendarOpenBtn = document.getElementById('openInterviewCalendarBtn');

        if (calendarModalEl && calendarOpenBtn && typeof bootstrap !== 'undefined') {
            const calendarModal = bootstrap.Modal.getOrCreateInstance(calendarModalEl);
            calendarOpenBtn.addEventListener('click', function (event) {
                event.preventDefault();
                calendarModal.show();
            });
        }

        if (calendarRoot) {
            const raw = calendarRoot.getAttribute('data-events') || '[]';
            let events = [];
            try { events = JSON.parse(raw); } catch (e) { events = []; }

            const calendarMonthLabel = document.getElementById('tbCalendarMonthLabel');
            const calendarSummary = document.getElementById('tbCalendarSummary');
            const prevMonthBtn = document.getElementById('tbCalendarPrevMonth');
            const nextMonthBtn = document.getElementById('tbCalendarNextMonth');
            const todayBtn = document.getElementById('tbCalendarToday');
            const dayNames = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
            const today = new Date();

            const pad = function (value) {
                return String(value).padStart(2, '0');
            };

            const toYmd = function (date) {
                return date.getFullYear() + '-' + pad(date.getMonth() + 1) + '-' + pad(date.getDate());
            };

            const parseYmd = function (ymd) {
                const parts = (ymd || '').split('-');
                if (parts.length !== 3) return null;
                const y = Number(parts[0]);
                const m = Number(parts[1]);
                const d = Number(parts[2]);
                if (!Number.isFinite(y) || !Number.isFinite(m) || !Number.isFinite(d)) return null;
                return new Date(y, m - 1, d);
            };

            const escapeHtml = function (value) {
                return String(value || '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            };

            const formatPrettyDate = function (ymd) {
                const parsed = parseYmd(ymd);
                if (!parsed) return ymd || 'Selected date';
                return parsed.toLocaleDateString('en-US', {
                    weekday: 'short',
                    month: 'short',
                    day: 'numeric',
                    year: 'numeric'
                });
            };

            const normalizedEvents = [];
            events.forEach(function (entry) {
                if (!entry) return;
                const fallbackDate = entry.timestamp ? new Date(Number(entry.timestamp) * 1000) : null;
                const dateObj = entry.ymd ? parseYmd(entry.ymd) : fallbackDate;
                if (!dateObj || Number.isNaN(dateObj.getTime())) return;
                const rawInterviewId = entry.interview_id || entry.interviewId || '';

                normalizedEvents.push({
                    interviewId: rawInterviewId === null || typeof rawInterviewId === 'undefined' ? '' : String(rawInterviewId),
                    ymd: toYmd(dateObj),
                    title: entry.title || 'Interview',
                    date: entry.date || '',
                    mode: entry.mode || 'n/a',
                    status: entry.status || 'pending',
                    location: entry.location || 'No location specified',
                    timestamp: Number(entry.timestamp || 0)
                });
            });
            normalizedEvents.sort(function (a, b) { return a.timestamp - b.timestamp; });

            const eventsByDay = {};
            normalizedEvents.forEach(function (entry) {
                if (!eventsByDay[entry.ymd]) eventsByDay[entry.ymd] = [];
                eventsByDay[entry.ymd].push(entry);
            });

            let viewYear = today.getFullYear();
            let viewMonth = today.getMonth();
            const todayKey = toYmd(today);
            let selectedKey = todayKey;

            const firstEventForMonth = function (year, month) {
                const prefix = year + '-' + pad(month + 1) + '-';
                for (let i = 0; i < normalizedEvents.length; i++) {
                    if (normalizedEvents[i].ymd.indexOf(prefix) === 0) return normalizedEvents[i].ymd;
                }
                return null;
            };

            const countEventsForMonth = function (year, month) {
                const prefix = year + '-' + pad(month + 1) + '-';
                let total = 0;
                Object.keys(eventsByDay).forEach(function (key) {
                    if (key.indexOf(prefix) === 0) {
                        total += eventsByDay[key].length;
                    }
                });
                return total;
            };

            const ensureSelectionForCurrentView = function () {
                const monthPrefix = viewYear + '-' + pad(viewMonth + 1) + '-';
                if (selectedKey && selectedKey.indexOf(monthPrefix) === 0) return;
                selectedKey = firstEventForMonth(viewYear, viewMonth) || (viewYear + '-' + pad(viewMonth + 1) + '-01');
            };

            const focusInterviewCard = function (interviewId, interviewTimestamp) {
                const id = String(interviewId || '').trim();
                const ts = String(interviewTimestamp || '').trim();

                const findCard = function () {
                    if (id !== '') {
                        const byId = document.querySelector('.tb-module-card[data-interview-id="' + id + '"]');
                        if (byId) return byId;
                    }

                    if (ts !== '') {
                        const byTs = document.querySelector('.tb-module-card[data-sort-date="' + ts + '"]');
                        if (byTs) return byTs;
                    }

                    return null;
                };

                const activateCard = function () {
                    const card = findCard();
                    if (!card) return false;

                    card.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    card.click();
                    card.classList.add('tb-calendar-linked');
                    window.setTimeout(function () {
                        card.classList.remove('tb-calendar-linked');
                    }, 1400);
                    return true;
                };

                const forceCloseCalendarModal = function () {
                    if (!calendarModalEl) return;

                    calendarModalEl.classList.remove('show');
                    calendarModalEl.setAttribute('aria-hidden', 'true');
                    calendarModalEl.removeAttribute('aria-modal');
                    calendarModalEl.style.display = 'none';

                    const hasAnyOpenModal = document.querySelectorAll('.modal.show').length > 0;
                    if (!hasAnyOpenModal) {
                        document.body.classList.remove('modal-open');
                        document.body.style.removeProperty('padding-right');
                        document.body.style.removeProperty('overflow');
                        document.querySelectorAll('.modal-backdrop').forEach(function (backdrop) {
                            backdrop.remove();
                        });
                    }
                };

                if (!calendarModalEl) {
                    return activateCard();
                }

                if (typeof bootstrap !== 'undefined') {
                    const modalInstance = bootstrap.Modal.getOrCreateInstance(calendarModalEl);
                    modalInstance.hide();
                }

                // Always force-close to avoid transition/backdrop desync, then activate card.
                forceCloseCalendarModal();
                window.setTimeout(function () {
                    activateCard();
                }, 80);
                return true;
            };

            const renderDayDetails = function (ymd) {
                if (!dayDetails) return;

                const dayEvents = eventsByDay[ymd] || [];
                let block = '<div class="tb-calendar-day-title">Interviews on ' + escapeHtml(formatPrettyDate(ymd)) + '</div>';

                if (dayEvents.length === 0) {
                    block += '<div class="tb-calendar-day-empty">No interviews on this date.</div>';
                    dayDetails.innerHTML = block;
                    return;
                }

                dayEvents.forEach(function (entry) {
                    const hasLink = String(entry.interviewId || '').trim() !== '' || String(entry.timestamp || '').trim() !== '';
                    block += '<button type="button" class="tb-calendar-event-item' + (hasLink ? ' tb-calendar-event-action' : '') + '" data-calendar-interview-id="' + escapeHtml(entry.interviewId) + '" data-calendar-interview-ts="' + escapeHtml(String(entry.timestamp || '')) + '">';
                    block += '<div class="tb-calendar-event-head">';
                    block += '<div class="tb-calendar-event-title">' + escapeHtml(entry.title) + '</div>';
                    block += '<span class="tb-calendar-event-status">' + escapeHtml(entry.status) + '</span>';
                    block += '</div>';
                    block += '<div class="small text-secondary">' + escapeHtml(entry.date || formatPrettyDate(entry.ymd)) + '</div>';
                    block += '<div class="small text-secondary">Mode: ' + escapeHtml(entry.mode) + ' | Location: ' + escapeHtml(entry.location) + '</div>';
                    if (hasLink) {
                        block += '<div class="small text-primary mt-1">Open interview details</div>';
                    }
                    block += '</button>';
                });

                dayDetails.innerHTML = block;

                dayDetails.querySelectorAll('.tb-calendar-event-action').forEach(function (item) {
                    item.addEventListener('click', function (event) {
                        event.preventDefault();
                        event.stopPropagation();
                        const interviewId = item.getAttribute('data-calendar-interview-id') || '';
                        const interviewTs = item.getAttribute('data-calendar-interview-ts') || '';
                        focusInterviewCard(interviewId, interviewTs);
                    });
                });
            };

            const renderCalendar = function () {
                ensureSelectionForCurrentView();

                const monthStart = new Date(viewYear, viewMonth, 1);
                const firstDay = (monthStart.getDay() + 6) % 7;
                const totalDays = new Date(viewYear, viewMonth + 1, 0).getDate();

                if (calendarMonthLabel) {
                    calendarMonthLabel.textContent = monthStart.toLocaleString('en-US', { month: 'long', year: 'numeric' });
                }

                if (calendarSummary) {
                    const monthlyEvents = countEventsForMonth(viewYear, viewMonth);
                    calendarSummary.textContent = monthlyEvents === 0
                        ? 'No interviews scheduled this month.'
                        : monthlyEvents + (monthlyEvents === 1 ? ' interview scheduled this month.' : ' interviews scheduled this month.');
                }

                let html = '<div class="tb-calendar-grid tb-calendar-head">';
                dayNames.forEach(function (name) { html += '<div>' + name + '</div>'; });
                html += '</div><div class="tb-calendar-grid tb-calendar-days">';

                for (let i = 0; i < firstDay; i++) {
                    html += '<div class="tb-calendar-cell tb-empty" aria-hidden="true"></div>';
                }

                for (let d = 1; d <= totalDays; d++) {
                    const currentDate = new Date(viewYear, viewMonth, d);
                    const key = toYmd(currentDate);
                    const dayEvents = eventsByDay[key] || [];
                    const classes = ['tb-calendar-cell'];
                    if (dayEvents.length) classes.push('tb-has-event');
                    if (key === selectedKey) classes.push('is-selected');
                    if (key === todayKey) classes.push('tb-is-today');

                    html += '<button type="button" class="' + classes.join(' ') + '" data-calendar-date="' + key + '" aria-label="' + escapeHtml(formatPrettyDate(key)) + '">';
                    html += String(d);
                    if (dayEvents.length) {
                        html += '<span class="tb-dot"></span><span class="tb-count">' + dayEvents.length + '</span>';
                    }
                    html += '</button>';
                }

                const cellsUsed = firstDay + totalDays;
                const trailing = (7 - (cellsUsed % 7)) % 7;
                for (let i = 0; i < trailing; i++) {
                    html += '<div class="tb-calendar-cell tb-empty" aria-hidden="true"></div>';
                }

                html += '</div>';
                calendarRoot.innerHTML = html;

                calendarRoot.querySelectorAll('[data-calendar-date]').forEach(function (cell) {
                    cell.addEventListener('click', function () {
                        selectedKey = cell.getAttribute('data-calendar-date') || selectedKey;
                        renderCalendar();
                    });
                });

                renderDayDetails(selectedKey);
            };

            if (prevMonthBtn) {
                prevMonthBtn.addEventListener('click', function () {
                    const prev = new Date(viewYear, viewMonth - 1, 1);
                    viewYear = prev.getFullYear();
                    viewMonth = prev.getMonth();
                    selectedKey = '';
                    renderCalendar();
                });
            }

            if (nextMonthBtn) {
                nextMonthBtn.addEventListener('click', function () {
                    const next = new Date(viewYear, viewMonth + 1, 1);
                    viewYear = next.getFullYear();
                    viewMonth = next.getMonth();
                    selectedKey = '';
                    renderCalendar();
                });
            }

            if (todayBtn) {
                todayBtn.addEventListener('click', function () {
                    viewYear = today.getFullYear();
                    viewMonth = today.getMonth();
                    selectedKey = todayKey;
                    renderCalendar();
                });
            }

            if (calendarModalEl) {
                calendarModalEl.addEventListener('shown.bs.modal', renderCalendar);
            }

            renderCalendar();
        }

        const now = new Date();
        const minValue = new Date(now.getTime() - now.getTimezoneOffset() * 60000).toISOString().slice(0, 16);

        const editModalEl = document.getElementById('editInterviewModal');
        const editForm = document.getElementById('editInterviewForm');
        if (editModalEl && editForm && typeof bootstrap !== 'undefined') {
            const editModal = new bootstrap.Modal(editModalEl);
            const modeSelect = editForm.querySelector('select[name="mode"]');
            const scheduleInput = editForm.querySelector('input[name="scheduled_at"]');
            const meetingInput = editForm.querySelector('input[name="meeting_link"]');
            const generateMeetingButton = editForm.querySelector('[data-edit-generate-meeting-link]');
            const generateMeetingFeedback = editForm.querySelector('[data-edit-meeting-link-feedback]');
            const locationInput = editForm.querySelector('input[name="location"]');
            const notesInput = editForm.querySelector('textarea[name="notes"]');
            const notesCount = editForm.querySelector('[data-edit-notes-count]');
            const onlineField = editForm.querySelector('[data-online-field]');
            const onsiteField = editForm.querySelector('[data-onsite-field]');

            if (scheduleInput) scheduleInput.min = minValue;

            const setGenerateFeedback = function (message, type) {
                if (!generateMeetingFeedback) return;
                generateMeetingFeedback.textContent = message || '';
                generateMeetingFeedback.classList.remove('text-success', 'text-danger', 'text-secondary');
                if (type === 'success') {
                    generateMeetingFeedback.classList.add('text-success');
                } else if (type === 'error') {
                    generateMeetingFeedback.classList.add('text-danger');
                } else {
                    generateMeetingFeedback.classList.add('text-secondary');
                }
            };

            const applyModeFields = function () {
                const mode = modeSelect ? modeSelect.value : 'online';
                if (mode === 'onsite') {
                    if (onlineField) onlineField.classList.add('d-none');
                    if (onsiteField) onsiteField.classList.remove('d-none');
                    if (meetingInput) {
                        meetingInput.required = false;
                        meetingInput.setCustomValidity('');
                    }
                    setGenerateFeedback('', 'info');
                    if (locationInput) { locationInput.required = true; }
                } else {
                    if (onsiteField) onsiteField.classList.add('d-none');
                    if (onlineField) onlineField.classList.remove('d-none');
                    if (locationInput) {
                        locationInput.required = false;
                        locationInput.setCustomValidity('');
                    }
                    if (meetingInput) { meetingInput.required = true; }
                }
            };

            if (modeSelect) modeSelect.addEventListener('change', applyModeFields);

            if (locationInput) {
                locationInput.addEventListener('input', function () {
                    if (!locationInput.value || locationInput.checkValidity()) {
                        locationInput.setCustomValidity('');
                    } else {
                        locationInput.setCustomValidity('Use 3-120 chars: letters, numbers and , . / # ( ) - only.');
                    }
                });
            }

            if (notesInput && notesCount) {
                const syncNotesCount = function () {
                    notesCount.textContent = String(notesInput.value.length);
                };
                notesInput.addEventListener('input', syncNotesCount);
                syncNotesCount();
            }

            const openEditModalForCard = function (card) {
                if (!card) return;
                editForm.setAttribute('action', card.getAttribute('data-edit-url') || '#');
                const scheduledAt = card.getAttribute('data-edit-scheduled-at') || '';
                const duration = card.getAttribute('data-edit-duration') || '60';
                const mode = card.getAttribute('data-edit-mode') || 'online';
                const meetingLink = card.getAttribute('data-edit-meeting-link') || '';
                const location = card.getAttribute('data-edit-location') || '';
                const notes = card.getAttribute('data-edit-notes') || '';
                const applicationId = card.getAttribute('data-application-id') || '';
                const interviewId = card.getAttribute('data-interview-id') || '';

                const durationInput = editForm.querySelector('input[name="duration_minutes"]');
                const notesInput = editForm.querySelector('textarea[name="notes"]');

                if (scheduleInput) scheduleInput.value = scheduledAt;
                if (durationInput) durationInput.value = duration;
                if (modeSelect) modeSelect.value = mode;
                if (meetingInput) meetingInput.value = meetingLink;
                if (locationInput) locationInput.value = location;
                if (notesInput) notesInput.value = notes;
                editForm.setAttribute('data-application-id', applicationId);
                editForm.setAttribute('data-interview-id', interviewId);
                setGenerateFeedback('', 'info');
                applyModeFields();
                if (notesCount && notesInput) notesCount.textContent = String(notesInput.value.length);
                editModal.show();
            };

            if (generateMeetingButton) {
                generateMeetingButton.addEventListener('click', async function () {
                    if (!meetingInput) return;

                    const mode = modeSelect ? modeSelect.value : 'online';
                    if (mode !== 'online') {
                        setGenerateFeedback('Switch mode to Online to generate a meeting link.', 'error');
                        return;
                    }

                    const endpoint = editForm.getAttribute('data-generate-link-url') || '';
                    if (endpoint === '') {
                        setGenerateFeedback('Meeting link endpoint is missing.', 'error');
                        return;
                    }

                    generateMeetingButton.disabled = true;
                    setGenerateFeedback('Generating Jitsi link...', 'info');

                    const payload = new URLSearchParams();
                    payload.set('mode', mode);
                    payload.set('application_id', editForm.getAttribute('data-application-id') || '');
                    payload.set('interview_id', editForm.getAttribute('data-interview-id') || '');

                    try {
                        const response = await fetch(endpoint, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                                'X-Requested-With': 'XMLHttpRequest'
                            },
                            body: payload.toString(),
                        });

                        const data = await response.json();
                        if (!response.ok || !data.ok || !data.meetingLink) {
                            setGenerateFeedback(data.error || 'Unable to generate a meeting link.', 'error');
                            return;
                        }

                        meetingInput.value = data.meetingLink;
                        setGenerateFeedback('Jitsi meeting link generated.', 'success');
                    } catch (error) {
                        setGenerateFeedback('Unable to generate a meeting link right now.', 'error');
                    } finally {
                        generateMeetingButton.disabled = false;
                    }
                });
            }

            const modifyBtn = document.querySelector('.tb-detail-primary');
            if (modifyBtn) {
                modifyBtn.addEventListener('click', function (e) {
                    e.preventDefault();
                    if (modifyBtn.classList.contains('disabled')) return;
                    const card = document.querySelector('.tb-module-card.is-selected');
                    openEditModalForCard(card);
                });
            }

            const openEditFor = params.get('openEditFor');
            if (openEditFor) {
                const card = document.querySelector('.tb-module-card[data-interview-id="' + openEditFor + '"]');
                if (card) openEditModalForCard(card);
            }
        }

        const reviewModalEl = document.getElementById('reviewInterviewModal');
        const reviewForm = document.getElementById('reviewInterviewForm');
        if (reviewModalEl && reviewForm && typeof bootstrap !== 'undefined') {
            const reviewModal = new bootstrap.Modal(reviewModalEl);
            const reviewScore = reviewForm.querySelector('input[name="overall_score"]');
            const reviewDecision = reviewForm.querySelector('select[name="decision"]');
            const reviewComment = reviewForm.querySelector('textarea[name="comment"]');
            const reviewCommentCount = reviewForm.querySelector('[data-review-comment-count]');

            if (reviewComment && reviewCommentCount) {
                const syncReviewCommentCount = function () {
                    reviewCommentCount.textContent = String(reviewComment.value.length);
                };
                reviewComment.addEventListener('input', syncReviewCommentCount);
                syncReviewCommentCount();
            }

            const openReviewModalForCard = function (card) {
                if (!card) return;
                const actionUrl = card.getAttribute('data-action-tertiary-href') || '#';
                reviewForm.setAttribute('action', actionUrl);
                if (reviewScore) reviewScore.value = card.getAttribute('data-review-score') || '80';
                if (reviewDecision) reviewDecision.value = card.getAttribute('data-review-decision') || 'accepted';
                if (reviewComment) reviewComment.value = card.getAttribute('data-review-comment') || '';
                if (reviewCommentCount && reviewComment) reviewCommentCount.textContent = String(reviewComment.value.length);
                reviewModal.show();
            };

            // Handle inline review buttons (new approach)
            document.querySelectorAll('.tb-inline-review').forEach(function (btn) {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    if (btn.disabled || btn.classList.contains('disabled')) return;
                    const card = btn.closest('.tb-module-card');
                    if (card) {
                        const feedbackUrl = btn.getAttribute('data-feedback-url') || card.getAttribute('data-action-tertiary-href') || '#';
                        reviewForm.setAttribute('action', feedbackUrl);
                        if (reviewScore) reviewScore.value = card.getAttribute('data-review-score') || '80';
                        if (reviewDecision) reviewDecision.value = card.getAttribute('data-review-decision') || 'accepted';
                        if (reviewComment) reviewComment.value = card.getAttribute('data-review-comment') || '';
                        if (reviewCommentCount && reviewComment) reviewCommentCount.textContent = String(reviewComment.value.length);
                        reviewModal.show();
                    }
                });
            });

            const openReviewFor = params.get('openReviewFor');
            if (openReviewFor) {
                const card = document.querySelector('.tb-module-card[data-interview-id="' + openReviewFor + '"]');
                if (card) openReviewModalForCard(card);
            }
        }

        // Handle inline modify buttons (new approach)
        document.querySelectorAll('.tb-inline-modify').forEach(function (btn) {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                if (btn.disabled || btn.classList.contains('disabled')) return;
                const card = btn.closest('.tb-module-card');
                if (card) {
                    const editModalEl = document.getElementById('editInterviewModal');
                    const editForm = document.getElementById('editInterviewForm');
                    if (editModalEl && editForm && typeof bootstrap !== 'undefined') {
                        const editModal = bootstrap.Modal.getOrCreateInstance(editModalEl);
                        editForm.setAttribute('action', card.getAttribute('data-edit-url') || '#');
                        const scheduledAt = card.getAttribute('data-edit-scheduled-at') || '';
                        const duration = card.getAttribute('data-edit-duration') || '60';
                        const mode = card.getAttribute('data-edit-mode') || 'online';
                        const meetingLink = card.getAttribute('data-edit-meeting-link') || '';
                        const location = card.getAttribute('data-edit-location') || '';
                        const notes = card.getAttribute('data-edit-notes') || '';

                        const scheduleInput = editForm.querySelector('input[name="scheduled_at"]');
                        const durationInput = editForm.querySelector('input[name="duration_minutes"]');
                        const modeSelect = editForm.querySelector('select[name="mode"]');
                        const meetingInput = editForm.querySelector('input[name="meeting_link"]');
                        const locationInput = editForm.querySelector('input[name="location"]');
                        const notesInput = editForm.querySelector('textarea[name="notes"]');
                        const notesCount = editForm.querySelector('[data-edit-notes-count]');
                        const onlineField = editForm.querySelector('[data-online-field]');
                        const onsiteField = editForm.querySelector('[data-onsite-field]');

                        if (scheduleInput) scheduleInput.value = scheduledAt;
                        if (durationInput) durationInput.value = duration;
                        if (modeSelect) modeSelect.value = mode;
                        if (meetingInput) meetingInput.value = meetingLink;
                        if (locationInput) locationInput.value = location;
                        if (notesInput) notesInput.value = notes;
                        
                        // Apply mode fields
                        if (mode === 'onsite') {
                            if (onlineField) onlineField.classList.add('d-none');
                            if (onsiteField) onsiteField.classList.remove('d-none');
                        } else {
                            if (onsiteField) onsiteField.classList.add('d-none');
                            if (onlineField) onlineField.classList.remove('d-none');
                        }
                        
                        if (notesCount && notesInput) notesCount.textContent = String(notesInput.value.length);
                        editModal.show();
                    }
                }
            });
        });

    };

    document.addEventListener('DOMContentLoaded', initInterviewsPage);
    document.addEventListener('turbo:load', initInterviewsPage);
</script>
{% endblock %}
