{% extends 'base.html.twig' %}
{% block title %}My Skills{% endblock %}

{% block body %}
<div class="container-xl py-5">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h1 class="h2 mb-0">My Professional Skills</h1>
        </div>
        <div class="col-auto">
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modal-skill">
                <i class="ti ti-plus me-2"></i>Add New Skill
            </button>
        </div>
    </div>

    <div class="row g-4">
        {% for skill in skills %}
            <div class="col-md-4">
                <div class="card card-body border shadow-sm h-100">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="d-flex align-items-center">
                            <div class="rounded-circle bg-blue-lt text-blue p-2 me-3">
                                <i class="ti ti-star"></i>
                            </div>
                            <h4 class="mb-0">{{ skill.getSkillName() }}</h4>
                        </div>
                        
                        <!-- Action Buttons -->
                        <div class="d-flex gap-2">
                            <!-- Edit Button -->
                            <a href="{{ path('app_candidate_skill_edit', {id: skill.getId()}) }}" 
                               class="btn btn-sm btn-warning">
                                <i class="ti ti-edit"></i>
                            </a>
                            
                            <!-- Delete Button -->
                            <a href="{{ path('app_candidate_skill_delete', {id: skill.getId()}) }}" 
                               class="btn btn-sm btn-danger"
                               onclick="return confirm('Are you sure you want to delete this skill?')">
                                <i class="ti ti-trash"></i>
                            </a>
                        </div>
                    </div>
                    
                    <p class="text-muted mb-0">
                        Level: <strong>{{ skill.getLevel() }}</strong>
                    </p>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <p class="text-muted">You haven't added any skills yet.</p>
            </div>
        {% endfor %}
    </div>
</div>

{# ====================== ADD SKILL MODAL ====================== #}
<div class="modal fade" id="modal-skill" tabindex="-1">
    <div class="modal-dialog">
        <form method="POST" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Professional Skill</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Skill Name</label>
                    <input type="text" name="skill_name" class="form-control" placeholder="e.g. PHP, Project Management" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Proficiency Level</label>
                    <select name="level" class="form-select">
                        <option value="Beginner">Beginner</option>
                        <option value="Intermediate">Intermediate</option>
                        <option value="Advanced">Advanced</option>
                        <option value="Expert">Expert</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Skill</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}