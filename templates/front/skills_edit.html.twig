{% extends 'base.html.twig' %}

{% block title %}Edit Skill{% endblock %}

{% block body %}
<div class="container-xl py-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h4 class="mb-0">Edit Skill</h4>
                </div>
                <div class="card-body">
                    <form method="POST">
                        <div class="mb-3">
                            <label class="form-label">Skill Name</label>
                            <input type="text" 
                                   name="skill_name" 
                                   class="form-control" 
                                   value="{{ skill.getSkillName() }}" 
                                   required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Proficiency Level</label>
                            <select name="level" class="form-select">
                                <option value="Beginner" {{ skill.getLevel() == 'Beginner' ? 'selected' : '' }}>Beginner</option>
                                <option value="Intermediate" {{ skill.getLevel() == 'Intermediate' ? 'selected' : '' }}>Intermediate</option>
                                <option value="Advanced" {{ skill.getLevel() == 'Advanced' ? 'selected' : '' }}>Advanced</option>
                                <option value="Expert" {{ skill.getLevel() == 'Expert' ? 'selected' : '' }}>Expert</option>
                            </select>
                        </div>

                        <div class="d-flex gap-2">
                            <a href="{{ path('app_candidate_skills') }}" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">Update Skill</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}