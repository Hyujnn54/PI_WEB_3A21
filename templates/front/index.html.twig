{% extends 'base.html.twig' %}

{% block title %}TalentBridge | Home{% endblock %}

{% block body %}
    {% set modules = [
        { title: 'User Management', description: 'Organize candidate, recruiter, and admin profiles in one workspace.', icon: 'ti ti-users-group' },
        { title: 'Job Offers', description: 'Publish and supervise open positions with clear status tracking.', icon: 'ti ti-briefcase-2' },
        { title: 'Applications', description: 'Monitor applications from submission to final decision.', icon: 'ti ti-file-check' },
        { title: 'Interviews', description: 'Plan and review interview cycles with shared visibility.', icon: 'ti ti-message-2' },
        { title: 'Events', description: 'Coordinate recruitment events and engagement activities.', icon: 'ti ti-calendar-event' },
        { title: 'Reporting', description: 'Use dashboard snapshots to support hiring decisions.', icon: 'ti ti-chart-bar' }
    ] %}

    <section class="py-5">
        <div class="container-xl">
            <div class="row align-items-center g-4">
                <div class="col-lg-6">
                    <h1 class="display-6 fw-bold mb-3">Recruitment Platform Template Setup</h1>
                    <p class="lead mb-4">This home page is now switched to the template-handoff layout and kept as a UI-only showcase.</p>
                    <div class="d-flex gap-2 flex-wrap">
                        <a href="{{ path('back_dashboard') }}" class="btn btn-primary">Go to Dashboard</a>
                        <a href="{{ path('front_job_offers', {role: 'candidate'}) }}" class="btn btn-outline-primary">Explore Job Offers</a>
                    </div>
                </div>
                <div class="col-lg-6 text-center">
                    <img src="{{ asset('team_uploads/logo.png') }}" class="img-fluid" alt="TalentBridge illustration" style="max-width: 260px;">
                </div>
            </div>
        </div>
    </section>

    <section class="py-5">
        <div class="container-xl">
            <div class="row mb-4">
                <div class="col-12 text-center">
                    <h2 class="h3 mb-0">Core Modules</h2>
                </div>
            </div>
            <div class="row g-4">
                {% for module in modules %}
                    <div class="col-md-6 col-lg-4">
                        <div class="card card-body border h-100">
                            <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-blue-lt text-blue mb-3" style="width: 44px; height: 44px;">
                                <i class="{{ module.icon }}"></i>
                            </div>
                            <h5>{{ module.title }}</h5>
                            <p class="mb-0">{{ module.description }}</p>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}
