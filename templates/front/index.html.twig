{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Front Office{% endblock %}

{% block body %}
<section class="hero-wrap py-5 py-lg-6">
    <div class="container py-4">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <p class="text-uppercase text-primary fw-semibold small mb-2">Talent Bridge Platform</p>
                <h1 class="display-5 fw-bold mb-3">Find the right people, faster.</h1>
                <p class="lead text-secondary mb-4">A modern recruitment hub connecting candidates, recruiters, and admins through one streamlined workflow.</p>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-primary btn-lg px-4" href="{{ path('back_dashboard') }}">Open Back Office</a>
                    <a class="btn btn-outline-primary btn-lg px-4" href="#jobs">Explore Jobs</a>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="metric-grid">
                    <div class="metric-card">
                        <div class="metric-label">Candidates</div>
                        <div class="metric-value">{{ stats.candidates }}</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Recruiters</div>
                        <div class="metric-value">{{ stats.recruiters }}</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Job Offers</div>
                        <div class="metric-value">{{ stats.jobOffers }}</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Applications</div>
                        <div class="metric-value">{{ stats.applications }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="jobs" class="pb-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h3 m-0">Latest Job Offers</h2>
            <span class="badge text-bg-primary">{{ stats.jobOffers }} total</span>
        </div>
        <div class="row g-3">
            {% for offer in latestOffers %}
                <div class="col-md-6 col-lg-4">
                    <article class="job-card h-100">
                        <h3 class="h5 mb-2">{{ offer.title }}</h3>
                        <p class="small text-secondary mb-2">{{ offer.location }} • {{ offer.contract_type }}</p>
                        <p class="small mb-3">{{ offer.description|slice(0, 120) ~ '...' }}</p>
                        <div class="d-flex justify-content-between small text-muted">
                            <span>Status: {{ offer.status }}</span>
                            <span>#{{ offer.id }}</span>
                        </div>
                    </article>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="alert alert-info mb-0">No job offers found in the database yet.</div>
                </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}
