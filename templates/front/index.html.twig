{% extends 'base.html.twig' %}

{% block title %}TalentBridge | Home{% endblock %}

{% block body %}
    {% set modules = [
        { title: 'User Management', description: 'Organize candidate, recruiter, and admin profiles in one workspace.', icon: 'ti ti-users-group' },
        { title: 'Job Offers', description: 'Publish and supervise open positions with clear status tracking.', icon: 'ti ti-briefcase-2' },
        { title: 'Applications', description: 'Monitor applications from submission to final decision.', icon: 'ti ti-file-check' },
        { title: 'Interviews', description: 'Plan and review interview cycles with shared visibility.', icon: 'ti ti-message-2' },
        { title: 'Events', description: 'Coordinate recruitment events and engagement activities.', icon: 'ti ti-calendar-event' },
        { title: 'Reporting', description: 'Use dashboard snapshots to support hiring decisions.', icon: 'ti ti-chart-bar' }
    ] %}

    <section class="py-5">
        <div class="container-xl">
            <div class="tb-front-home-hero">
            <div class="row align-items-center g-4">
                <div class="col-lg-6">
                    <div class="badge rounded-pill text-bg-light mb-3">Talent Bridge Portal</div>
                    <h1 class="display-5 fw-bold mb-3">A Hiring Workspace That Feels Alive</h1>
                    <p class="lead mb-4 text-secondary">Navigate offers, interviews, applications, and events from one unified front portal with stronger visual hierarchy and faster actions.</p>
                    <div class="d-flex gap-2 flex-wrap">
                        <a href="{{ path('front_job_offers', {role: 'candidate'}) }}" class="btn btn-primary">Start as Candidate</a>
                        <a href="{{ path('front_job_offers', {role: 'recruiter'}) }}" class="btn btn-outline-primary">Switch to Recruiter</a>
                        <a href="{{ path('front_job_offers', {role: 'candidate'}) }}" class="btn btn-outline-primary">Explore Job Offers</a>
                        <a href="{{ path('back_dashboard') }}" class="btn btn-outline-secondary">Admin Dashboard</a>
                    </div>
                </div>
                <div class="col-lg-6 text-center">
                    <div class="tb-front-home-logo-ring">
                        <img src="{{ asset('assets/team_uploads/logo.png') }}" class="img-fluid" alt="TalentBridge illustration" style="max-width: 58%;">
                    </div>
                </div>
            </div>
            </div>
        </div>
    </section>

    <section class="pt-2 pb-5">
        <div class="container-xl">
            <div class="row mb-4">
                <div class="col-12 text-center">
                    <h2 class="h3 mb-2">Core Modules</h2>
                    <p class="text-secondary mb-0">Each module is optimized for role-based workflows without changing existing business logic.</p>
                </div>
            </div>
            <div class="row g-4">
                {% for module in modules %}
                    <div class="col-md-6 col-lg-4">
                        <div class="card card-body tb-front-home-card">
                            <div class="tb-front-home-icon mb-3">
                                <i class="{{ module.icon }}"></i>
                            </div>
                            <h5>{{ module.title }}</h5>
                            <p class="mb-0">{{ module.description }}</p>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}
