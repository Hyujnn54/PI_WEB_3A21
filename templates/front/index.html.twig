{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Front Office{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-header d-print-none tb-hero">
        <div class="container-xl">
            <div class="row g-3 align-items-center">
                <div class="col-lg-8">
                    <h2 class="page-title">Smart Hiring Workspace</h2>
                    <p class="tb-hero-subtitle">Talent Bridge connects candidates, recruiters, and admins with one clean hiring flow from offer to interview.</p>
                    <div class="mt-3 d-flex flex-wrap gap-2">
                        <a class="btn btn-primary" href="#jobs">Browse Opportunities</a>
                        <a class="btn btn-outline-primary" href="{{ path('back_dashboard') }}">Go to Back Office</a>
                    </div>
                </div>
                <div class="col-lg-4 ms-lg-auto">
                    <div class="card tb-glass-card">
                        <div class="card-body">
                            <div class="h3 mb-1">{{ stats.jobOffers }}</div>
                            <div class="text-secondary">Active offers in platform</div>
                            <div class="progress progress-sm mt-3">
                                <div class="progress-bar bg-blue" style="width: 78%" role="progressbar" aria-valuenow="78" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            <div class="row row-deck row-cards mb-3">
                <div class="col-sm-6 col-lg-3">
                    <div class="card card-sm"><div class="card-body"><div class="h2 m-0">{{ stats.candidates }}</div><div class="text-secondary">Candidates</div></div></div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="card card-sm"><div class="card-body"><div class="h2 m-0">{{ stats.recruiters }}</div><div class="text-secondary">Recruiters</div></div></div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="card card-sm"><div class="card-body"><div class="h2 m-0">{{ stats.applications }}</div><div class="text-secondary">Applications</div></div></div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="card card-sm"><div class="card-body"><div class="h2 m-0">{{ stats.interviews }}</div><div class="text-secondary">Interviews</div></div></div>
                </div>
            </div>

            <div class="row row-cards mb-3">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title mb-0">Team Navigation</h3>
                        </div>
                        <div class="card-body d-flex flex-wrap gap-2">
                            <a class="btn btn-outline-primary" href="{{ path('management_users') }}">Users</a>
                            <a class="btn btn-outline-primary" href="{{ path('management_job_offers') }}">Job Offers</a>
                            <a class="btn btn-outline-primary" href="{{ path('management_job_applications') }}">Job Applications</a>
                            <a class="btn btn-outline-primary" href="{{ path('management_events') }}">Events</a>
                            <a class="btn btn-outline-primary" href="{{ path('management_interviews') }}">Interviews</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row row-cards" id="jobs">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h3 class="card-title mb-0">Latest Job Offers</h3>
                            <span class="badge bg-blue-lt">{{ stats.jobOffers }} total</span>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                {% for offer in latestOffers %}
                                    <div class="col-md-6 col-xl-4">
                                        <article class="tb-offer-card h-100">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h3 class="h5 mb-0">{{ offer.title }}</h3>
                                                <span class="badge bg-azure-lt">{{ offer.status }}</span>
                                            </div>
                                            <p class="small text-secondary mb-2">{{ offer.location }} | {{ offer.contract_type }}</p>
                                            <p class="small mb-3">{{ offer.description|slice(0, 130) ~ '...' }}</p>
                                            <div class="d-flex justify-content-between small text-muted">
                                                <span>Offer #{{ offer.id }}</span>
                                                <span>Quality: {{ offer.quality_score }}</span>
                                            </div>
                                        </article>
                                    </div>
                                {% else %}
                                    <div class="col-12">
                                        <div class="alert alert-info mb-0">No job offers found in the database yet.</div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
