{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Verify Recovery Code{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-body auth-body">
        <div class="container container-tight py-4 py-md-5">
            <div class="tb-auth-shell mx-auto">
                <div class="text-center mb-4">
                    <h1 class="h2 mb-1">Verify Code & Reset</h1>
                    <div class="text-secondary">Enter your email, code, and your new password.</div>
                </div>

                <div class="card card-md auth-card tb-auth-card">
                    <div class="card-body p-4 p-md-4">
                        {% if error is defined and error %}
                            <div class="alert alert-danger tb-auth-alert" role="alert">
                                <i class="ti ti-alert-circle me-2"></i>{{ error }}
                            </div>
                        {% endif %}
                        {% for message in app.flashes('error') %}
                            <div class="alert alert-danger tb-auth-alert" role="alert">
                                <i class="ti ti-alert-circle me-2"></i>{{ message }}
                            </div>
                        {% endfor %}
                        {% for message in app.flashes('success') %}
                            <div class="alert alert-success tb-auth-alert" role="alert">
                                <i class="ti ti-circle-check me-2"></i>{{ message }}
                            </div>
                        {% endfor %}

                        <form method="post" action="{{ path('app_forgot_password_verify') }}" novalidate>
                            <div class="mb-3">
                                <label class="form-label">Email Address</label>
                                <div class="input-icon">
                                    <span class="input-icon-addon"><i class="ti ti-mail"></i></span>
                                    <input type="email" name="email" class="form-control tb-auth-input" value="{{ email|default('') }}" placeholder="your@email.com" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Recovery Code</label>
                                <div class="input-icon">
                                    <span class="input-icon-addon"><i class="ti ti-key"></i></span>
                                    <input type="text" name="code" class="form-control tb-auth-input" placeholder="6 digits" maxlength="6" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">New Password</label>
                                <div class="input-icon">
                                    <span class="input-icon-addon"><i class="ti ti-lock"></i></span>
                                    <input type="password" name="new_password" class="form-control tb-auth-input" placeholder="At least 8 chars, letters and numbers" required>
                                </div>
                            </div>

                            <div class="form-footer pt-2">
                                <button type="submit" class="btn btn-primary w-100 tb-auth-btn">Change Password</button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="text-center text-secondary mt-3">
                    Back to <a href="{{ path('app_login') }}" class="tb-auth-link">Login</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
