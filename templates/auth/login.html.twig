{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Login{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-body auth-body">
        <div class="container container-tight py-4">
            <div class="text-center mb-4">
                <h1 class="h2">Talent Bridge</h1>
                <div class="text-secondary">Sign in to continue to your workspace</div>
            </div>
            <div class="card card-md auth-card">
                <div class="card-body">
                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger">{{ message }}</div>
                    {% endfor %}

                    <form method="post" action="{{ path('app_login') }}">
                        <div class="mb-3">
                            <label class="form-label">Email Address</label>
                            {# The 'name' must be 'email' for the Controller to find it #}
                            <input type="email" name="email" class="form-control" placeholder="your@email.com" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            {# The 'name' must be 'password' for the Controller to find it #}
                            <input type="password" name="password" class="form-control" placeholder="Your password" required>
                        </div>
                        <div class="form-footer">
                            <button type="submit" class="btn btn-primary w-100">Sign In</button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="text-center text-secondary mt-3">
                No account yet? <a href="{{ path('app_register') }}">Register</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}