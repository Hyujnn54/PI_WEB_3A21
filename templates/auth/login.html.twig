{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Login{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-body auth-body">
        <div class="container container-tight py-4 py-md-5">
            <div class="tb-auth-shell mx-auto">
                <div class="text-center mb-4">
                    <img src="{{ asset('assets/team_upload/logo.png') }}" alt="Talent Bridge" class="tb-auth-logo mb-3" onerror="if(!this.dataset.fallback){this.dataset.fallback='1';this.src='{{ asset('assets/team_uploads/logo.png') }}';}else{this.style.display='none';}">
                    <h1 class="h2 mb-1">Welcome Back</h1>
                    <div class="text-secondary">Sign in to continue managing your HR workspace.</div>
                </div>

                <div class="card card-md auth-card tb-auth-card">
                    <div class="card-body p-4 p-md-4">
                        {% if error %}
                            <div class="alert alert-danger tb-auth-alert" role="alert">
                                <i class="ti ti-alert-circle me-2"></i>{{ error.messageKey|trans(error.messageData, 'security') }}
                            </div>
                        {% endif %}

                        {% for message in app.flashes('error') %}
                            <div class="alert alert-danger tb-auth-alert" role="alert">
                                <i class="ti ti-alert-circle me-2"></i>{{ message }}
                            </div>
                        {% endfor %}

                        <form method="post" action="{{ path('app_login') }}" novalidate>
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                            <div class="mb-3">
                                <label class="form-label">Email Address</label>
                                <div class="input-icon">
                                    <span class="input-icon-addon"><i class="ti ti-mail"></i></span>
                                    <input type="email" name="email" class="form-control tb-auth-input" placeholder="your@email.com" value="{{ last_username|default('') }}" autocomplete="email" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <div class="input-icon">
                                    <span class="input-icon-addon"><i class="ti ti-lock"></i></span>
                                    <input type="password" name="password" class="form-control tb-auth-input" placeholder="Your password" autocomplete="current-password" required>
                                </div>
                                <div class="text-end mt-2">
                                    <a href="{{ path('app_forgot_password') }}" class="tb-auth-link">Forgot your password? Recover it</a>
                                </div>
                            </div>

                            <div class="form-footer pt-2">
                                <button type="submit" class="btn btn-primary w-100 tb-auth-btn">Sign In</button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="text-center text-secondary mt-3">
                    No account yet? <a href="{{ path('app_register') }}" class="tb-auth-link">Register</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

