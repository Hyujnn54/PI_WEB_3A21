        function validateForm() {
            const errors = {};
            const title = document.getElementById('title').value.trim();
            const description = document.getElementById('description').value.trim();
            const eventType = document.getElementById('event_type').value.trim();
            const location = document.getElementById('location').value.trim();
            const eventDate = document.getElementById('event_date').value;
            const capacity = document.getElementById('capacity').value;
            const meetLink = document.getElementById('meet_link').value.trim();

            // Clear previous errors
            document.querySelectorAll('[id$="Error"]').forEach(el => el.classList.add('d-none'));

            // Validate title
            if (!title) {
                errors.title = 'Event title is required.';
            } else if (title.length < 3) {
                errors.title = 'Event title must be at least 3 characters.';
            } else if (title.length > 255) {
                errors.title = 'Event title cannot exceed 255 characters.';
            }

            // Validate description
            if (!description) {
                errors.description = 'Description is required.';
            } else if (description.length < 10) {
                errors.description = 'Description must be at least 10 characters.';
            }

            // Validate event type
            if (!eventType) {
                errors.event_type = 'Event type is required.';
            }

            // Validate location
            if (!location) {
                errors.location = 'Location is required.';
            } else if (location.length < 2) {
                errors.location = 'Location must be at least 2 characters.';
            }

            // Validate event date
            if (!eventDate) {
                errors.event_date = 'Event date is required.';
            } else {
                const date = new Date(eventDate);
                const now = new Date();
                if (date <= now) {
                    errors.event_date = 'Event date must be in the future.';
                }
            }

            // Validate capacity
            if (!capacity) {
                errors.capacity = 'Capacity is required.';
            } else {
                const cap = parseInt(capacity);
                if (cap < 1) {
                    errors.capacity = 'Capacity must be at least 1.';
                } else if (cap > 1000) {
                    errors.capacity = 'Capacity cannot exceed 1000.';
                }
            }

            // Validate meet link
            if (meetLink && !isValidUrl(meetLink)) {
                errors.meet_link = 'Please enter a valid URL.';
            }

            // Display errors
            if (Object.keys(errors).length > 0) {
                Object.keys(errors).forEach(field => {
                    const errorEl = document.getElementById(field + 'Error');
                    if (errorEl) {
                        errorEl.textContent = errors[field];
                        errorEl.classList.remove('d-none');
                    }
                });
                return false;
            }
            return true;
        }

        function isValidUrl(string) {
            try {
                new URL(string);
                return true;
            } catch (_) {
                return false;
            }
        }

        function renderMapSearchResults(results) {
            if (!mapSearchResults) {
                return;
            }

            if (!Array.isArray(results) || results.length === 0) {
                mapSearchResults.innerHTML = '';
                mapSearchResults.classList.add('d-none');
                return;
            }

            mapSearchResults.innerHTML = '';
            mapSearchResults.classList.remove('d-none');

            results.forEach(function (result) {
                const button = document.createElement('button');
                button.type = 'button';
                button.className = 'tb-map-result-btn';
                button.textContent = result.display_name || 'Selected location';
                button.addEventListener('click', function () {
                    const lat = parseFloat(result.lat);
                    const lng = parseFloat(result.lon);
                    if (Number.isNaN(lat) || Number.isNaN(lng) || !eventMap) {
                        return;
                    }

                    setPickedLocation(lat, lng, result.display_name || 'Selected location', true);
                    mapSearchResults.innerHTML = '';
                    mapSearchResults.classList.add('d-none');
                });

                mapSearchResults.appendChild(button);
            });
        }

        function setPickedLocation(lat, lng, label, focusMap) {
            if (!eventMap || Number.isNaN(lat) || Number.isNaN(lng)) {
                return;
            }

            if (!eventLocationMarker) {
                eventLocationMarker = L.marker([lat, lng]).addTo(eventMap);
            } else {
                eventLocationMarker.setLatLng([lat, lng]);
            }

            eventLocationMarker.bindPopup(label || 'Selected destination').openPopup();

            if (locationInput && label) {
                locationInput.value = label;
            }
            if (locationLatInput) {
                locationLatInput.value = String(lat);
            }
            if (locationLngInput) {
                locationLngInput.value = String(lng);
            }

            if (focusMap) {
                eventMap.setView([lat, lng], 14);
            }
        }

        async function reverseGeocode(lat, lng) {
            const url = `https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${encodeURIComponent(lat)}&lon=${encodeURIComponent(lng)}`;

            try {
                const response = await fetch(url, {
                    headers: {
                        'Accept': 'application/json'
                    }
                });

                if (!response.ok) {
                    throw new Error('Reverse geocoding request failed');
                }

                const data = await response.json();
                return data && data.display_name ? data.display_name : `${lat.toFixed(6)}, ${lng.toFixed(6)}`;
            } catch (error) {
                return `${lat.toFixed(6)}, ${lng.toFixed(6)}`;
            }
        }

        async function searchDestination() {
            if (!mapSearchInput) {
                return;
            }

            const query = mapSearchInput.value.trim();
            if (!query) {
                renderMapSearchResults([]);
                return;
            }

            const url = `https://nominatim.openstreetmap.org/search?format=jsonv2&limit=5&q=${encodeURIComponent(query)}`;
            try {
                const response = await fetch(url, {
                    headers: {
                        'Accept': 'application/json'
                    }
                });

                if (!response.ok) {
                    throw new Error('Search request failed');
                }

                const results = await response.json();
                renderMapSearchResults(results);
            } catch (error) {
                renderMapSearchResults([]);
            }
        }

        function initializeLocationMap() {
            const mapContainer = document.getElementById('eventLocationMap');
            if (!mapContainer || typeof L === 'undefined') {
                return;
            }

            eventMap = L.map(mapContainer).setView([36.8065, 10.1815], 6);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(eventMap);

            eventMap.on('click', async function (ev) {
                const lat = ev.latlng.lat;
                const lng = ev.latlng.lng;
                const label = await reverseGeocode(lat, lng);
                setPickedLocation(lat, lng, label, false);
            });

            if (mapSearchBtn) {
                mapSearchBtn.addEventListener('click', searchDestination);
            }

            if (mapSearchInput) {
                mapSearchInput.addEventListener('keydown', function (event) {
                    if (event.key === 'Enter') {
                        event.preventDefault();
                        searchDestination();
                    }
                });
            }

            const rawLat = locationLatInput ? parseFloat(locationLatInput.value) : NaN;
            const rawLng = locationLngInput ? parseFloat(locationLngInput.value) : NaN;
            if (!Number.isNaN(rawLat) && !Number.isNaN(rawLng)) {
                setPickedLocation(rawLat, rawLng, (locationInput && locationInput.value) ? locationInput.value : 'Selected destination', true);
            }

            if ((Number.isNaN(rawLat) || Number.isNaN(rawLng)) && locationInput && locationInput.value.trim() !== '') {
                mapSearchInput.value = locationInput.value.trim();
                searchDestination();
            }

            setTimeout(function () {
                if (eventMap) {
                    eventMap.invalidateSize();
                }
            }, 150);
        }

