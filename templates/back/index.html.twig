{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Back Office{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-header d-print-none">
        <div class="container-xl">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <h2 class="page-title">Back Office Dashboard</h2>
                    <div class="text-secondary">Control panel for admin, recruiter, candidate, events and interview pipelines.</div>
                </div>
                <div class="col-auto ms-auto d-print-none">
                    <a href="{{ path('front_home') }}" class="btn btn-outline-primary">Open Front Office</a>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            <div class="row row-cards">
                <div class="col-lg-3 col-sm-6">
                    <div class="card card-sm"><div class="card-body"><div class="text-secondary">Admins</div><div class="display-6 fw-bold">{{ stats.admins }}</div></div></div>
                </div>
                <div class="col-lg-3 col-sm-6">
                    <div class="card card-sm"><div class="card-body"><div class="text-secondary">Candidates</div><div class="display-6 fw-bold">{{ stats.candidates }}</div></div></div>
                </div>
                <div class="col-lg-3 col-sm-6">
                    <div class="card card-sm"><div class="card-body"><div class="text-secondary">Recruiters</div><div class="display-6 fw-bold">{{ stats.recruiters }}</div></div></div>
                </div>
                <div class="col-lg-3 col-sm-6">
                    <div class="card card-sm"><div class="card-body"><div class="text-secondary">Interviews</div><div class="display-6 fw-bold">{{ stats.interviews }}</div></div></div>
                </div>

                <div class="col-xl-4">
                    <div class="card h-100">
                        <div class="card-header">
                            <h3 class="card-title">Navigation</h3>
                        </div>
                        <div class="list-group list-group-flush tb-admin-list">
                            <a class="list-group-item list-group-item-action" href="{{ path('management_users') }}">Users & Roles</a>
                            <a class="list-group-item list-group-item-action" href="{{ path('management_job_offers') }}">Job Offers</a>
                            <a class="list-group-item list-group-item-action" href="{{ path('management_job_applications') }}">Applications</a>
                            <a class="list-group-item list-group-item-action" href="{{ path('management_events') }}">Events</a>
                            <a class="list-group-item list-group-item-action" href="{{ path('management_interviews') }}">Interviews</a>
                        </div>
                    </div>
                </div>

                <div class="col-xl-8">
                    <div class="card h-100">
                        <div class="card-header">
                            <h3 class="card-title">Platform Overview</h3>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-vcenter card-table">
                                <thead>
                                    <tr>
                                        <th>Module</th>
                                        <th class="text-end">Records</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td>Job Offers</td><td class="text-end">{{ stats.jobOffers }}</td><td><span class="badge bg-blue-lt">Active</span></td></tr>
                                    <tr><td>Applications</td><td class="text-end">{{ stats.applications }}</td><td><span class="badge bg-azure-lt">Tracking</span></td></tr>
                                    <tr><td>Events</td><td class="text-end">{{ stats.events }}</td><td><span class="badge bg-indigo-lt">Planning</span></td></tr>
                                    <tr><td>Candidates</td><td class="text-end">{{ stats.candidates }}</td><td><span class="badge bg-cyan-lt">Live</span></td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
