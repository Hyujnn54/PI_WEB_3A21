{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Back Office{% endblock %}

{% block body %}
<section class="py-4">
    <div class="container-fluid px-4">
        <div class="row g-4">
            <div class="col-12 col-xl-3">
                <aside class="panel h-100">
                    <h2 class="h5 mb-3">Admin Navigation</h2>
                    <div class="list-group admin-links">
                        <a class="list-group-item list-group-item-action" href="#">Users & Roles</a>
                        <a class="list-group-item list-group-item-action" href="#">Job Offers</a>
                        <a class="list-group-item list-group-item-action" href="#">Applications</a>
                        <a class="list-group-item list-group-item-action" href="#">Events</a>
                        <a class="list-group-item list-group-item-action" href="#">Interviews</a>
                    </div>
                </aside>
            </div>
            <div class="col-12 col-xl-9">
                <div class="panel mb-4">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            <h1 class="h3 mb-1">Back Office Dashboard</h1>
                            <p class="text-secondary m-0">Operational overview of Talent Bridge recruitment activity.</p>
                        </div>
                        <a href="{{ path('front_home') }}" class="btn btn-outline-primary">Front Office</a>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-sm-6 col-lg-3"><div class="panel stat"><div class="small text-muted">Admins</div><div class="h4 m-0">{{ stats.admins }}</div></div></div>
                    <div class="col-sm-6 col-lg-3"><div class="panel stat"><div class="small text-muted">Candidates</div><div class="h4 m-0">{{ stats.candidates }}</div></div></div>
                    <div class="col-sm-6 col-lg-3"><div class="panel stat"><div class="small text-muted">Recruiters</div><div class="h4 m-0">{{ stats.recruiters }}</div></div></div>
                    <div class="col-sm-6 col-lg-3"><div class="panel stat"><div class="small text-muted">Interviews</div><div class="h4 m-0">{{ stats.interviews }}</div></div></div>
                </div>

                <div class="row g-3">
                    <div class="col-md-4"><div class="panel h-100"><div class="small text-muted">Job Offers</div><div class="display-6">{{ stats.jobOffers }}</div></div></div>
                    <div class="col-md-4"><div class="panel h-100"><div class="small text-muted">Applications</div><div class="display-6">{{ stats.applications }}</div></div></div>
                    <div class="col-md-4"><div class="panel h-100"><div class="small text-muted">Events</div><div class="display-6">{{ stats.events }}</div></div></div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
