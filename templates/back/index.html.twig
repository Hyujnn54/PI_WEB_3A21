{% extends 'base.html.twig' %}

{% block title %}Talent Bridge | Back Office{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-header d-print-none tb-admin-hero">
        <div class="container-xl">
            <div class="row g-2 align-items-center">
                <div class="col">
                    <h2 class="page-title"><i class="ti ti-layout-dashboard me-1"></i>Admin Dashboard</h2>
                    <div class="text-secondary">Control panel for admin, recruiter, candidate, events and interview pipelines.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            <div class="row row-cards">
                <div class="col-lg-3 col-sm-6">
                    <div class="card card-sm"><div class="card-body"><div class="text-secondary">Admins</div><div class="display-6 fw-bold">{{ stats.admins }}</div></div></div>
                </div>
                <div class="col-lg-3 col-sm-6">
                    <div class="card card-sm"><div class="card-body"><div class="text-secondary">Candidates</div><div class="display-6 fw-bold">{{ stats.candidates }}</div></div></div>
                </div>
                <div class="col-lg-3 col-sm-6">
                    <div class="card card-sm"><div class="card-body"><div class="text-secondary">Recruiters</div><div class="display-6 fw-bold">{{ stats.recruiters }}</div></div></div>
                </div>
                <div class="col-lg-3 col-sm-6">
                    <div class="card card-sm"><div class="card-body"><div class="text-secondary">Interviews</div><div class="display-6 fw-bold">{{ stats.interviews }}</div></div></div>
                </div>

                <div class="col-xl-4">
                    <div class="card h-100">
                        <div class="card-header">
                            <h3 class="card-title">Navigation</h3>
                        </div>
                        <div class="list-group list-group-flush tb-admin-list">
                            <a class="list-group-item list-group-item-action" href="{{ path('management_users') }}">Users & Roles</a>
                            <a class="list-group-item list-group-item-action" href="{{ path('management_job_offers') }}">Job Offers</a>
                            <a class="list-group-item list-group-item-action" href="{{ path('management_job_applications') }}">Applications</a>
                            <a class="list-group-item list-group-item-action" href="{{ path('management_events') }}">Events</a>
                            <a class="list-group-item list-group-item-action" href="{{ path('management_interviews') }}">Interviews</a>
                        </div>
                    </div>
                </div>

                <div class="col-xl-8">
                    <div class="card h-100">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-chart-bar me-1"></i>Statistics Section</h3>
                        </div>
                        <div class="card-body">
                            <div class="progress mb-3"><div class="progress-bar bg-blue" style="width: 71%"></div></div>
                            <div class="progress mb-3"><div class="progress-bar bg-indigo" style="width: 52%"></div></div>
                            <div class="progress"><div class="progress-bar bg-cyan" style="width: 84%"></div></div>
                            <p class="small text-secondary mt-3 mb-0">Applications conversion, event engagement, and interview quality trends at a glance.</p>
                        </div>
                    </div>
                </div>

                <div class="col-xl-6">
                    <div class="card h-100">
                        <div class="card-header"><h3 class="card-title"><i class="ti ti-calendar-event me-1"></i>Calendar Section</h3></div>
                        <div class="card-body">
                            <div class="tb-mini-calendar">
                                <div>Mon</div><div>Tue</div><div>Wed</div><div>Thu</div><div>Fri</div><div>Sat</div><div>Sun</div>
                                <div>14</div><div class="is-active">15</div><div>16</div><div>17</div><div class="is-accent">18</div><div>19</div><div>20</div>
                            </div>
                            <p class="small text-secondary mt-3 mb-0">15: Candidate event campaign, 18: interview calibration board.</p>
                        </div>
                    </div>
                </div>

                <div class="col-xl-6">
                    <div class="card h-100">
                        <div class="card-header"><h3 class="card-title"><i class="ti ti-users me-1"></i>All Users Overview</h3></div>
                        <div class="table-responsive">
                            <table class="table table-vcenter card-table">
                                <thead><tr><th>ID</th><th>Name</th><th>Email</th><th>Status</th></tr></thead>
                                <tbody>
                                {% for user in usersPreview %}
                                    <tr>
                                        <td>#{{ user.id }}</td>
                                        <td>{{ user.first_name }} {{ user.last_name }}</td>
                                        <td>{{ user.email }}</td>
                                        <td><span class="badge {{ user.is_active ? 'bg-green-lt' : 'bg-red-lt' }}">{{ user.is_active ? 'Active' : 'Inactive' }}</span></td>
                                    </tr>
                                {% else %}
                                    <tr><td colspan="4" class="text-secondary">No users found in table preview.</td></tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
