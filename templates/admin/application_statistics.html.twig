{% extends 'admin/base_admin.html.twig' %}

{% block title %}Talent Bridge | Applications Statistics{% endblock %}

{% block admin_content %}
    {% set total = global.total %}
    {% set submittedPct = total > 0 ? (global.submitted * 100 / total) : 0 %}
    {% set shortlistedPct = total > 0 ? (global.shortlisted * 100 / total) : 0 %}
    {% set rejectedPct = total > 0 ? (global.rejected * 100 / total) : 0 %}
    {% set interviewPct = total > 0 ? (global.interview * 100 / total) : 0 %}
    {% set hiredPct = total > 0 ? (global.hired * 100 / total) : 0 %}

    <style>
        .tb-stats-hero {
            background: linear-gradient(135deg, #15335b 0%, #0d5bd7 100%);
            border-radius: 14px;
            color: #fff;
            box-shadow: 0 10px 30px rgba(13, 91, 215, 0.18);
        }

        .tb-stat-card {
            border: 1px solid #e9eef4;
            border-radius: 12px;
            box-shadow: 0 3px 12px rgba(15, 23, 42, 0.04);
        }

        .tb-stat-icon {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.05rem;
        }
    </style>

    <div class="mb-4 tb-stats-hero p-4 p-lg-5 d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h1 class="h3 mb-1 text-white">Applications Statistics</h1>
            <p class="mb-0 text-white-50">Global and per-offer application performance overview.</p>
        </div>
        <a href="{{ path('management_job_applications_statistics') }}" class="btn btn-light btn-sm">
            <i class="ti ti-refresh me-1"></i>Refresh
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4 col-xl-2">
            <div class="card tb-stat-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="text-muted small">Total</div>
                        <span class="tb-stat-icon bg-primary-lt text-primary"><i class="ti ti-stack-2"></i></span>
                    </div>
                    <div class="h4 mb-0 text-primary">{{ global.total }}</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2">
            <div class="card tb-stat-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="text-muted small">Submitted</div>
                        <span class="tb-stat-icon bg-secondary-lt text-secondary"><i class="ti ti-send"></i></span>
                    </div>
                    <div class="h4 mb-0">{{ global.submitted }}</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2">
            <div class="card tb-stat-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="text-muted small">Shortlisted</div>
                        <span class="tb-stat-icon bg-orange-lt text-orange"><i class="ti ti-star"></i></span>
                    </div>
                    <div class="h4 mb-0 text-orange">{{ global.shortlisted }}</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2">
            <div class="card tb-stat-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="text-muted small">Rejected</div>
                        <span class="tb-stat-icon bg-red-lt text-danger"><i class="ti ti-x"></i></span>
                    </div>
                    <div class="h4 mb-0 text-danger">{{ global.rejected }}</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2">
            <div class="card tb-stat-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="text-muted small">Interview</div>
                        <span class="tb-stat-icon bg-blue-lt text-blue"><i class="ti ti-message-2"></i></span>
                    </div>
                    <div class="h4 mb-0 text-blue">{{ global.interview }}</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2">
            <div class="card tb-stat-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="text-muted small">Hired</div>
                        <span class="tb-stat-icon bg-green-lt text-green"><i class="ti ti-circle-check"></i></span>
                    </div>
                    <div class="h4 mb-0 text-green">{{ global.hired }}</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-xl-6">
            <div class="card tb-stat-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h2 class="h6 mb-0">Global Acceptance Rate</h2>
                        <span class="fw-semibold text-success">{{ global.acceptance_rate }}%</span>
                    </div>
                    <div class="progress" role="progressbar" aria-label="Global acceptance rate" aria-valuenow="{{ global.acceptance_rate }}" aria-valuemin="0" aria-valuemax="100" style="height: 10px;">
                        <div class="progress-bar bg-success js-stat-progress" data-rate="{{ global.acceptance_rate }}"></div>
                    </div>
                    <small class="text-muted">Calculated as (Shortlisted + Hired) / Total applications.</small>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-6">
            <div class="card tb-stat-card h-100">
                <div class="card-body">
                    <h2 class="h6 mb-3">Status Distribution</h2>
                    <div id="applicationStatusChart" style="min-height: 280px;"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="card tb-stat-card">
        <div class="card-body pb-0">
            <h2 class="h6 mb-3">Per-Offer Statistics</h2>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Offer</th>
                        <th>Total</th>
                        <th>Submitted</th>
                        <th>Shortlisted</th>
                        <th>Rejected</th>
                        <th>Interview</th>
                        <th>Hired</th>
                        <th>Acceptance</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in offerRows %}
                        <tr>
                            <td>{{ row.offer_title }}</td>
                            <td>{{ row.total }}</td>
                            <td>{{ row.submitted }}</td>
                            <td>{{ row.shortlisted }}</td>
                            <td>{{ row.rejected }}</td>
                            <td>{{ row.interview }}</td>
                            <td>{{ row.hired }}</td>
                            <td style="min-width: 180px;">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span>{{ row.acceptance_rate }}%</span>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar bg-success js-stat-progress" data-rate="{{ row.acceptance_rate }}"></div>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">No offer statistics available.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <script>
        (function () {
            const initKey = '__tbAdminApplicationStatsInit';

            const initApplicationStats = function (retryCount) {
                const chartEl = document.getElementById('applicationStatusChart');
                if (!chartEl) {
                    return;
                }

                document.querySelectorAll('.js-stat-progress').forEach(function (bar) {
                    const rate = Number(bar.getAttribute('data-rate') || 0);
                    bar.style.width = Math.max(0, Math.min(100, rate)) + '%';
                });

                if (typeof ApexCharts === 'undefined') {
                    if ((retryCount || 0) < 15) {
                        window.setTimeout(function () {
                            initApplicationStats((retryCount || 0) + 1);
                        }, 120);
                    }
                    return;
                }

                if (chartEl._tbApexInstance) {
                    chartEl._tbApexInstance.destroy();
                }
                chartEl.innerHTML = '';

                var statusOptions = {
                    series: [{{ global.submitted }}, {{ global.shortlisted }}, {{ global.rejected }}, {{ global.interview }}, {{ global.hired }}],
                    chart: { type: 'donut', height: 280 },
                    labels: ['Submitted', 'Shortlisted', 'Rejected', 'Interview', 'Hired'],
                    colors: ['#6c757d', '#f39c12', '#e74c3c', '#9b59b6', '#2ecc71'],
                    legend: { position: 'bottom' },
                    plotOptions: {
                        pie: {
                            donut: {
                                size: '55%',
                                labels: {
                                    show: true,
                                    total: {
                                        show: true,
                                        label: 'Total',
                                        formatter: function () { return '{{ global.total }}'; }
                                    }
                                }
                            }
                        }
                    }
                };

                chartEl._tbApexInstance = new ApexCharts(chartEl, statusOptions);
                chartEl._tbApexInstance.render();
            };

            if (!window[initKey]) {
                window[initKey] = true;
                document.addEventListener('DOMContentLoaded', function () { initApplicationStats(0); });
                document.addEventListener('turbo:load', function () { initApplicationStats(0); });
            }

            initApplicationStats(0);
        })();
    </script>
{% endblock %}
