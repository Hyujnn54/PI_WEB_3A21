{% extends 'admin/base_admin.html.twig' %}

{% block title %}Talent Bridge | Admin Job Offers{% endblock %}

{% block admin_content %}
    <div class="row mb-4 align-items-center">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h1 class="h3 mb-1">All Job Offers</h1>
                <p class="mb-0 text-muted">Admin view of all published offers.</p>
            </div>
            <a href="{{ path('app_admin') }}" class="btn btn-outline-primary">
                <i class="ti ti-arrow-left me-1"></i>Back to Dashboard
            </a>
        </div>
    </div>

    <div class="card border">
        <div class="table-responsive">
            <table class="table table-vcenter card-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Recruiter ID</th>
                        <th>Location</th>
                        <th>Contract</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Deadline</th>
                        <th>Warning</th>
                    </tr>
                </thead>
                <tbody>
                {% for offer in offers %}
                    {% set warningStatus = offer.warning_status|default(null) %}
                    {% set isActive = warningStatus == 'SENT' %}
                    {% set isPendingReview = warningStatus == 'RESOLVED' %}
                    {% set rowClass = isActive ? 'table-warning' : (isPendingReview ? 'table-info' : '') %}
                    <tr class="{{ rowClass }}">
                        <td>#{{ offer.id }}</td>
                        <td>{{ offer.title }}</td>
                        <td>{{ offer.recruiter_id }}</td>
                        <td>{{ offer.location }}</td>
                        <td>{{ offer.contract_type }}</td>
                        <td>{{ offer.status }}</td>
                        <td>{{ offer.created_at ? offer.created_at|date('Y-m-d H:i') : '-' }}</td>
                        <td>{{ offer.deadline ? offer.deadline|date('Y-m-d H:i') : '-' }}</td>
                        <td style="min-width: 320px;">
                            {% if isPendingReview %}
                                <div class="small fw-semibold text-info-emphasis mb-2">
                                    <i class="ti ti-refresh me-1"></i>Pending Review
                                </div>
                                <div class="small text-secondary mb-2">Original reason: {{ offer.warning_reason|default('-') }}</div>
                                <div class="small text-muted mb-2">Modified: {{ offer.warning_edited_at ? offer.warning_edited_at|date('Y-m-d H:i') : '-' }}</div>
                                <div class="d-flex flex-column gap-2">
                                    <form method="post" action="{{ path('app_admin_accept_job_offer_changes', {id: offer.id}) }}" style="display: inline;">
                                        <button type="submit" class="btn btn-sm btn-outline-success" onclick="return confirm('Accept this job modification?');">
                                            <i class="ti ti-check me-1"></i>Accept Changes
                                        </button>
                                    </form>
                                    <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="collapse" data-bs-target="#warning-form-{{ offer.id }}">
                                        <i class="ti ti-alert-triangle me-1"></i>Send Another Warning
                                    </button>
                                    <div class="collapse mt-2" id="warning-form-{{ offer.id }}">
                                        <form method="post" action="{{ path('app_admin_job_offer_warning', {id: offer.id}) }}" class="d-flex flex-column gap-2">
                                            <textarea name="reason" rows="2" class="form-control form-control-sm" placeholder="New warning reason..." required></textarea>
                                            <button type="submit" class="btn btn-sm btn-danger">Submit Warning</button>
                                        </form>
                                    </div>
                                </div>
                            {% elseif isActive %}
                                <div class="small fw-semibold text-warning-emphasis mb-1">
                                    <i class="ti ti-alert-circle me-1"></i>Active Warning
                                </div>
                                <div class="small text-secondary">Reason: {{ offer.warning_reason|default('-') }}</div>
                            {% else %}
                                <form method="post" action="{{ path('app_admin_job_offer_warning', {id: offer.id}) }}" class="d-flex flex-column gap-2">
                                    <textarea name="reason" rows="2" class="form-control form-control-sm" placeholder="Reason for warning..." required></textarea>
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Send Warning</button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9" class="text-secondary">No job offers found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
