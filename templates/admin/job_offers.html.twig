{% extends 'admin/base_admin.html.twig' %}

{% block title %}Talent Bridge | Admin Job Offers{% endblock %}

{% block admin_content %}
    {% set warningModalServerErrors = app.flashes('warning_modal_error') %}
    {% set warningModalServerModes = app.flashes('warning_modal_mode') %}
    {% set warningModalServerTypes = app.flashes('warning_modal_type') %}
    {% set warningModalServerTexts = app.flashes('warning_modal_text') %}
    {% set warningModalServerError = warningModalServerErrors|first|default('') %}
    {% set warningModalServerMode = warningModalServerModes|first|default('warn') %}
    {% set warningModalServerType = warningModalServerTypes|first|default('') %}
    {% set warningModalServerText = warningModalServerTexts|first|default('') %}

    <div class="row mb-4 align-items-center">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h1 class="h3 mb-1">All Job Offers</h1>
                <p class="mb-0 text-muted">Admin view of all published offers.</p>
            </div>
            <div class="d-flex gap-2">
                <a href="{{ path('app_admin_job_offers_statistics') }}" class="btn btn-primary">
                    <i class="ti ti-chart-pie me-1"></i>Statistics
                </a>
                <a href="{{ path('app_admin') }}" class="btn btn-outline-primary">
                    <i class="ti ti-arrow-left me-1"></i>Back to Dashboard
                </a>
            </div>
        </div>
    </div>

    {% if expiredOffers|default([])|length > 0 %}
        <div class="card border-danger mb-3">
            <div class="card-header">
                <h3 class="card-title text-danger mb-0"><i class="ti ti-clock-exclamation me-1"></i>Expired Offers (Auto-Closed)</h3>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Title</th>
                                <th>Location</th>
                                <th>Contract</th>
                                <th>Status</th>
                                <th>Deadline</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for expired in expiredOffers %}
                                <tr>
                                    <td>#{{ expired.id }}</td>
                                    <td>{{ expired.title }}</td>
                                    <td>{{ expired.location|default('-') }}</td>
                                    <td>{{ expired.contract_type|default('-') }}</td>
                                    <td><span class="badge bg-danger">{{ expired.status|default('closed')|capitalize }}</span></td>
                                    <td>{{ expired.deadline ? expired.deadline|date('Y-m-d H:i') : '-' }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {% endif %}

    <div class="card border mb-3">
        <div class="card-body d-flex flex-wrap gap-2 align-items-center" id="adminOfferMultiFilter">
            {{ form_start(filterForm, {
                action: path('app_admin_job_offers'),
                method: 'GET',
                attr: {
                    class: 'd-flex flex-wrap gap-2 align-items-center',
                    id: 'adminOfferFilterForm'
                }
            }) }}
                {{ form_widget(filterForm.search, {
                    attr: {
                        class: 'form-control',
                        style: 'max-width: 220px;',
                        placeholder: 'Search title, location, contract, status...',
                        id: 'adminSearchInput'
                    }
                }) }}
                {{ form_widget(filterForm.contract_type, {
                    attr: {
                        class: 'form-select',
                        style: 'max-width: 190px;',
                        id: 'adminFilterContractType'
                    }
                }) }}
                {{ form_widget(filterForm.status, {
                    attr: {
                        class: 'form-select',
                        style: 'max-width: 170px;',
                        id: 'adminFilterStatus'
                    }
                }) }}
                {{ form_widget(filterForm.deadline, {
                    attr: {
                        class: 'form-control',
                        style: 'max-width: 170px;',
                        id: 'adminFilterDeadline'
                    }
                }) }}
                <button type="submit" class="btn btn-primary btn-sm">Search</button>
                <a href="{{ path('app_admin_job_offers') }}" class="btn btn-outline-secondary btn-sm" id="adminClearOfferFilters">Reset</a>
                <div class="small text-secondary ms-auto" id="adminOfferFilterResults">{{ resultCount|default(offers|length) }} result(s)</div>
            {{ form_end(filterForm) }}
        </div>
    </div>

    <div class="card border">
        <div class="table-responsive">
            <table class="table table-vcenter card-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Recruiter ID</th>
                        <th>Location</th>
                        <th>Contract</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Deadline</th>
                        <th>Warning</th>
                    </tr>
                </thead>
                <tbody>
                {% for offer in offers %}
                    {% set warningStatus = offer.warning_status|default(null) %}
                    {% set warningStatusKey = warningStatus ? warningStatus|upper : '' %}
                    {% set isActive = warningStatusKey in ['SENT', 'SEEN'] %}
                    {% set isPendingReview = warningStatusKey == 'RESOLVED' %}
                    {% set rowClass = isActive ? 'table-danger' : (isPendingReview ? 'table-warning' : '') %}
                    <tr class="{{ rowClass }} admin-offer-row"
                        data-offer-id="{{ offer.id }}"
                        data-warning-state="{{ warningStatusKey }}"
                        data-details-url="{{ path('app_admin_job_offer_details', {id: offer.id}) }}"
                        data-analyze-url="{{ path('app_admin_job_offer_analyze', {id: offer.id}) }}"
                        data-accept-url="{{ path('app_admin_accept_job_offer_changes', {id: offer.id}) }}"
                        data-warning-url="{{ path('app_admin_job_offer_warning', {id: offer.id}) }}"
                        data-reject-url="{{ path('app_admin_reject_job_offer_changes', {id: offer.id}) }}">
                        <td>#{{ offer.id }}</td>
                        <td>{{ offer.title }}</td>
                        <td>{{ offer.recruiter_id }}</td>
                        <td>{{ offer.location }}</td>
                        <td>{{ offer.contract_type }}</td>
                        <td>{{ offer.status }}</td>
                        <td>{{ offer.created_at ? offer.created_at|date('Y-m-d H:i') : '-' }}</td>
                        <td>{{ offer.deadline ? offer.deadline|date('Y-m-d H:i') : '-' }}</td>
                        <td style="min-width: 320px;">
                            <div class="d-flex flex-column gap-2 mb-2">
                                <button type="button" class="btn btn-sm btn-outline-primary js-open-review"
                                        data-offer-id="{{ offer.id }}"
                                        data-details-url="{{ path('app_admin_job_offer_details', {id: offer.id}) }}"
                                        data-analyze-url="{{ path('app_admin_job_offer_analyze', {id: offer.id}) }}"
                                        data-accept-url="{{ path('app_admin_accept_job_offer_changes', {id: offer.id}) }}"
                                        data-warning-url="{{ path('app_admin_job_offer_warning', {id: offer.id}) }}"
                                        data-reject-url="{{ path('app_admin_reject_job_offer_changes', {id: offer.id}) }}"
                                        data-review-mode="details"
                                        data-bs-toggle="modal"
                                        data-bs-target="#reviewOfferModal">
                                    <i class="ti ti-search me-1"></i>Details
                                </button>
                            </div>
                            {% if isPendingReview %}
                                <div class="small fw-semibold text-warning-emphasis mb-2 d-flex align-items-center gap-1">
                                    <i class="ti ti-bell-ringing"></i>
                                    Recruiter Resolved Warning
                                </div>
                                <div class="small text-secondary mb-2">Previous warning: {{ offer.warning_reason|default('-') }}</div>
                                <div class="small text-muted mb-2">Recruiter submitted changes. Review this offer in the popup.</div>
                                <div class="d-flex flex-column gap-2">
                                    <button type="button" class="btn btn-sm btn-primary js-open-review"
                                            data-offer-id="{{ offer.id }}"
                                            data-details-url="{{ path('app_admin_job_offer_details', {id: offer.id}) }}"
                                            data-analyze-url="{{ path('app_admin_job_offer_analyze', {id: offer.id}) }}"
                                            data-accept-url="{{ path('app_admin_accept_job_offer_changes', {id: offer.id}) }}"
                                            data-warning-url="{{ path('app_admin_job_offer_warning', {id: offer.id}) }}"
                                            data-reject-url="{{ path('app_admin_reject_job_offer_changes', {id: offer.id}) }}"
                                            data-review-mode="pending"
                                            data-bs-toggle="modal"
                                            data-bs-target="#reviewOfferModal">
                                        <i class="ti ti-search me-1"></i>Review Resolved Offer
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-danger js-warning-open"
                                            data-offer-id="{{ offer.id }}"
                                            data-action="reject"
                                            data-action-url="{{ path('app_admin_reject_job_offer_changes', {id: offer.id}) }}"
                                            data-bs-toggle="modal"
                                            data-bs-target="#warningModal">
                                        <i class="ti ti-x me-1"></i>Reject Changes
                                    </button>
                                </div>
                            {% elseif isActive %}
                                <div class="small fw-semibold text-danger mb-1">
                                    <i class="ti ti-alert-circle me-1"></i>Active Warning
                                </div>
                                <div class="small text-secondary">Reason: {{ offer.warning_reason|default('-') }}</div>
                                <div class="small text-danger mt-1"><i class="ti ti-lock me-1"></i>Warning is locked until recruiter resolves it.</div>
                                <button type="button" class="btn btn-sm btn-danger mt-2" disabled title="Locked until resolved">
                                    <i class="ti ti-lock me-1"></i>Warning Already Sent
                                </button>
                            {% else %}
                                <button type="button" class="btn btn-sm btn-outline-danger js-warning-open"
                                        data-offer-id="{{ offer.id }}"
                                        data-action="warn"
                                        data-action-url="{{ path('app_admin_job_offer_warning', {id: offer.id}) }}"
                                        data-bs-toggle="modal"
                                        data-bs-target="#warningModal">
                                    <i class="ti ti-alert-triangle me-1"></i>Signaler
                                </button>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9" class="text-secondary">No job offers found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="modal fade" id="reviewOfferModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="reviewOfferModalTitle">Review Recruiter Changes</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="reviewOfferLoading" class="text-secondary">Loading offer details...</div>
                    <div id="reviewOfferContent" class="d-none">
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <div class="small text-muted">Title</div>
                                <div class="fw-semibold" id="reviewOfferTitle">-</div>
                            </div>
                            <div class="col-md-6">
                                <div class="small text-muted">Status</div>
                                <div class="fw-semibold" id="reviewOfferStatus">-</div>
                            </div>
                            <div class="col-md-6">
                                <div class="small text-muted">Location</div>
                                <div class="fw-semibold" id="reviewOfferLocation">-</div>
                            </div>
                            <div class="col-md-6">
                                <div class="small text-muted">Contract</div>
                                <div class="fw-semibold" id="reviewOfferContract">-</div>
                            </div>
                            <div class="col-md-6">
                                <div class="small text-muted">Deadline</div>
                                <div class="fw-semibold" id="reviewOfferDeadline">-</div>
                            </div>
                            <div class="col-md-6">
                                <div class="small text-muted">Recruiter ID</div>
                                <div class="fw-semibold" id="reviewOfferRecruiter">-</div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="small text-muted mb-1">Description</div>
                            <div class="border rounded p-2 bg-light-subtle" id="reviewOfferDescription">-</div>
                        </div>
                        <div class="mb-3 d-none" id="reviewCorrectionBox">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="fw-semibold">Submitted Changes</div>
                                <div class="small text-muted" id="reviewCorrectionSubmittedAt"></div>
                            </div>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="small text-muted mb-1">Previous Title</div>
                                    <div class="border rounded p-2 bg-light-subtle" id="reviewOldTitle">-</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="small text-muted mb-1">New Title</div>
                                    <div class="border rounded p-2 bg-success-lt" id="reviewNewTitle">-</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="small text-muted mb-1">Previous Description</div>
                                    <div class="border rounded p-2 bg-light-subtle" id="reviewOldDescription">-</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="small text-muted mb-1">New Description</div>
                                    <div class="border rounded p-2 bg-success-lt" id="reviewNewDescription">-</div>
                                </div>
                            </div>
                        </div>
                        <div>
                            <div class="small text-muted mb-1">Skills</div>
                            <div id="reviewOfferSkills" class="d-flex flex-wrap gap-2"></div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer d-flex justify-content-between">
                    <div class="small text-muted" id="reviewOfferFooterHint">Approve the changes or send another warning from here.</div>
                    <div class="d-flex gap-2 align-items-center">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-outline-primary" id="reviewAnalyzeBtn">
                            <i class="ti ti-brain me-1"></i>Analyzer
                        </button>
                        <div class="d-flex gap-2" id="reviewOfferActions">
                            <form method="post" id="reviewAcceptForm">
                                <button type="submit" class="btn btn-success" onclick="return confirm('Accept recruiter changes for this offer?');">
                                    <i class="ti ti-check me-1"></i>Accept Changes
                                </button>
                            </form>
                            <button type="button" class="btn btn-danger" id="reviewSendWarningBtn">
                                <i class="ti ti-alert-triangle me-1"></i>Signaler
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="warningModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" id="warningModalForm" novalidate>
                    <div class="modal-header">
                        <h5 class="modal-title" id="warningModalTitle">Signaler une offre</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Raison</label>
                            <select class="form-select" name="warning_type" id="warningType" required>
                                <option value="">Select type</option>
                                <option value="Policy violation" {{ warningModalServerType == 'Policy violation' ? 'selected' : '' }}>Policy violation</option>
                                <option value="Incorrect information" {{ warningModalServerType == 'Incorrect information' ? 'selected' : '' }}>Incorrect information</option>
                                <option value="Missing required details" {{ warningModalServerType == 'Missing required details' ? 'selected' : '' }}>Missing required details</option>
                                <option value="Deadline issue" {{ warningModalServerType == 'Deadline issue' ? 'selected' : '' }}>Deadline issue</option>
                                <option value="Description trompeuse" {{ warningModalServerType == 'Description trompeuse' ? 'selected' : '' }}>Description trompeuse</option>
                                <option value="Other" {{ warningModalServerType == 'Other' ? 'selected' : '' }}>Other</option>
                            </select>
                        </div>
                        <div>
                            <label class="form-label">Message</label>
                            <textarea class="form-control" name="warning_text" id="warningText" rows="4" placeholder="Write warning details..." required>{{ warningModalServerText }}</textarea>
                            <div class="d-flex align-items-center gap-2 mt-2">
                                <button type="button" class="btn btn-outline-primary btn-sm" id="warningGenerateAiBtn">
                                    <i class="ti ti-sparkles me-1"></i>Générer avec IA (Groq)
                                </button>
                                <span class="small text-secondary" id="warningAiStatus"></span>
                            </div>
                            <div class="invalid-feedback d-block" id="warningModalError" style="display:{{ warningModalServerError != '' ? 'block' : 'none' }};">{{ warningModalServerError }}</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger" id="warningSubmitBtn">Envoyer warning</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        (function () {
            const table = document.querySelector('.table.table-vcenter.card-table');
            if (!table) return;

            const rows = Array.from(table.querySelectorAll('tbody .admin-offer-row'));

            const filterForm = document.getElementById('adminOfferFilterForm');
            const searchInput = document.getElementById('adminSearchInput');
            const contractTypeSelect = document.getElementById('adminFilterContractType');
            const statusSelect = document.getElementById('adminFilterStatus');
            const deadlineInput = document.getElementById('adminFilterDeadline');

            const warningModal = document.getElementById('warningModal');
            const warningModalForm = document.getElementById('warningModalForm');
            const warningModalTitle = document.getElementById('warningModalTitle');
            const warningSubmitBtn = document.getElementById('warningSubmitBtn');
            const warningType = document.getElementById('warningType');
            const warningText = document.getElementById('warningText');
            const warningGenerateAiBtn = document.getElementById('warningGenerateAiBtn');
            const warningAiStatus = document.getElementById('warningAiStatus');
            const warningModalError = document.getElementById('warningModalError');
            const serverWarningMode = '{{ warningModalServerMode }}';
            const hasServerWarningError = {{ warningModalServerError != '' ? 'true' : 'false' }};
            const reviewModal = document.getElementById('reviewOfferModal');
            const reviewLoading = document.getElementById('reviewOfferLoading');
            const reviewContent = document.getElementById('reviewOfferContent');
            const reviewAcceptForm = document.getElementById('reviewAcceptForm');
            const reviewSendWarningBtn = document.getElementById('reviewSendWarningBtn');
            const reviewAnalyzeBtn = document.getElementById('reviewAnalyzeBtn');
            const reviewModalTitle = document.getElementById('reviewOfferModalTitle');
            const reviewFooterHint = document.getElementById('reviewOfferFooterHint');
            const reviewActions = document.getElementById('reviewOfferActions');
            let reviewRejectUrl = '';
            let reviewWarningUrl = '';
            let reviewAnalyzeUrl = '';
            let currentReviewMode = 'details';
            let currentReviewOfferId = '';
            let currentWarningOfferId = '';

            const setWarningAiStatus = function (message, isError) {
                if (!warningAiStatus) return;
                warningAiStatus.textContent = message || '';
                warningAiStatus.classList.toggle('text-danger', Boolean(isError));
                warningAiStatus.classList.toggle('text-secondary', !isError);
            };

            const cleanModalState = function () {
                if (document.querySelector('.modal.show')) {
                    return;
                }

                document.body.classList.remove('modal-open');
                document.body.style.removeProperty('overflow');
                document.body.style.removeProperty('padding-right');
                document.querySelectorAll('.modal-backdrop').forEach(function (backdrop) {
                    backdrop.remove();
                });
            };

            if (warningModal) {
                warningModal.addEventListener('hidden.bs.modal', cleanModalState);
            }

            if (reviewModal) {
                reviewModal.addEventListener('hidden.bs.modal', cleanModalState);
            }

            const setReviewDetails = function (payload) {
                const offer = payload.offer || {};
                const skills = payload.skills || [];
                const correction = payload.correction || null;

                document.getElementById('reviewOfferTitle').textContent = offer.title || '-';
                document.getElementById('reviewOfferStatus').textContent = offer.status || '-';
                document.getElementById('reviewOfferLocation').textContent = offer.location || '-';
                document.getElementById('reviewOfferContract').textContent = offer.contract_type || '-';
                document.getElementById('reviewOfferDeadline').textContent = offer.deadline || '-';
                document.getElementById('reviewOfferRecruiter').textContent = offer.recruiter_id || '-';
                document.getElementById('reviewOfferDescription').textContent = offer.description || 'No description provided.';

                const correctionBox = document.getElementById('reviewCorrectionBox');
                if (correctionBox) {
                    if (correction) {
                        document.getElementById('reviewCorrectionSubmittedAt').textContent = correction.submitted_at ? ('Submitted ' + correction.submitted_at) : '';
                        document.getElementById('reviewOldTitle').textContent = correction.old_title || '-';
                        document.getElementById('reviewNewTitle').textContent = correction.new_title || '-';
                        document.getElementById('reviewOldDescription').textContent = correction.old_description || '-';
                        document.getElementById('reviewNewDescription').textContent = correction.new_description || '-';
                        correctionBox.classList.remove('d-none');
                    } else {
                        correctionBox.classList.add('d-none');
                    }
                }

                const skillsNode = document.getElementById('reviewOfferSkills');
                skillsNode.innerHTML = '';
                if (!skills.length) {
                    const emptyBadge = document.createElement('span');
                    emptyBadge.className = 'badge bg-secondary-lt';
                    emptyBadge.textContent = 'No skills listed';
                    skillsNode.appendChild(emptyBadge);
                    return;
                }

                skills.forEach(function (skill) {
                    const chip = document.createElement('span');
                    chip.className = 'badge bg-primary-lt text-primary';
                    chip.textContent = (skill.skill_name || '-') + ' (' + (skill.level_required || '-') + ')';
                    skillsNode.appendChild(chip);
                });
            };

            const openReviewModal = function (offerId, detailsUrl, analyzeUrl, acceptUrl, warningUrl, rejectUrl, mode) {
                currentReviewOfferId = (offerId || '').toString();
                currentReviewMode = mode || 'details';
                reviewRejectUrl = rejectUrl || '';
                reviewWarningUrl = warningUrl || '';
                reviewAnalyzeUrl = analyzeUrl || '';
                reviewAcceptForm.setAttribute('action', acceptUrl || '#');

                if (mode === 'pending') {
                    reviewModalTitle.textContent = 'Review Recruiter Changes';
                    reviewFooterHint.textContent = 'Approve the changes or send another warning from here.';
                    reviewActions.classList.remove('d-none');
                    reviewAcceptForm.classList.remove('d-none');
                    reviewSendWarningBtn.innerHTML = '<i class="ti ti-x me-1"></i>Reject Changes';
                } else {
                    reviewModalTitle.textContent = 'Job Offer Details';
                    reviewFooterHint.textContent = 'Analyze this offer or send a warning to the recruiter.';
                    reviewActions.classList.remove('d-none');
                    reviewAcceptForm.classList.add('d-none');
                    reviewSendWarningBtn.innerHTML = '<i class="ti ti-alert-triangle me-1"></i>Signaler';
                }

                reviewLoading.textContent = 'Loading offer details...';
                reviewLoading.classList.remove('d-none');
                reviewContent.classList.add('d-none');

                fetch(detailsUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(function (response) { return response.json(); })
                    .then(function (payload) {
                        if (!payload || !payload.ok) {
                            throw new Error((payload && payload.error) ? payload.error : 'Unable to load details');
                        }
                        setReviewDetails(payload);
                        reviewLoading.classList.add('d-none');
                        reviewContent.classList.remove('d-none');
                    })
                    .catch(function (error) {
                        reviewLoading.textContent = error.message || 'Unable to load offer details.';
                        reviewContent.classList.add('d-none');
                    });

                if (window.bootstrap && reviewModal) {
                    window.bootstrap.Modal.getOrCreateInstance(reviewModal).show();
                }
            };

            document.querySelectorAll('.js-open-review').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    const offerId = btn.getAttribute('data-offer-id') || '';
                    const detailsUrl = btn.getAttribute('data-details-url') || '';
                    const analyzeUrl = btn.getAttribute('data-analyze-url') || '';
                    const acceptUrl = btn.getAttribute('data-accept-url') || '#';
                    const warningUrl = btn.getAttribute('data-warning-url') || '#';
                    const rejectUrl = btn.getAttribute('data-reject-url') || '#';
                    const mode = btn.getAttribute('data-review-mode') || 'details';
                    openReviewModal(offerId, detailsUrl, analyzeUrl, acceptUrl, warningUrl, rejectUrl, mode);
                });
            });

            rows.forEach(function (row) {
                row.addEventListener('click', function (event) {
                    if (event.target.closest('a,button,form,input,select,textarea,label')) {
                        return;
                    }

                    const detailsUrl = row.getAttribute('data-details-url') || '';
                    if (!detailsUrl) {
                        return;
                    }

                    const warningState = (row.getAttribute('data-warning-state') || '').toUpperCase();
                    const mode = warningState === 'RESOLVED' ? 'pending' : 'readonly';
                    openReviewModal(
                        row.getAttribute('data-offer-id') || '',
                        detailsUrl,
                        row.getAttribute('data-analyze-url') || '',
                        row.getAttribute('data-accept-url') || '#',
                        row.getAttribute('data-warning-url') || '#',
                        row.getAttribute('data-reject-url') || '#',
                        mode
                    );
                });
            });

            if (reviewSendWarningBtn) {
                reviewSendWarningBtn.addEventListener('click', function (event) {
                    event.preventDefault();
                    const actionUrl = currentReviewMode === 'pending' ? reviewRejectUrl : reviewWarningUrl;
                    if (!actionUrl) return;
                    currentWarningOfferId = currentReviewOfferId;
                    warningModalForm.setAttribute('action', actionUrl);

                    if (currentReviewMode === 'pending') {
                        warningModalTitle.textContent = 'Rejeter les changements et signaler';
                        warningSubmitBtn.textContent = 'Rejeter les changements';
                        warningSubmitBtn.classList.remove('btn-danger');
                        warningSubmitBtn.classList.add('btn-warning');
                    } else {
                        warningModalTitle.textContent = 'Signaler une offre';
                        warningSubmitBtn.textContent = 'Signaler';
                        warningSubmitBtn.classList.remove('btn-warning');
                        warningSubmitBtn.classList.add('btn-danger');
                    }
                    if (warningType) warningType.value = '';
                    if (warningText) warningText.value = '';
                    setWarningAiStatus('', false);
                    if (warningModalError) {
                        warningModalError.textContent = '';
                        warningModalError.style.display = 'none';
                    }

                    if (!window.bootstrap || !warningModal) {
                        return;
                    }

                    const showWarningModal = function () {
                        window.bootstrap.Modal.getOrCreateInstance(warningModal).show();
                    };

                    if (reviewModal && reviewModal.classList.contains('show')) {
                        reviewModal.addEventListener('hidden.bs.modal', showWarningModal, { once: true });
                        window.bootstrap.Modal.getOrCreateInstance(reviewModal).hide();
                    } else {
                        showWarningModal();
                    }
                });
            }

            if (reviewAnalyzeBtn) {
                reviewAnalyzeBtn.addEventListener('click', function () {
                    if (!reviewAnalyzeUrl || !currentReviewOfferId) {
                        alert('Please open offer details first, then run Analyzer.');
                        return;
                    }

                    reviewAnalyzeBtn.disabled = true;
                    reviewAnalyzeBtn.innerHTML = '<i class="ti ti-loader me-1"></i>Analyzing...';

                    fetch(reviewAnalyzeUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                    .then(function (response) { return response.json(); })
                    .then(function (payload) {
                        if (!payload || payload.ok !== true) {
                            throw new Error((payload && payload.error) ? payload.error : 'Analysis failed.');
                        }

                        const commentAnalysis = payload.commentAnalysis || {};
                        const groqAnalysis = payload.groqAnalysis || {};
                        const flagDecision = payload.flagDecision || {};
                        const labels = Array.isArray(commentAnalysis.labels) && commentAnalysis.labels.length > 0 ? commentAnalysis.labels.join(', ') : 'none';
                        const groqIssues = Array.isArray(groqAnalysis.issues) && groqAnalysis.issues.length > 0 ? groqAnalysis.issues.join('; ') : 'none';
                        const groqRecommendations = Array.isArray(groqAnalysis.recommendations) && groqAnalysis.recommendations.length > 0 ? groqAnalysis.recommendations.join('; ') : 'none';
                        const message = [
                            'Analyzer Result (Offer #' + (currentReviewOfferId || '-') + ')',
                            '',
                            'Comment Analyzer',
                            'Toxicity: ' + Number(commentAnalysis.toxicityScore || 0).toFixed(3),
                            'Spam: ' + Number(commentAnalysis.spamScore || 0).toFixed(3),
                            'Sentiment: ' + String(commentAnalysis.sentiment || 'neutral'),
                            'Labels: ' + labels,
                            'Flagged: ' + (((commentAnalysis.flagged || false) === true) ? 'YES' : 'NO'),
                            '',
                            'Groq Offer Review',
                            'Source: ' + String(groqAnalysis.source || 'unknown') + (groqAnalysis.model ? ' (' + groqAnalysis.model + ')' : ''),
                            'Risk: ' + String(groqAnalysis.riskLevel || 'unknown'),
                            'Summary: ' + String(groqAnalysis.summary || '-'),
                            'Issues: ' + groqIssues,
                            'Recommendations: ' + groqRecommendations,
                            '',
                            'Offer Flag Decision',
                            'Flagged: ' + (((flagDecision.flagged || false) === true) ? 'YES' : 'NO'),
                            'Quality score: ' + String(flagDecision.qualityScore || '-'),
                            'Reason: ' + String(flagDecision.reason || '-')
                        ].join('\n');

                        alert(message);
                    })
                    .catch(function (error) {
                        alert(error.message || 'Unable to analyze this offer right now.');
                    })
                    .finally(function () {
                        reviewAnalyzeBtn.disabled = false;
                        reviewAnalyzeBtn.innerHTML = '<i class="ti ti-brain me-1"></i>Analyzer';
                    });
                });
            }

            document.querySelectorAll('.js-warning-open').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    const actionMode = btn.getAttribute('data-action') || 'warn';
                    const actionUrl = btn.getAttribute('data-action-url') || '#';
                    currentWarningOfferId = (btn.getAttribute('data-offer-id') || '').toString();
                    warningModalForm.setAttribute('action', actionUrl);

                    if (actionMode === 'reject') {
                        warningModalTitle.textContent = 'Rejeter les changements et signaler';
                        warningSubmitBtn.textContent = 'Rejeter les changements';
                        warningSubmitBtn.classList.remove('btn-danger');
                        warningSubmitBtn.classList.add('btn-warning');
                    } else {
                        warningModalTitle.textContent = 'Signaler une offre';
                        warningSubmitBtn.textContent = 'Envoyer warning';
                        warningSubmitBtn.classList.remove('btn-warning');
                        warningSubmitBtn.classList.add('btn-danger');
                    }

                    if (warningType) warningType.value = '';
                    if (warningText) warningText.value = '';
                    setWarningAiStatus('', false);
                    if (warningModalError) {
                        warningModalError.textContent = '';
                        warningModalError.style.display = 'none';
                    }
                });
            });

            if (warningModalForm) {
                warningModalForm.addEventListener('submit', function (event) {
                    const typeValue = (warningType && warningType.value ? warningType.value : '').trim();
                    const textValue = (warningText && warningText.value ? warningText.value : '').trim();
                    if (typeValue === '' || textValue === '') {
                        event.preventDefault();
                        if (warningModalError) {
                            warningModalError.textContent = 'Warning type and message are required.';
                            warningModalError.style.display = 'block';
                        }
                    }
                });
            }

            if (warningGenerateAiBtn) {
                warningGenerateAiBtn.addEventListener('click', function () {
                    const typeValue = (warningType && warningType.value ? warningType.value : '').trim();
                    if (currentWarningOfferId === '') {
                        setWarningAiStatus('Sélectionnez une offre avant de générer le message.', true);
                        return;
                    }

                    if (typeValue === '') {
                        setWarningAiStatus('Choisissez une raison avant de lancer la génération IA.', true);
                        return;
                    }

                    warningGenerateAiBtn.disabled = true;
                    setWarningAiStatus('Génération du message en cours...', false);

                    fetch('{{ path('app_admin_job_offer_warning_ai_generate') }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({
                            offer_id: currentWarningOfferId,
                            warning_type: typeValue
                        })
                    })
                    .then(function (response) { return response.json(); })
                    .then(function (payload) {
                        if (!payload || payload.ok !== true) {
                            throw new Error((payload && payload.error) ? payload.error : 'Generation failed.');
                        }

                        if (warningText) {
                            warningText.value = payload.message || '';
                        }

                        if (warningModalError) {
                            warningModalError.textContent = '';
                            warningModalError.style.display = 'none';
                        }

                        if ((payload.source || '') === 'ai') {
                            setWarningAiStatus('Message généré avec IA (Groq). Vous pouvez le modifier avant envoi.', false);
                        } else {
                            setWarningAiStatus('IA indisponible, message professionnel proposé automatiquement.', false);
                        }
                    })
                    .catch(function (error) {
                        setWarningAiStatus(error.message || 'Erreur lors de la génération IA.', true);
                    })
                    .finally(function () {
                        warningGenerateAiBtn.disabled = false;
                    });
                });
            }

            if (hasServerWarningError && window.bootstrap && warningModal) {
                if (serverWarningMode === 'reject') {
                    warningModalTitle.textContent = 'Rejeter les changements et signaler';
                    warningSubmitBtn.textContent = 'Rejeter les changements';
                    warningSubmitBtn.classList.remove('btn-danger');
                    warningSubmitBtn.classList.add('btn-warning');
                } else {
                    warningModalTitle.textContent = 'Signaler une offre';
                    warningSubmitBtn.textContent = 'Envoyer warning';
                    warningSubmitBtn.classList.remove('btn-warning');
                    warningSubmitBtn.classList.add('btn-danger');
                }

                window.bootstrap.Modal.getOrCreateInstance(warningModal).show();
            }

            if (filterForm) {
                if (searchInput) {
                    let searchDebounceTimer = null;
                    searchInput.addEventListener('input', function () {
                        if (searchDebounceTimer) {
                            clearTimeout(searchDebounceTimer);
                        }

                        searchDebounceTimer = setTimeout(function () {
                            filterForm.requestSubmit();
                        }, 350);
                    });
                }

                const autoSubmitFilter = function () {
                    filterForm.requestSubmit();
                };
                if (contractTypeSelect) contractTypeSelect.addEventListener('change', autoSubmitFilter);
                if (statusSelect) statusSelect.addEventListener('change', autoSubmitFilter);
                if (deadlineInput) deadlineInput.addEventListener('change', autoSubmitFilter);
            }
        })();
    </script>
{% endblock %}
