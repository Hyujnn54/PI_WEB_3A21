{% extends 'admin/base_admin.html.twig' %}

{% block title %}Talent Bridge | Admin Application Details{% endblock %}

{% block admin_content %}
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h1 class="h3 mb-1">Application Details</h1>
                <p class="mb-0 text-muted">Admin inspection view for one application.</p>
            </div>
            <a href="{{ path('management_job_applications') }}" class="btn btn-outline-secondary">Back to Applications</a>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-lg-8">
            <div class="card border">
                <div class="card-header">
                    <h5 class="mb-0">{{ offer ? offer.title : 'Unknown Offer' }}</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="small text-muted">Current Status</div>
                            <div class="fw-semibold">{{ application.current_status }}</div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-muted">Applied At</div>
                            <div class="fw-semibold">{{ application.applied_at|date('d M Y H:i') }}</div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-muted">Candidate</div>
                            {% set candidateName = 'Candidate' %}
                            {% if candidate %}
                                {% set candidateName = (candidate.firstName|default('') ~ ' ' ~ candidate.lastName|default(''))|trim %}
                                {% if candidateName == '' %}
                                    {% set candidateName = candidate.email|default('Candidate') %}
                                {% endif %}
                            {% endif %}
                            <div class="fw-semibold">{{ candidateName }}</div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-muted">Phone</div>
                            <div class="fw-semibold">{{ application.phone }}</div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-muted">CV File</div>
                            {% set cvPath = (application.cv_path|default('')|trim) %}
                            {% set cvPathNormalized = cvPath|replace({'\\': '/'}) %}
                            {% set cvUrl = '' %}
                            {% if cvPathNormalized != '' %}
                                {% if cvPathNormalized starts with 'http://' or cvPathNormalized starts with 'https://' %}
                                    {% set cvUrl = cvPathNormalized %}
                                {% elseif cvPathNormalized starts with '/' %}
                                    {% set cvUrl = cvPathNormalized %}
                                {% elseif cvPathNormalized starts with 'public/' %}
                                    {% set cvUrl = asset(cvPathNormalized|slice(7)) %}
                                {% elseif cvPathNormalized starts with 'uploads/' %}
                                    {% set cvUrl = asset(cvPathNormalized) %}
                                {% else %}
                                    {% set cvUrl = asset('uploads/applications/' ~ cvPathNormalized) %}
                                {% endif %}
                            {% endif %}

                            {% if cvUrl != '' %}
                                <a class="btn btn-outline-primary btn-sm" href="{{ cvUrl }}" target="_blank" rel="noopener">
                                    <i class="ti ti-file-cv me-1"></i>Open CV
                                </a>
                            {% else %}
                                <span class="badge bg-secondary-subtle text-secondary-emphasis">CV unavailable</span>
                            {% endif %}
                        </div>
                        <div class="col-12">
                            <div class="small text-muted mb-1">Cover Letter</div>
                            <div class="p-3 border rounded bg-light-subtle">{{ application.cover_letter }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="card border">
                <div class="card-header">
                    <h5 class="mb-0">Admin Actions</h5>
                </div>
                <div class="card-body d-grid gap-3">
                    <form method="post" action="{{ application.is_archived ? unarchiveUrl : archiveUrl }}">
                        <input type="hidden" name="return_to" value="details">
                        <button type="submit" class="btn {{ application.is_archived ? 'btn-outline-success' : 'btn-outline-danger' }} w-100">
                            {{ application.is_archived ? 'Unarchive Application' : 'Archive Application' }}
                        </button>
                    </form>

                    <form method="post" action="{{ path('management_job_applications_update_status', {'applicationId': application.id}) }}">
                        <div class="mb-2">
                            <label class="form-label">Update Status</label>
                            <select name="status" class="form-select" required>
                                {% for statusOption in statusOptions %}
                                    <option value="{{ statusOption.value }}" {{ application.current_status == statusOption.value ? 'selected' : '' }}>{{ statusOption.label }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Note (optional)</label>
                            <textarea name="note" rows="3" class="form-control" placeholder="If empty, an admin note is generated automatically."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Save Status</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card border">
                <div class="card-header">
                    <h5 class="mb-0">Status History</h5>
                </div>
                <div class="card-body">
                    {% if historyEntries is not empty %}
                        <div class="list-group list-group-flush">
                            {% for entry in historyEntries %}
                                <div class="list-group-item px-0">
                                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                        <div>
                                            <div class="fw-semibold">{{ entry.status }}</div>
                                            <div class="text-muted">{{ entry.note }}</div>
                                            <form method="post" action="{{ path('management_job_applications_history_note_update', {'applicationId': application.id, 'historyId': entry.id}) }}" class="mt-2 js-note-edit-form" novalidate>
                                                <div class="input-group input-group-sm">
                                                    <input type="text" name="note" class="form-control js-note-input" value="{{ entry.note }}" maxlength="255">
                                                    <button type="submit" class="btn btn-outline-primary">Update Note</button>
                                                </div>
                                                <div class="invalid-feedback d-block js-note-error" style="display:none;"></div>
                                            </form>
                                        </div>
                                        <div class="d-flex flex-column align-items-end gap-2">
                                            <div class="small text-muted">{{ entry.changed_at|date('d M Y H:i') }}</div>
                                            <form method="post" action="{{ path('management_job_applications_history_delete', {'applicationId': application.id, 'historyId': entry.id}) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="text-muted">No history available.</div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <script>
        (function () {
            const forms = document.querySelectorAll('.js-note-edit-form');
            if (!forms.length) {
                return;
            }

            forms.forEach(function (form) {
                const input = form.querySelector('.js-note-input');
                const error = form.querySelector('.js-note-error');
                if (!input || !error) {
                    return;
                }

                const validate = function () {
                    const value = (input.value || '').trim();
                    if (value === '') {
                        input.classList.add('is-invalid');
                        error.textContent = 'Note cannot be empty.';
                        error.style.display = 'block';
                        return false;
                    }

                    input.classList.remove('is-invalid');
                    error.textContent = '';
                    error.style.display = 'none';
                    return true;
                };

                input.addEventListener('input', validate);
                input.addEventListener('blur', validate);

                form.addEventListener('submit', function (event) {
                    if (!validate()) {
                        event.preventDefault();
                    }
                });
            });
        })();
    </script>
{% endblock %}
