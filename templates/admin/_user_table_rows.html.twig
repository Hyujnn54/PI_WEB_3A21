{% for user in users %}
    <tr>
        <td>
            <div class="d-flex py-1 align-items-center">
                <span class="avatar me-2 rounded-circle bg-blue-lt">
                    {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                </span>
                <div class="font-weight-medium text-capitalize">{{ user.firstName }} {{ user.lastName }}</div>
            </div>
        </td>
        <td><span class="text-muted">{{ user.email }}</span></td>
        <td>
            {% for role in user.roles %}
                <span class="badge {{ role == 'ROLE_ADMIN' ? 'bg-red' : (role == 'ROLE_RECRUITER' ? 'bg-purple' : 'bg-blue') }}-lt">
                    {{ role|replace({'ROLE_': ''}) }}
                </span>
            {% endfor %}
        </td>
        <td>
            <span class="badge {{ user.isActive|default(false) ? 'bg-success' : 'bg-secondary' }}">
                {{ user.isActive|default(false) ? 'Active' : 'Inactive' }}
            </span>
        </td>
        <td class="text-muted">
            {# Safe check for Candidate entities missing createAt #}
            {% if attribute(user, 'createAt') is defined and user.createAt is not null %}
                {{ user.createAt|date('d M Y') }}
            {% else %}
                <span class="text-muted small">N/A</span>
            {% endif %}
        </td>
        <td>
            <div class="btn-list flex-nowrap">
                <a href="{{ path('app_admin_edit_user', {id: user.id}) }}" class="btn btn-white btn-sm">Edit</a>
                <button class="btn btn-white btn-sm text-danger">Delete</button>
            </div>
        </td>
    </tr>
{% else %}
    <tr><td colspan="6" class="text-center py-4 text-muted">No results found.</td></tr>
{% endfor %}