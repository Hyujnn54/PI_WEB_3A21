{% extends 'admin/base_admin.html.twig' %}

{% block title %}TalentBridge | Add User{% endblock %}

{% block admin_content %}
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-1">Add User</h1>
                <p class="mb-0">Reusable admin page prepared using workshop inheritance flow.</p>
            </div>
            <a href="{{ path('app_admin') }}" class="btn btn-outline-primary">Back to Dashboard</a>
        </div>
    </div>

    <div class="card border">
        <div class="card-body">
            <form>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">First Name</label>
                        <input type="text" class="form-control" placeholder="Enter first name">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Last Name</label>
                        <input type="text" class="form-control" placeholder="Enter last name">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" placeholder="user@example.com">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Role</label>
                        <select class="form-select">
                            <option>Candidate</option>
                            <option>Recruiter</option>
                            <option>Admin</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">Create User</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
{% endblock %}
