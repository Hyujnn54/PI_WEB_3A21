{% extends 'admin/base_admin.html.twig' %}

{% block title %}TalentBridge | Edit User{% endblock %}

{% block admin_content %}
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-1">Edit User</h1>
                <p class="text-muted mb-0">Modify details for <strong>{{ user.firstName }} {{ user.lastName }}</strong>.</p>
            </div>
            <a href="{{ path('app_admin_users') }}" class="btn btn-outline-secondary">
                <i class="ti ti-arrow-left me-1"></i>Back to List
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white">
            <h3 class="card-title">User Information</h3>
        </div>
        <div class="card-body">
            {# The form action points back to the current edit route with the user's ID #}
            <form action="{{ path('app_admin_edit_user', {id: user.id}) }}" method="POST">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label required">First Name</label>
                        <input type="text" name="first_name" class="form-control" value="{{ user.firstName }}" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label required">Last Name</label>
                        <input type="text" name="last_name" class="form-control" value="{{ user.lastName }}" required>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label required">Email Address</label>
                        <input type="email" name="email" class="form-control" value="{{ user.email }}" required>
                    </div>
                    
                    <div class="col-md-12">
                        <div class="hr-text">Role Management</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Current Role</label>
                        {# We display the first role found in the user's roles array #}
                        <input type="text" class="form-control" value="{{ user.roles|first }}" disabled>
                    </div>

                    <div class="col-12 mt-4">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="ti ti-device-floppy me-1"></i>Update User Details
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
{% endblock %}