{% extends 'admin/base_admin.html.twig' %}

{% block title %}Talent Bridge | Admin Dashboard{% endblock %}

{% block admin_content %}
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h1 class="h3 mb-1">Administration Dashboard</h1>
                    <p class="text-muted mb-0">Welcome back! Here's an overview of your recruitment pipeline.</p>
                </div>
                <div class="d-flex gap-2">
                    <a href="{{ path('app_admin_job_offers') }}" class="btn btn-primary">
                        <i class="ti ti-briefcase-2 me-1"></i>Job Offers
                    </a>
                    <a href="{{ path('app_admin_job_offers_statistics') }}" class="btn btn-outline-warning">
                        <i class="ti ti-chart-pie me-1"></i>Job Offer Statistics
                    </a>
                    <a href="{{ path('management_job_applications_statistics') }}" class="btn btn-outline-primary">
                        <i class="ti ti-chart-pie me-1"></i>View Statistics
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        {% for kpi in kpis %}
            <div class="col-md-6 col-xl-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <p class="mb-2 small text-muted text-uppercase fw-semibold">{{ kpi.label }}</p>
                                <h3 class="mb-0 fw-bold">{{ kpi.value }}</h3>
                            </div>
                            <div class="rounded-3 p-3" style="background: linear-gradient(135deg, #0d5bd7 0%, #1a365d 100%);">
                                <i class="{{ kpi.icon }} text-white" style="font-size: 1.5rem;"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12 col-xl-6">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title mb-3">
                        <i class="ti ti-rocket text-primary me-2"></i>Quick Actions
                    </h5>
                    <div class="d-grid gap-2">
                        <a href="{{ path('app_admin_job_offers') }}" class="btn btn-light text-start d-flex align-items-center gap-3 py-3">
                            <div class="rounded-2 bg-warning bg-opacity-10 p-2">
                                <i class="ti ti-briefcase-2 text-warning"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">Manage Job Offers</div>
                                <small class="text-muted">Review and moderate published offers</small>
                            </div>
                            <i class="ti ti-chevron-right ms-auto text-muted"></i>
                        </a>
                        <a href="{{ path('management_job_applications') }}" class="btn btn-light text-start d-flex align-items-center gap-3 py-3">
                            <div class="rounded-2 bg-primary bg-opacity-10 p-2">
                                <i class="ti ti-file-check text-primary"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">Review Applications</div>
                                <small class="text-muted">Manage candidate applications</small>
                            </div>
                            <i class="ti ti-chevron-right ms-auto text-muted"></i>
                        </a>
                        <a href="{{ path('management_interviews') }}" class="btn btn-light text-start d-flex align-items-center gap-3 py-3">
                            <div class="rounded-2 bg-success bg-opacity-10 p-2">
                                <i class="ti ti-message-2 text-success"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">Manage Interviews</div>
                                <small class="text-muted">View and schedule interviews</small>
                            </div>
                            <i class="ti ti-chevron-right ms-auto text-muted"></i>
                        </a>
                        <a href="{{ path('app_admin_add_user') }}" class="btn btn-light text-start d-flex align-items-center gap-3 py-3">
                            <div class="rounded-2 bg-info bg-opacity-10 p-2">
                                <i class="ti ti-user-plus text-info"></i>
                            </div>
                            <div>
                                <div class="fw-semibold">Add New User</div>
                                <small class="text-muted">Create a new user account</small>
                            </div>
                            <i class="ti ti-chevron-right ms-auto text-muted"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-6">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title mb-3">
                        <i class="ti ti-chart-bar text-primary me-2"></i>Analytics Overview
                    </h5>
                    <div class="row g-3">
                        <div class="col-md-6 col-xl-4">
                            <div class="p-3 rounded-3 bg-warning bg-opacity-10">
                                <div class="text-warning fw-bold h4 mb-1">
                                    <a href="{{ path('app_admin_job_offers_statistics') }}" class="text-decoration-none text-warning">
                                        <i class="ti ti-briefcase-2 me-1"></i>Job Offers
                                    </a>
                                </div>
                                <small class="text-muted">Moderation and status overview</small>
                            </div>
                        </div>
                        <div class="col-md-6 col-xl-4">
                            <div class="p-3 rounded-3 bg-primary bg-opacity-10">
                                <div class="text-primary fw-bold h4 mb-1">
                                    <a href="{{ path('management_job_applications_statistics') }}" class="text-decoration-none text-primary">
                                        <i class="ti ti-chart-pie me-1"></i>Applications
                                    </a>
                                </div>
                                <small class="text-muted">View detailed statistics</small>
                            </div>
                        </div>
                        <div class="col-md-6 col-xl-4">
                            <div class="p-3 rounded-3 bg-success bg-opacity-10">
                                <div class="text-success fw-bold h4 mb-1">
                                    <a href="{{ path('management_interviews_statistics') }}" class="text-decoration-none text-success">
                                        <i class="ti ti-chart-bar me-1"></i>Interviews
                                    </a>
                                </div>
                                <small class="text-muted">View detailed statistics</small>
                            </div>
                        </div>
                    </div>
                    <hr class="my-3">
                    <div class="small text-muted">
                        <i class="ti ti-info-circle me-1"></i>
                        Click on the analytics cards above to view detailed charts and metrics for each module.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h5 class="card-title mb-3">
                <i class="ti ti-list-check text-primary me-2"></i>System Status
            </h5>
            <div class="table-responsive">
                <table class="table table-borderless mb-0">
                    <tbody>
                        <tr>
                            <td class="ps-0">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge bg-success rounded-circle p-1">&nbsp;</span>
                                    <span>Job Offer Module</span>
                                </div>
                            </td>
                            <td class="text-end text-success">Active</td>
                        </tr>
                        <tr>
                            <td class="ps-0">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge bg-success rounded-circle p-1">&nbsp;</span>
                                    <span>Application Module</span>
                                </div>
                            </td>
                            <td class="text-end text-success">Active</td>
                        </tr>
                        <tr>
                            <td class="ps-0">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge bg-success rounded-circle p-1">&nbsp;</span>
                                    <span>Interview Module</span>
                                </div>
                            </td>
                            <td class="text-end text-success">Active</td>
                        </tr>
                        <tr>
                            <td class="ps-0">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge bg-success rounded-circle p-1">&nbsp;</span>
                                    <span>Statistics & Analytics</span>
                                </div>
                            </td>
                            <td class="text-end text-success">Active</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
