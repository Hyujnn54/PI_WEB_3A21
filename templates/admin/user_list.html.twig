{% extends 'admin/base_admin.html.twig' %}

{% block admin_content %}
<div class="container-xl">
    <div class="page-header d-print-none mb-4">
        <div class="row align-items-center">
            <div class="col">
                <h2 class="page-title">User Management</h2>
                <div class="text-muted small mt-1">{{ totalCount }} total accounts registered</div>
            </div>
        </div>
    </div>

    <div class="card mb-3 border-0 shadow-sm">
        <div class="card-body p-3">
            <div class="row g-2">
                <div class="col">
                    <div class="input-icon">
                        <span class="input-icon-addon"><i class="ti ti-search text-muted"></i></span>
                        <input type="text" id="js-search-input" class="form-control" 
                               placeholder="Search by name or email..." value="{{ searchTerm }}">
                    </div>
                </div>
                <div class="col-auto">
                    <select id="js-role-filter" class="form-select">
                        <option value="">All Roles</option>
                        <option value="ROLE_ADMIN" {{ currentRole == 'ROLE_ADMIN' ? 'selected' }}>Admins</option>
                        <option value="ROLE_RECRUITER" {{ currentRole == 'ROLE_RECRUITER' ? 'selected' }}>Recruiters</option>
                        <option value="ROLE_CANDIDATE" {{ currentRole == 'ROLE_CANDIDATE' ? 'selected' }}>Candidates</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-vcenter card-table table-striped">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Roles</th>
                        <th>Status</th>
                        <th>Joined Date</th>
                        <th class="w-1">Actions</th>
                    </tr>
                </thead>
                <tbody id="user-table-body">
                    {% include 'admin/_user_table_rows.html.twig' %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const searchInput = document.getElementById('js-search-input');
        const roleSelect = document.getElementById('js-role-filter');
        const tableBody = document.getElementById('user-table-body');

        function updateList() {
            tableBody.style.opacity = '0.5';
            fetch(`{{ path('app_admin_users') }}?search=${searchInput.value}&role=${roleSelect.value}&ajax=1`)
                .then(res => res.text())
                .then(html => {
                    tableBody.innerHTML = html;
                    tableBody.style.opacity = '1';
                });
        }
        searchInput.addEventListener('input', updateList);
        roleSelect.addEventListener('change', updateList);
    });
</script>
{% endblock %}