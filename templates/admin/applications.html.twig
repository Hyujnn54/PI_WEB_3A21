{% extends 'admin/base_admin.html.twig' %}

{% block title %}Talent Bridge | Admin Applications{% endblock %}

{% block admin_content %}
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h1 class="h3 mb-1">All Applications</h1>
                <p class="mb-0 text-muted">Centralized admin view of all job applications in the system.</p>
            </div>
            <span id="adminApplicationRecordCount" class="badge bg-primary-subtle text-primary-emphasis">{{ rows|length }} records</span>
        </div>
    </div>

    <div class="card border mb-3">
        <div class="card-body py-2">
            <form id="adminApplicationFiltersForm" method="get" action="{{ path('management_job_applications') }}" data-data-url="{{ data_url }}">
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-xl-6">
                        <label class="form-label mb-1" for="adminApplicationSearch">Search</label>
                        <div class="input-icon">
                            <span class="input-icon-addon"><i class="ti ti-search"></i></span>
                            <input id="adminApplicationSearch" name="q" type="text" class="form-control" placeholder="Search by offer, candidate, phone, status..." value="{{ filters.q|default('') }}">
                        </div>
                    </div>
                    <div class="col-12 col-md-6 col-xl-3">
                        <label class="form-label mb-1" for="adminApplicationStatusFilter">Filter by Status</label>
                        <select id="adminApplicationStatusFilter" name="status" class="form-select">
                            <option value="all" {{ filters.status|default('all') == 'all' ? 'selected' : '' }}>All Statuses</option>
                            <option value="submitted" {{ filters.status|default('all') == 'submitted' ? 'selected' : '' }}>Submitted</option>
                            <option value="in_review" {{ filters.status|default('all') == 'in_review' ? 'selected' : '' }}>In Review</option>
                            <option value="shortlisted" {{ filters.status|default('all') == 'shortlisted' ? 'selected' : '' }}>Shortlisted</option>
                            <option value="rejected" {{ filters.status|default('all') == 'rejected' ? 'selected' : '' }}>Rejected</option>
                            <option value="interview" {{ filters.status|default('all') == 'interview' ? 'selected' : '' }}>Interview</option>
                            <option value="hired" {{ filters.status|default('all') == 'hired' ? 'selected' : '' }}>Hired</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-6 col-xl-3">
                        <label class="form-label mb-1" for="adminApplicationSortMode">Sort</label>
                        <select id="adminApplicationSortMode" name="sort" class="form-select">
                            <option value="default" {{ filters.sort|default('default') == 'default' ? 'selected' : '' }}>Default Order</option>
                            <option value="title_asc" {{ filters.sort|default('default') == 'title_asc' ? 'selected' : '' }}>Title A-Z</option>
                            <option value="title_desc" {{ filters.sort|default('default') == 'title_desc' ? 'selected' : '' }}>Title Z-A</option>
                            <option value="date_desc" {{ filters.sort|default('default') == 'date_desc' ? 'selected' : '' }}>Date Newest</option>
                            <option value="date_asc" {{ filters.sort|default('default') == 'date_asc' ? 'selected' : '' }}>Date Oldest</option>
                        </select>
                    </div>
                    <div class="col-12 d-flex justify-content-end gap-2">
                        <a href="{{ path('management_job_applications') }}" class="btn btn-outline-secondary">
                            <i class="ti ti-rotate-clockwise-2 me-1"></i>Reset
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-filter me-1"></i>Apply
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card border">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Offer</th>
                        <th>Candidate</th>
                        <th>Phone</th>
                        <th>Status</th>
                        <th>Applied At</th>
                        <th>Archived</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="adminApplicationsTableBody">
                    {% include 'admin/_application_rows.html.twig' with { rows: rows } %}
                </tbody>
            </table>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const filterForm = document.getElementById('adminApplicationFiltersForm');
            const searchInput = document.getElementById('adminApplicationSearch');
            const statusSelect = document.getElementById('adminApplicationStatusFilter');
            const sortSelect = document.getElementById('adminApplicationSortMode');
            const tableBody = document.getElementById('adminApplicationsTableBody');
            const countBadge = document.getElementById('adminApplicationRecordCount');

            if (!filterForm || !tableBody) {
                return;
            }

            const dataUrl = filterForm.getAttribute('data-data-url') || filterForm.getAttribute('action');
            let debounceTimer = null;
            let activeController = null;

            const buildQueryString = function () {
                const params = new URLSearchParams(new FormData(filterForm));
                return params.toString();
            };

            const updateUrl = function (queryString) {
                const actionUrl = filterForm.getAttribute('action') || window.location.pathname;
                const nextUrl = queryString === '' ? actionUrl : actionUrl + '?' + queryString;
                window.history.replaceState({}, '', nextUrl);
            };

            const fetchRows = function () {
                if (activeController) {
                    activeController.abort();
                }

                activeController = new AbortController();

                const queryString = buildQueryString();
                const endpoint = queryString === '' ? dataUrl : dataUrl + '?' + queryString;

                fetch(endpoint, {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    signal: activeController.signal
                })
                    .then(function (response) {
                        if (!response.ok) {
                            throw new Error('Failed to load applications.');
                        }

                        return response.json();
                    })
                    .then(function (payload) {
                        tableBody.innerHTML = payload.rowsHtml || '';
                        if (countBadge) {
                            countBadge.textContent = String(payload.count || 0) + ' records';
                        }
                        updateUrl(queryString);
                    })
                    .catch(function (error) {
                        if (error.name === 'AbortError') {
                            return;
                        }
                    });
            };

            const scheduleFetch = function () {
                if (debounceTimer) {
                    window.clearTimeout(debounceTimer);
                }

                debounceTimer = window.setTimeout(fetchRows, 250);
            };

            if (searchInput) {
                searchInput.addEventListener('input', scheduleFetch);
            }
            if (statusSelect) {
                statusSelect.addEventListener('change', scheduleFetch);
            }
            if (sortSelect) {
                sortSelect.addEventListener('change', scheduleFetch);
            }

            filterForm.addEventListener('submit', function (event) {
                event.preventDefault();
                fetchRows();
            });
        });
    </script>

{% endblock %}
